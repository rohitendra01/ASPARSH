<% layout('layouts/dashboard-boilerplate') %>
<% block('styles').append('<link rel="stylesheet" href="/css/visiting-cards/index.css">') %>
<% const slugSegment = (typeof slug !== 'undefined' && slug) ? '/' + encodeURIComponent(slug) : ''; %>

<link rel="stylesheet" href="/css/visiting-cards/new.css">
<link rel="stylesheet" href="/css/vcard-ui.css">
<link rel="stylesheet" href="/css/fa-all.min.css">

<div class="wz">
  <div class="wz-header">
    <h1>🪪 Create Client vCard</h1>
    <p>Select a design and fill in the card details.</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert-err">⚠️ <%= error %></div>
  <% } %>

  <!-- Progress -->
  <div class="progress-bar">
    <div class="step-node active" id="pn1"><div class="step-dot">1</div><div class="step-lbl">Design</div></div>
    <div class="step-line" id="pl1"></div>
    <div class="step-node" id="pn2"><div class="step-dot">2</div><div class="step-lbl">Card Details</div></div>
    <div class="step-line" id="pl2"></div>
    <div class="step-node" id="pn3"><div class="step-dot">3</div><div class="step-lbl">Confirm</div></div>
  </div>

  <!-- ═══ STEP 1 — Design ═══ -->
  <div id="step-1">
    <% if (!templates || templates.length === 0) { %>
      <div style="text-align:center;padding:3rem;background:#fff;border:1px solid #e2e8f0;border-radius:14px;">
        <div style="font-size:2.5rem;margin-bottom:.8rem">🎨</div>
        <h3>No Design Templates Yet</h3>
        <p style="color:#64748b;margin:.5rem 0 1.2rem">Register a design first before creating a vCard.</p>
        <a href="/dashboard<%= slugSegment %>/templates/new" class="btn btn-primary">+ Add First Template</a>
      </div>
    <% } else { %>

    <div class="step1-layout">
      <!-- LEFT: Template picker -->
      <div class="step1-panel">
        <h3>🎨 Choose a Design <span class="panel-required-badge">Required</span></h3>
        <div class="tmpl-grid">
          <% templates.forEach(function(t) { %>
            <div class="tmpl-card" id="tmpl-card-<%= t._id %>">
              <% if (t.thumbnailUrl) { %>
                <img src="<%= t.thumbnailUrl %>" alt="<%= t.name %>" loading="lazy">
              <% } else { %>
                <div class="tmpl-ph">🎨</div>
              <% } %>
              <div class="tmpl-info">
                <div class="tmpl-info-text">
                  <h4><%= t.name %></h4>
                  <p><%= t.category %></p>
                </div>
                <button type="button" class="btn-select" data-id="<%= t._id %>" data-name="<%= t.name %>" data-category="<%= t.category %>" data-thumb="<%= t.thumbnailUrl || '' %>" onclick="handleSelectTemplate(this)">
                  Select Design
                </button>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- RIGHT: Profile picker -->
      <div class="step1-panel">
        <h3>👤 Link a Customer <span class="panel-required-badge">Required</span></h3>
        <div class="profile-search-box">
          <span class="ico">🔍</span>
          <input type="text" id="profileSearch" placeholder="Search profiles to link..." autocomplete="off">
        </div>
        <div class="sel-profile-strip" id="selProfileStrip">
          <span id="selProfileLabel">—</span>
          <button type="button" onclick="clearProfile()" title="Remove link">✕</button>
        </div>
        <div class="profile-list" id="profileList">
          <% if (profiles && profiles.length > 0) { %>
            <% profiles.forEach(function(p) { %>
              <div class="profile-item" id="prof-item-<%= p._id %>">
                <div class="profile-avatar">
                  <% if (p.image) { %><img src="<%= p.image %>" alt="<%= p.name %>" style="width:100%;height:100%;object-fit:cover;"><% } else { %><%= (p.name||'?')[0].toUpperCase() %><% } %>
                </div>
                <div class="profile-meta">
                  <div class="pname"><%= p.name %></div>
                  <div class="pdetail"><%= p.occupation || p.email || p.mobile || p.slug %></div>
                </div>
                <button type="button" class="btn-select-profile" data-id="<%= p._id %>" data-slug="<%= p.slug %>" data-name="<%= p.name %>" onclick="handleSelectProfile(this)">Select</button>
              </div>
            <% }); %>
          <% } else { %>
            <div class="no-profiles" id="noProfMsg">No profiles yet. <a href="/dashboard<%= slugSegment %>/profiles/new" style="color:#6366f1;font-weight:600;">Create one?</a></div>
          <% } %>
        </div>
      </div>
    </div>

    <% } %>

    <div class="wz-actions" style="margin-top:1.2rem;">
      <a href="/dashboard<%= slugSegment %>/visiting-cards" class="btn btn-secondary">Cancel</a>
      <div class="right">
        <button type="button" class="btn btn-primary" id="step1Next" onclick="goToStep2()" disabled>
          Next: Fill Details →
        </button>
      </div>
    </div>
  </div>

  <!-- ═══ STEP 2 — Card Data Form ═══ -->
  <div id="step-2" style="display:none;">
    <!-- Summary bar -->
    <div class="sel-bar">
      <div class="sel-bar-item">
        <img id="selThumbImg" src="" alt="" style="display:none;">
        <div><div class="lbl">Design</div><div class="val" id="selTmplName">—</div></div>
      </div>
    </div>

    <form id="vcardForm"
          action="/dashboard<%= slugSegment %>/visiting-cards"
          method="POST"
          enctype="multipart/form-data">
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>
      <input type="hidden" name="templateId" id="templateIdInput">
      <input type="hidden" name="profileId" id="profileIdInput">

      <!-- 1. Profile / Identity -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">👤 Core Identity</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div class="g2">
          <div class="f">
            <label>Full Name <span class="req">*</span></label>
            <input type="text" name="profile[fullName]" required placeholder="Dr. Rohit Verma / ABC Corp" id="inp-fullName">
          </div>
          <div class="f">
            <label>Designation</label>
            <input type="text" name="profile[designation]" placeholder="Senior Cardiologist / CEO">
          </div>
          <div class="f">
            <label>Company / Firm Name</label>
            <input type="text" name="profile[companyName]" placeholder="City Heart Hospital">
          </div>

          <div class="f">
            <label>Logo / Brand Image <small class="hint">(Upload file)</small></label>
            <div class="img-field-wrap">
              <label class="file-label" for="inp-logoUrl" id="lbl-logoUrl">
                <span>🖼️</span> Choose Logo
                <img class="img-thumb" id="prev-logoUrl" alt="">
              </label>
              <input type="file" id="inp-logoUrl" name="profile[logoUrl]" accept="image/*">
            </div>
          </div>
          <div class="f">
            <label>Profile / Hero Photo <small class="hint">(Upload file)</small></label>
            <div class="img-field-wrap">
              <label class="file-label" for="inp-profileImage" id="lbl-profileImage">
                <span>📷</span> Choose Photo
                <img class="img-thumb" id="prev-profileImage" alt="">
              </label>
              <input type="file" id="inp-profileImage" name="profile[profileImage]" accept="image/*">
            </div>
          </div>
          <div class="f">
            <label>Cover / Banner Image <small class="hint">(Upload file)</small></label>
            <div class="img-field-wrap">
              <label class="file-label" for="inp-coverImage" id="lbl-coverImage">
                <span>🖼️</span> Choose Banner
                <img class="img-thumb" id="prev-coverImage" alt="">
              </label>
              <input type="file" id="inp-coverImage" name="profile[coverImage]" accept="image/*">
            </div>
          </div>
          <div class="f">
             <!-- Cover spacer to align grid elements depending on columns -->
          </div>
          <div class="f span2">
            <label>Bio / Introduction</label>
            <textarea name="profile[bio]" placeholder="Short intro about this person or business…"></textarea>
          </div>
        </div>

        <div style="margin-top:1.5rem">
          <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:.4rem;">Custom Profile Fields</label>
          <div id="customFieldsContainer"></div>
          <button type="button" class="add-row-btn" onclick="addCustomField()">+ Add Custom Field</button>
        </div>
      </div>
</div>

      <!-- 2. Contact & Hours -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">📞 Contact Information & Hours</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div class="g2">
          <div class="f"><label>Primary Phone</label><input type="tel" name="contact[primaryPhone]" placeholder="+91 98765 43210"></div>
          <div class="f"><label>Primary Email</label><input type="email" name="contact[primaryEmail]" placeholder="contact@example.com"></div>
          <div class="f"><label>Website</label><input type="url" name="contact[website]" placeholder="https://example.com"></div>
          <div class="f"><label>Business Hours</label><input type="text" name="contact[businessHours]" placeholder="Mon-Fri: 9AM - 8PM"></div>
          <div class="f"><label>Address</label><input type="text" name="contact[location][address]" placeholder="Plot 12, MG Road"></div>
          <div class="f"><label>Google Maps Embed URL</label><input type="url" name="contact[location][mapEmbedUrl]" placeholder="https://maps.google.com/…"></div>
        </div>

        <div style="margin-top:1rem;">
          <label style="font-size:.78rem;font-weight:600;color:#374151;display:block;margin-bottom:.4rem;">Additional Contacts <small class="hint">(Fax, Skype, Telegram, etc.)</small></label>
          <div id="additionalContactsContainer"></div>
          <button type="button" class="add-row-btn" onclick="addAdditionalContact()">+ Add Contact</button>
        </div>
      </div>
</div>

      <!-- 3. Social Media -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🔗 Social Media Links</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="socialsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addSocial()">+ Add Social Link</button>
      </div>
</div>

      <!-- 4a. Hero Stats -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">⭐ Hero Stats (Top Section)</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="heroStatsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addHeroStat()">+ Add Hero Stat</button>
      </div>
</div>

      <!-- 4. Stats -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">📊 Highlights & Stats</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="statsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addStat()">+ Add Stat</button>
      </div>
</div>

      <!-- 5. Services / Offerings -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🛠️ Services / Offerings</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="servicesContainer"></div>
        <button type="button" class="add-row-btn" onclick="addService()">+ Add Service / Item</button>
      </div>
</div>

      <!-- 6. Pricing Plans -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">💰 Pricing Packages</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="pricingContainer"></div>
        <button type="button" class="add-row-btn" onclick="addPricing()">+ Add Package</button>
      </div>
</div>

      <!-- 7. Portfolio (Links/Videos) -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🎬 Portfolio / Media Links</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="portfolioContainer"></div>
        <button type="button" class="add-row-btn" onclick="addPortfolio()">+ Add Video / Link</button>
      </div>
</div>

      <!-- 8. Gallery (Images) -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🖼️ Gallery Images</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="galleryContainer"></div>
        <button type="button" class="add-row-btn" onclick="addGallery()">+ Add Gallery Image</button>
      </div>
</div>

      <!-- 9. Experience / Timeline -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">💼 Experience / Timeline</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="experienceContainer"></div>
        <button type="button" class="add-row-btn" onclick="addExperience()">+ Add Entry</button>
      </div>
</div>

      <!-- 10. Testimonials -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">⭐ Testimonials / Reviews</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="testimonialsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addTestimonial()">+ Add Review</button>
      </div>
</div>

      <!-- 11. Partners -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🤝 Partners / Affiliates</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="partnersContainer"></div>
        <button type="button" class="add-row-btn" onclick="addPartner()">+ Add Partner</button>
      </div>
</div>

      <!-- 12. Specializations -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🗂️ Specializations (Secondary)</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="specializationsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addSpecialization()">+ Add Specialization</button>
      </div>
</div>

      <!-- 13. Qualifications / Simple List -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">📜 Qualifications / Certifications</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <p class="hint">Enter one per line.</p>
        <div class="f">
          <textarea name="qualifications" rows="4" placeholder="MD General Medicine&#10;Member of Medical Association"></textarea>
        </div>
      </div>
</div>

            <!-- 14. Process -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🔄 Process / Steps</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="processContainer"></div>
        <button type="button" class="add-row-btn" onclick="addProcess()">+ Add Step</button>
      </div>
</div>

      <!-- 15. FAQs -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">❓ FAQs (Frequently Asked Questions)</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div id="faqsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addFaq()">+ Add FAQ</button>
      </div>
</div>

      <!-- 16. Tags -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🏷️ Tags / Keywords</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <p class="hint">Type a keyword and press Enter or comma.</p>
        <div class="form-field f" style="max-width: 500px;">
          <div id="tagsWrapper" class="tags-input-wrapper">
            <input type="text" placeholder="Add a tag..." autocomplete="off">
            <input type="hidden" name="tags" id="tagsHidden" value="<%= (typeof card !== 'undefined' && card.tags ? JSON.stringify(card.tags) : '[]') %>">
          </div>
        </div>
      </div>
</div>

      <!-- 17. Call to Action -->
      <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">📣 Call To Action (Bottom Section)</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div class="g2 field-grid">
          <div class="f form-field"><label>Title</label><input type="text" name="callToAction[title]" value="<%= (typeof card !== 'undefined' && card.callToAction && card.callToAction.title) ? card.callToAction.title : '' %>"></div>
          <div class="f form-field"><label>Button Text</label><input type="text" name="callToAction[buttonText]" value="<%= (typeof card !== 'undefined' && card.callToAction && card.callToAction.buttonText) ? card.callToAction.buttonText : '' %>"></div>
          <div class="f form-field"><label>Button Link</label><input type="url" name="callToAction[buttonLink]" value="<%= (typeof card !== 'undefined' && card.callToAction && card.callToAction.buttonLink) ? card.callToAction.buttonLink : '' %>"></div>
          <div class="f form-field" style="grid-column:1 / -1;"><label>Description</label><textarea name="callToAction[description]"><%= (typeof card !== 'undefined' && card.callToAction && card.callToAction.description) ? card.callToAction.description : '' %></textarea></div>
        </div>
      </div>
</div>


      <!-- (Hero Images moved to Section 1) -->
      <div class="card-block open sec-purple">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🎨 Theme & Section Titles</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
        <div class="g3">
          <div class="f"><label>Primary Color</label><input type="color" name="theme[primaryColor]" value="#1e40af"></div>
          <div class="f"><label>Secondary Color</label><input type="color" name="theme[secondaryColor]" value="#0891b2"></div>
          <div class="f">
            <label>Font Style</label>
            <select name="theme[fontStyle]">
              <option value="Inter">Inter</option>
              <option value="Roboto">Roboto</option>
              <option value="Poppins">Poppins</option>
              <option value="Merriweather">Merriweather</option>
              <option value="Lato">Lato</option>
              <option value="Outfit">Outfit</option>
            </select>
          </div>
        </div>
        <div class="g2" style="margin-top:1.5rem">
           <div class="f"><label>"Services" Section Title</label><input type="text" name="theme[sectionTitles][services]" placeholder="Our Services"></div>
           <div class="f"><label>"Services" Section Subtitle</label><input type="text" name="theme[sectionDescriptions][services]" placeholder="Describe your services..."></div>
           <div class="f"><label>"Experience" Section Title</label><input type="text" name="theme[sectionTitles][experience]" placeholder="Experience"></div>
           <div class="f"><label>"Gallery" Section Title</label><input type="text" name="theme[sectionTitles][gallery]" placeholder="Gallery"></div>
           <div class="f"><label>"Partners" Section Title</label><input type="text" name="theme[sectionTitles][partners]" placeholder="Our Partners"></div>
           <div class="f"><label>"Stats" Section Title</label><input type="text" name="theme[sectionTitles][stats]" placeholder="Medical Excellence"></div>
           <div class="f form-field"><label>"Faqs" Title</label><input type="text" name="theme[sectionTitles][faqs]" placeholder="Faqs"></div>
           <div class="f form-field"><label>"Faqs" Subtitle</label><input type="text" name="theme[sectionDescriptions][faqs]" placeholder=""></div>

           <div class="f form-field"><label>"Portfolio" Title</label><input type="text" name="theme[sectionTitles][portfolio]" placeholder="Portfolio"></div>
           <div class="f form-field"><label>"Portfolio" Subtitle</label><input type="text" name="theme[sectionDescriptions][portfolio]" placeholder=""></div>

           <div class="f form-field"><label>"Process" Title</label><input type="text" name="theme[sectionTitles][process]" placeholder="Process"></div>
           <div class="f form-field"><label>"Process" Subtitle</label><input type="text" name="theme[sectionDescriptions][process]" placeholder=""></div>

           <div class="f form-field"><label>"Pricing" Title</label><input type="text" name="theme[sectionTitles][pricing]" placeholder="Pricing"></div>
           <div class="f form-field"><label>"Pricing" Subtitle</label><input type="text" name="theme[sectionDescriptions][pricing]" placeholder=""></div>

           <div class="f form-field"><label>"About" Title</label><input type="text" name="theme[sectionTitles][about]" placeholder="About"></div>
           <div class="f form-field"><label>"About" Subtitle</label><input type="text" name="theme[sectionDescriptions][about]" placeholder=""></div>

        </div>
      </div>

      <div class="wz-actions">
        <button type="button" class="btn btn-secondary" onclick="goToStep(1)">← Back</button>
        <div class="right">
          <button type="button" class="btn btn-primary" onclick="goToStep(3)">Review & Confirm →</button>
        </div>
      </div>
    </form>
  </div>
</div>

  <!-- ═══ STEP 3 — Confirm ═══ -->
  <div id="step-3" style="display:none;">
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">✅ Ready to Create</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="reviewSummary" class="review-grid"></div>
    </div>
    <div class="wz-actions">
      <button type="button" class="btn btn-secondary" onclick="goToStep(2)">← Back to Edit</button>
      <div class="right">
        <button type="button" class="btn btn-primary" id="finalBtn" onclick="submitForm()">🚀 Create vCard</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/vcard-ui.js"></script>
<script>
// ─── State ───────────────────────────
let selTemplate = null;
let currentStep = 1;

// ─── Template selection ──────────────
function handleSelectTemplate(btn) {
  selectTemplate(btn.dataset.id, btn.dataset.name, btn.dataset.category, btn.dataset.thumb);
}

function selectTemplate(id, name, category, thumb) {
  document.querySelectorAll('.tmpl-card').forEach(c => {
    c.classList.remove('sel');
    c.querySelector('.btn-select').textContent = "Select Design";
  });
  const el = document.getElementById('tmpl-card-' + id);
  if(el) {
    el.classList.add('sel');
    el.querySelector('.btn-select').textContent = "✅ Selected";
  }
  selTemplate = { id, name, category, thumb };
  checkStep1Next();
}

// ─── Profile selection ───────────────
let selProfile = null;
function handleSelectProfile(btn) {
  selectProfile(btn.dataset.id, btn.dataset.slug, btn.dataset.name);
}

function selectProfile(id, slug, name) {
  const el = document.getElementById('prof-item-' + id);
  // Toggle off if already selected
  if (el && el.classList.contains('sel')) {
    clearProfile();
    return;
  }
  
  document.querySelectorAll('.profile-item').forEach(i => {
    i.classList.remove('sel');
    i.querySelector('.btn-select-profile').textContent = "Select";
  });
  
  if (el) {
    el.classList.add('sel');
    el.querySelector('.btn-select-profile').textContent = "✅ Selected";
  }
  
  selProfile = { id, slug, name };
  document.getElementById('profileIdInput').value = id;
  document.getElementById('selProfileLabel').textContent = selProfile.name;
  document.getElementById('selProfileStrip').classList.add('show');
  
  // Auto-fill name
  const nameFld = document.getElementById('inp-fullName');
  if (nameFld && !nameFld.value) nameFld.value = selProfile.name;

  checkStep1Next();
}

function clearProfile() {
  selProfile = null;
  document.getElementById('profileIdInput').value = '';
  document.getElementById('selProfileStrip').classList.remove('show');
  document.querySelectorAll('.profile-item').forEach(i => {
    i.classList.remove('sel');
    const btn = i.querySelector('.btn-select-profile');
    if(btn) btn.textContent = "Select";
  });
  checkStep1Next();
}

function checkStep1Next() {
  const btn = document.getElementById('step1Next');
  if (btn) {
    btn.disabled = !(selTemplate && selProfile);
  }
}

// ─── Profile SEARCH (AJAX) ─────────────
let profileSearchTimeout = null;
const origProfilesHtml = document.getElementById('profileList') ? document.getElementById('profileList').innerHTML : '';

const profileSearchInput = document.getElementById('profileSearch');
if (profileSearchInput) {
  profileSearchInput.addEventListener('input', function() {
    clearTimeout(profileSearchTimeout);
    const q = this.value.trim();
    if (q.length < 2) {
      if (q.length === 0) {
        document.getElementById('profileList').innerHTML = origProfilesHtml;
        if(selProfile) selectProfile(selProfile.id, selProfile.slug, selProfile.name); // re-highlight
      }
      return;
    }
    
    // Show loading
    document.getElementById('profileList').innerHTML = '<div class="no-profiles">Searching...</div>';
    
    profileSearchTimeout = setTimeout(async () => {
      try {
        const resp = await fetch(`/api/profiles/search?q=${encodeURIComponent(q)}`);
        const json = await resp.json();
        
        let html = '';
        if (json.success && json.data && json.data.length > 0) {
          json.data.forEach(p => {
             const isSel = selProfile && selProfile.id === p._id;
             const safeName = (p.name || '').replace(/'/g, "\\'");
             const init = p.name ? p.name[0].toUpperCase() : '?';
             const avatar = p.image ? `<img src="${p.image}" style="width:100%;height:100%;object-fit:cover;">` : init;
             
             html += `
              <div class="profile-item ${isSel ? 'sel' : ''}" id="prof-item-${p._id}">
                <div class="profile-avatar">${avatar}</div>
                <div class="profile-meta">
                  <div class="pname">${p.name}</div>
                  <div class="pdetail">${p.occupation || p.email || p.mobile || p.slug || ''}</div>
                </div>
                <button type="button" class="btn-select-profile" data-id="${p._id}" data-slug="${p.slug}" data-name="${safeName}" onclick="handleSelectProfile(this)">
                  ${isSel ? '✅ Selected' : 'Select'}
                </button>
              </div>`;
          });
        } else {
          html = '<div class="no-profiles">No profiles found for "'+q+'"</div>';
        }
        document.getElementById('profileList').innerHTML = html;
        
      } catch(err) {
        document.getElementById('profileList').innerHTML = '<div class="no-profiles" style="color:#ef4444">Search failed.</div>';
      }
    }, 400); // debounce 400ms
  });
}

// ─── Step navigation ─────────────────
async function goToStep2() {
  if (!selTemplate) return;
  document.getElementById('templateIdInput').value = selTemplate.id;
  document.getElementById('selTmplName').textContent = selTemplate.name;
  const img = document.getElementById('selThumbImg');
  if (selTemplate.thumb) { img.src = selTemplate.thumb; img.style.display = ''; } else img.style.display = 'none';

  // Fetch Custom Fields Schema for this template
  try {
    const slugSegment = '<%= slugSegment %>'; // or use the variable from EJS
    const res = await fetch(`/dashboard${slugSegment}/visiting-cards/template/${selTemplate.id}/schema`);
    const data = await res.json();
    const container = document.getElementById('customFieldsContainer');
    container.innerHTML = ''; // clear

    if (data.customFields && data.customFields.length > 0) {
      data.customFields.forEach(field => {
        const row = document.createElement('div');
        row.className = 'f';
        const typeMap = {
          'text': 'text',
          'url': 'url',
          'color': 'color'
        };
        const inputType = typeMap[field.type] || 'text';
        
        let reqHTML = field.required ? '<span class="req">*</span>' : '';
        let inputHTML = '';
        
        if (field.type === 'textarea') {
           inputHTML = `<textarea name="profile[customFields][${field.name}]" ${field.required ? 'required' : ''}></textarea>`;
        } else if (field.type === 'image') {
           inputHTML = `<input type="file" name="profile[customFields][${field.name}]" accept="image/*" ${field.required ? 'required' : ''}>`;
        } else {
           inputHTML = `<input type="${inputType}" name="profile[customFields][${field.name}]" ${field.required ? 'required' : ''}>`;
        }

        row.innerHTML = `<label>${field.label} ${reqHTML} <small style="color:#94a3b8;font-weight:normal;">(${field.name})</small></label>${inputHTML}`;
        container.appendChild(row);
      });
    }
  } catch (err) {
    console.error('Failed to load template schema:', err);
  }

  goToStep(2);
}

function goToStep(n) {
  [1,2,3].forEach(i => {
    document.getElementById('step-' + i).style.display = (i === n) ? '' : 'none';
    const nd = document.getElementById('pn' + i);
    nd.classList.remove('active','done');
    if (i < n)  nd.classList.add('done');
    if (i === n) nd.classList.add('active');
    if (i <= 2) document.getElementById('pl' + i).classList.toggle('done', i < n);
  });
  currentStep = n;
  if (n === 3) buildReview();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}


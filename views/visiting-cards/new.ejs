<% layout('layouts/dashboard-boilerplate') %>
<% block('styles').append('<link rel="stylesheet" href="/css/portfolio/business/visiting-card.css">') %>
<% // Pre-encode slug for safe URL usage and avoid double slashes
  const slugSegment = (typeof slug !== 'undefined' && slug) ? '/' + encodeURIComponent(slug) : ''; %>

<div class="visiting-card-form-root">
  <h1>Create Visiting Card</h1>

  <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
    <input type="hidden" id="_csrf" name="_csrf" value="<%= csrfToken %>">
  <% } %>

  <form action="/dashboard/<%= slug || '' %>/visiting-cards" method="POST" enctype="application/x-www-form-urlencoded">
    <% if (profile && profile._id) { %>
      <input type="hidden" name="profileSlug" value="<%= profile.slug %>">
      <input type="hidden" name="slug" value="<%= slug || '' %>">
    <% } else { %>
      <input type="hidden" name="profileSlug" value="">
      <input type="hidden" name="slug" value="">
    <% } %>

    <!-- If a profile is attached, show summary and use its data by default -->
    <% if (profile) { %>
      <div class="attached-profile">
        <strong>Attached profile:</strong> <%= profile.name %> — <%= profile.email || profile.mobile || profile.slug %>
      </div>
      <p>Most fields will be pre-filled from the attached profile. Uncheck "Use profile data" below to provide custom values.</p>
      <label>
        <input type="checkbox" id="use-profile-data" checked> Use profile data (disable to override)
      </label>
    <% } else { %>
      <!-- Profile search / attach -->
      <label>
        Attach Profile
        <input id="profile-search" type="search" placeholder="Search profile by name, email or slug..." autocomplete="off">
      </label>
      <div id="profile-suggestions" class="suggestions"></div>
      <div id="selected-profile" class="selected-profile">No profile selected</div>
    <% } %>

    <!-- Visiting-card fields: keep only card-specific fields. Contact/name/image come from Profile. -->
    <label>
      Title / Designation
      <input type="text" name="title" id="field-title" value="" required>
    </label>

    <label>
      Description
      <textarea name="description" id="field-description" rows="4" required></textarea>
    </label>

    <label>
      Website (optional)
      <input type="url" name="website" id="field-website" value="">
    </label>


    <div class="form-actions">
  <button type="submit" class="btn btn-primary">Create Visiting Card</button>
  <a href="/dashboard<%= slugSegment %>/visiting-cards" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

<script>
// Profile search helper
;(function(){
  const input = document.getElementById('profile-search');
  const suggestions = document.getElementById('profile-suggestions');
  const selected = document.getElementById('selected-profile');
  const profileIdField = document.querySelector('input[name="profileSlug"]');
  const slugField = document.querySelector('input[name="slug"]');

  let timeout = null;
  input && input.addEventListener('input', function(e){
    const q = (e.target.value || '').trim();
    suggestions.innerHTML = '';
    if (timeout) clearTimeout(timeout);
    if (!q || q.length < 2) return;
    timeout = setTimeout(async ()=>{
      try {
        const res = await fetch('/api/profiles/search?q=' + encodeURIComponent(q));
        if (!res.ok) return;
        const profiles = await res.json();
        suggestions.innerHTML = '';
        profiles.forEach(p => {
          const div = document.createElement('div');
          div.className = 'suggestion-item';
          div.textContent = (p.name || p.slug || p.email) + ' — ' + (p.email || p.slug || '');
          div.dataset.id = p._id;
          div.dataset.slug = p.slug;
          div.addEventListener('click', ()=>{
            profileIdField.value = p.slug || '';
            slugField.value = p.slug || '';
            selected.textContent = (p.name || p.slug || '') + ' — ' + (p.email || '');
            suggestions.innerHTML = '';
            input.value = '';
          });
          suggestions.appendChild(div);
        });
      } catch (err) {
        console.error('Profile search error', err);
      }
    }, 250);
  });
})();
</script>
<script>
  // Toggle override is now limited to card-level fields (none of which conflict with Profile)
;(function(){
  const useProfileCheckbox = document.getElementById('use-profile-data');
  if (!useProfileCheckbox) return;
  // No inputs to disable in the current design; keep UI for clarity
})();

// (legacy duplicate profileId script removed) - profileSlug search handler above is used
</script>

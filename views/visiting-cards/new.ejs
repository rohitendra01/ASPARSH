<script>
// ─── State ───────────────────────────
let selTemplate = null;
let currentStep = 1;

// ─── Template selection ──────────────
function handleSelectTemplate(btn) {
  selectTemplate(btn.dataset.id, btn.dataset.name, btn.dataset.category, btn.dataset.thumb);
}

function selectTemplate(id, name, category, thumb) {
  document.querySelectorAll('.tmpl-card').forEach(c => {
    c.classList.remove('sel');
    c.querySelector('.btn-select').textContent = "Select Design";
  });
  const el = document.getElementById('tmpl-card-' + id);
  if(el) {
    el.classList.add('sel');
    el.querySelector('.btn-select').textContent = "✅ Selected";
  }
  selTemplate = { id, name, category, thumb };
  checkStep1Next();
}

// ─── Profile selection ───────────────
let selProfile = null;
function handleSelectProfile(btn) {
  selectProfile(btn.dataset.id, btn.dataset.slug, btn.dataset.name);
}

function selectProfile(id, slug, name) {
  const el = document.getElementById('prof-item-' + id);
  // Toggle off if already selected
  if (el && el.classList.contains('sel')) {
    clearProfile();
    return;
  }
  
  document.querySelectorAll('.profile-item').forEach(i => {
    i.classList.remove('sel');
    i.querySelector('.btn-select-profile').textContent = "Select";
  });
  
  if (el) {
    el.classList.add('sel');
    el.querySelector('.btn-select-profile').textContent = "✅ Selected";
  }
  
  selProfile = { id, slug, name };
  document.getElementById('profileIdInput').value = id;
  document.getElementById('selProfileLabel').textContent = selProfile.name;
  document.getElementById('selProfileStrip').classList.add('show');
  
  // Auto-fill name
  const nameFld = document.getElementById('inp-fullName');
  if (nameFld && !nameFld.value) nameFld.value = selProfile.name;

  checkStep1Next();
}

function clearProfile() {
  selProfile = null;
  document.getElementById('profileIdInput').value = '';
  document.getElementById('selProfileStrip').classList.remove('show');
  document.querySelectorAll('.profile-item').forEach(i => {
    i.classList.remove('sel');
    const btn = i.querySelector('.btn-select-profile');
    if(btn) btn.textContent = "Select";
  });
  checkStep1Next();
}

function checkStep1Next() {
  const btn = document.getElementById('step1Next');
  if (btn) {
    btn.disabled = !(selTemplate && selProfile);
  }
}

// ─── Profile SEARCH (AJAX) ─────────────
let profileSearchTimeout = null;
const origProfilesHtml = document.getElementById('profileList') ? document.getElementById('profileList').innerHTML : '';

const profileSearchInput = document.getElementById('profileSearch');
if (profileSearchInput) {
  profileSearchInput.addEventListener('input', function() {
    clearTimeout(profileSearchTimeout);
    const q = this.value.trim();
    if (q.length < 2) {
      if (q.length === 0) {
        document.getElementById('profileList').innerHTML = origProfilesHtml;
        if(selProfile) selectProfile(selProfile.id, selProfile.slug, selProfile.name); // re-highlight
      }
      return;
    }
    
    // Show loading
    document.getElementById('profileList').innerHTML = '<div class="no-profiles">Searching...</div>';
    
    profileSearchTimeout = setTimeout(async () => {
      try {
        const resp = await fetch(`/api/profiles/search?q=${encodeURIComponent(q)}`);
        const json = await resp.json();
        
        let html = '';
        if (json.success && json.data && json.data.length > 0) {
          json.data.forEach(p => {
             const isSel = selProfile && selProfile.id === p._id;
             const safeName = (p.name || '').replace(/'/g, "\\'");
             const init = p.name ? p.name[0].toUpperCase() : '?';
             const avatar = p.image ? `<img src="${p.image}" style="width:100%;height:100%;object-fit:cover;">` : init;
             
             html += `
              <div class="profile-item ${isSel ? 'sel' : ''}" id="prof-item-${p._id}">
                <div class="profile-avatar">${avatar}</div>
                <div class="profile-meta">
                  <div class="pname">${p.name}</div>
                  <div class="pdetail">${p.occupation || p.email || p.mobile || p.slug || ''}</div>
                </div>
                <button type="button" class="btn-select-profile" data-id="${p._id}" data-slug="${p.slug}" data-name="${safeName}" onclick="handleSelectProfile(this)">
                  ${isSel ? '✅ Selected' : 'Select'}
                </button>
              </div>`;
          });
        } else {
          html = '<div class="no-profiles">No profiles found for "'+q+'"</div>';
        }
        document.getElementById('profileList').innerHTML = html;
        
      } catch(err) {
        document.getElementById('profileList').innerHTML = '<div class="no-profiles" style="color:#ef4444">Search failed.</div>';
      }
    }, 400); // debounce 400ms
  });
}

// ─── Step navigation ─────────────────
async function goToStep2() {
  if (!selTemplate) return;
  document.getElementById('templateIdInput').value = selTemplate.id;
  document.getElementById('selTmplName').textContent = selTemplate.name;
  const img = document.getElementById('selThumbImg');
  if (selTemplate.thumb) { img.src = selTemplate.thumb; img.style.display = ''; } else img.style.display = 'none';
  goToStep(2);
}

function goToStep(n) {
  [1,2,3].forEach(i => {
    document.getElementById('step-' + i).style.display = (i === n) ? '' : 'none';
    const nd = document.getElementById('pn' + i);
    nd.classList.remove('active','done');
    if (i < n)  nd.classList.add('done');
    if (i === n) nd.classList.add('active');
    if (i <= 2) document.getElementById('pl' + i).classList.toggle('done', i < n);
  });
  currentStep = n;
  if (n === 3) buildReview();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}


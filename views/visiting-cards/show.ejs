<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asparsh | Visiting Card</title>
    <link rel="stylesheet" href="/css/visiting-cards/visiting-card.css">
    <link rel="stylesheet" href="/css/visiting-cards/visiting-show.css">
    <script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
</head>
<body>
    <% 
        // Prefer visiting card values, fall back to attached profile where available
        const profileData = typeof profile !== 'undefined' ? profile : null;
        const getProfileSocial = (platform) => {
            if (!profileData || !Array.isArray(profileData.socialLinks)) return null;
            const found = profileData.socialLinks.find(s => s.platform && s.platform.toLowerCase() === platform.toLowerCase());
            return found ? found.url : null;
        };
        const cardOrProfile = (key) => {
            if (card && card[key]) return card[key];
            if (key === 'email' && profileData && profileData.email) return profileData.email;
            if (key === 'phone' && profileData && profileData.mobile) return profileData.mobile;
            if (key === 'image' && profileData && profileData.image) return profileData.image;
            if (key === 'name' && profileData && profileData.name) return profileData.name;
            if (key === 'address' && profileData && profileData.address) {
                const addr = profileData.address || {};
                return [addr.addressLine, addr.city, addr.state, addr.country, addr.postcode].filter(Boolean).join(', ');
            }
            return null;
        };
    %>

    <div class="container">
        <div class="card">
            <div class="profile-section">
                <div class="profile-image-wrapper">
                    <div class="profile-gradient"></div>
                    <div class="profile-image-container">
                        <% const headerImg = cardOrProfile('image'); %>
                        <% if (headerImg) { %>
                            <img src="<%= headerImg %>" alt="<%= cardOrProfile('name') || 'Visiting Card' %>" class="profile-image" />
                        <% } else { %>
                            <img src="/assets/portfolio-image.jpg" alt="Visiting Card Header Image" class="profile-image" />
                        <% } %>
                    </div>
                </div>
                <h1 class="profile-name"><%= cardOrProfile('name') || '' %></h1>
                <p class="profile-title"><%= card && card.title ? card.title : '' %></p>
                <% if (profile && profile.address) { %>
                    <p class="profile-location"><%= profile.address.city %>, <%= profile.address.state %></p>
                <% } %>
            </div>

            <div class="contact-section">
                <div class="contact-item">
                    <i data-feather="mail" class="contact-icon"></i>
                    <span class="contact-text"><%= profile.email %></span>
                </div>
                <div class="contact-item">
                    <i data-feather="phone" class="contact-icon"></i>
                    <span class="contact-text">+91 <%= profile.mobile %></span>
                </div>
                <div class="contact-item">
                    <i data-feather="map-pin" class="contact-icon"></i>
                    <span class="contact-text"><%= profile.address.city %>, <%= profile.address.state %></span>
                </div>
            </div>
            
            <div class="social-section">
                <% const gitHubLink = getProfileSocial('github'); %>
                <% const linkedinLink = getProfileSocial('linkedin'); %>
                <% const twitterLink = getProfileSocial('twitter'); %>
                <% const facebookLink = getProfileSocial('facebook'); %>
                <% const instagramLink = getProfileSocial('instagram'); %>
                <% const emailLink = cardOrProfile('email'); %>

                <p class="social-title">Connect with me</p>
                <div class="social-links">
                    <% if (gitHubLink) { %>
                        <a href="<%= gitHubLink %>" class="social-link" target="_blank" aria-label="GitHub">
                            <i data-feather="github" class="social-icon"></i>
                        </a>
                    <% } %>

                    <% if (linkedinLink) { %>
                        <a href="<%= linkedinLink %>" class="social-link" target="_blank" aria-label="LinkedIn">
                            <i data-feather="linkedin" class="social-icon"></i>
                        </a>
                    <% } %>

                    <% if (twitterLink) { %>
                        <a href="<%= twitterLink %>" class="social-link" target="_blank" aria-label="Twitter">
                            <i data-feather="twitter" class="social-icon"></i>
                        </a>
                    <% } %>

                    <% if (instagramLink) { %>
                        <a href="<%= instagramLink %>" class="social-link" target="_blank" aria-label="Instagram">
                            <i data-feather="instagram" class="social-icon"></i>
                        </a>
                    <% } %>

                    <% if (facebookLink) { %>
                        <a href="<%= facebookLink %>" class="social-link" target="_blank" aria-label="Facebook">
                            <i data-feather="facebook" class="social-icon"></i>
                        </a>
                    <% } %>

                    <% if (emailLink) { %>
                        <a href="mailto:<%= emailLink %>" class="social-link" aria-label="Email">
                            <i data-feather="mail" class="social-icon"></i>
                        </a>
                    <% } %>
                </div>
            </div>

            <div class="buttons-section">
                <button id="save-contact-btn" class="action-btn btn-white">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </svg>
                    Save Contact
                </button>
                <button id="save-cv-btn" class="action-btn btn-purple">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Save CV
                </button>
                <button id="share-whatsapp-btn" class="action-btn btn-green">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    Share via WhatsApp
                </button>
                <button id="website-btn" class="action-btn btn-white">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                    </svg>
                    Website
                </button>
            </div>

            <div class="bio-box">
                <h3 class="bio-title">
                    <i data-feather="user" class="bio-icon"></i>
                    About Me
                </h3>
                <p class="bio-text"><%= card && card.description ? card.description : 'No description available' %></p>
            </div>
            
            <div class="footer">
                <p class="footer-text">
                    Powered by <span class="footer-brand">ASPARSH</span>
                </p>
                <p class="footer-copyright">
                    © 2025 All rights reserved
                </p>
            </div>
        </div>
    </div>

    <script>
        // Initialize Feather Icons
        feather.replace();

        // Get profile data from EJS
        const profileData = {
            name: '<%= profile.name %>',
            email: '<%= profile.email %>',
            mobile: '<%= profile.mobile %>',
            city: '<%= profile.address?.city || "" %>',
            state: '<%= profile.address?.state || "" %>',
            title: '<%= card && card.title ? card.title : "" %>',
            cvUrl: '<%= card && card.cvUrl ? card.cvUrl : "" %>',
            websiteUrl: '<%= card && card.websiteUrl ? card.websiteUrl : "" %>'
        };

        // Save Contact functionality
        document.getElementById('save-contact-btn').addEventListener('click', function() {
            const vcard = `BEGIN:VCARD
VERSION:3.0
FN:${profileData.name}
TITLE:${profileData.title}
TEL:+91${profileData.mobile}
EMAIL:${profileData.email}
ADR:;;${profileData.city};${profileData.state};;India
END:VCARD`;
            
            const blob = new Blob([vcard], { type: 'text/vcard' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.style.display = 'none';
            a.href = url;
            a.download = `${profileData.name.replace(/\s+/g, '-').toLowerCase()}-contact.vcf`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
        });

        // Save CV functionality
        document.getElementById('save-cv-btn').addEventListener('click', function() {
            if (profileData.cvUrl) {
                window.open(profileData.cvUrl, '_blank');
            } else {
                alert('CV not available for this profile.');
            }
        });

        // Share via WhatsApp functionality
        document.getElementById('share-whatsapp-btn').addEventListener('click', function() {
            const location = profileData.city && profileData.state 
                ? `${profileData.city}, ${profileData.state}` 
                : '';
            const text = encodeURIComponent(
                `Check out ${profileData.name}'s digital business card!\n\n` +
                `Name: ${profileData.name}\n` +
                `Title: ${profileData.title}\n` +
                `Email: ${profileData.email}\n` +
                `Phone: +91 ${profileData.mobile}\n` +
                `Location: ${location}\n` +
                `Visit: ${window.location.href}`
            );
            const whatsappUrl = `https://wa.me/?text=${text}`;
            window.open(whatsappUrl, '_blank');
        });

        // Website button functionality
        document.getElementById('website-btn').addEventListener('click', function() {
            if (profileData.websiteUrl) {
                window.open(profileData.websiteUrl, '_blank');
            } else {
                alert('Website URL not available for this profile.');
            }
        });
    </script>
</body>
</html>

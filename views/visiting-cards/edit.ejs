function updateCustomFieldName(input) {
  const safeName = input.value.trim().replace(/[^a-zA-Z0-9_]/g, '');
  const valInput = input.closest('.array-row').querySelector('.cf-value');
  if (safeName) {
      valInput.name = 'profile[customFields][' + safeName + ']';
  } else {
      valInput.name = '';
  }
}


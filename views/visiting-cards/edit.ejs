<% layout('layouts/dashboard-boilerplate') %>
<% block('styles').append('<link rel="stylesheet" href="/css/visiting-cards/index.css">') %>
<%
  const slugSegment = (typeof slug !== 'undefined' && slug) ? '/' + encodeURIComponent(slug) : '';
  const tpl = (card.templateId) || {};
  // Pre-load arrays as JSON for JS hydration
  const _customFields = encodeURIComponent(JSON.stringify((card.profile && card.profile.customFields) || {}));
  const _heroStats   = encodeURIComponent(JSON.stringify(card.heroStats || []));
  const _socials     = encodeURIComponent(JSON.stringify(card.socials || []));
  const _stats       = encodeURIComponent(JSON.stringify(card.stats || []));
  const _services    = encodeURIComponent(JSON.stringify(card.services || []));
  const _pricingPlans= encodeURIComponent(JSON.stringify(card.pricingPlans || []));
  const _portfolio   = encodeURIComponent(JSON.stringify(card.portfolio || []));
  const _gallery     = encodeURIComponent(JSON.stringify(card.gallery || []));
  const _experience  = encodeURIComponent(JSON.stringify(card.experience || []));
  const _testimonials= encodeURIComponent(JSON.stringify(card.testimonials || []));
  const _partners    = encodeURIComponent(JSON.stringify(card.partners || []));
  const _specializations = encodeURIComponent(JSON.stringify(card.specializations || []));
  const _additionals = encodeURIComponent(JSON.stringify((card.contact && card.contact.additionalContacts) || []));

  // Visual state helpers
  const pImg = (card.profile && card.profile.profileImage) || '';
  const lImg = (card.profile && card.profile.logoUrl) || '';
  const cImg = (card.profile && card.profile.coverImage) || '';

  // CSS variables for IDE-friendly style management
  const pStyle = pImg ? 'display:inline-block;' : 'display:none;';
  const lStyle = lImg ? 'display:inline-block;' : 'display:none;';
  const cStyle = cImg ? 'display:inline-block;' : 'display:none;';
%>

<link rel="stylesheet" href="/css/visiting-cards/edit.css">
<link rel="stylesheet" href="/css/vcard-ui.css">
<link rel="stylesheet" href="/css/fa-all.min.css">

<div class="edit-root">
  <div class="edit-header">
    <h1>✏️ Edit vCard</h1>
    <div class="template-badge">🎨 Template: <%= tpl.name || 'Unknown' %></div>
    <div class="slug-display">Public URL: /visiting-card/<%= card.slug %></div>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="vcard-form-alert"><%= error %></div>
  <% } %>

  <form id="editVcardForm"
        action="/dashboard<%= slugSegment %>/visiting-cards/<%= card._id %>?_method=PUT"
        method="POST"
        enctype="multipart/form-data">
    <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>

    <!-- 1. Profile / Identity -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">👤 Core Identity</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div class="field-grid">
        <div class="form-field">
          <label>Full Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="profile[fullName]" required value="<%= (card.profile && card.profile.fullName) || '' %>">
        </div>
        <div class="form-field">
          <label>Designation</label>
          <input type="text" name="profile[designation]" value="<%= (card.profile && card.profile.designation) || '' %>">
        </div>
        <div class="form-field">
          <label>Company / Firm Name</label>
          <input type="text" name="profile[companyName]" value="<%= (card.profile && card.profile.companyName) || '' %>">
        </div>
        <div class="form-field">
          <label>Profile Image</label>
          <input type="hidden" name="profile[profileImage]" id="hidden-profileImage" value="<%= pImg %>">
          <div class="img-field-wrap">
            <label class="file-label" for="inp-profileImage" id="lbl-profileImage">
              <span id="txt-profileImage"><%= pImg ? '✅ Change Photo' : '📷 Choose Photo' %></span>
              <img class="img-thumb" id="prev-profileImage" style="<%= pStyle %>" src="<%= pImg %>" alt="">
              <button type="button" class="remove-img-btn" id="btn-rm-profileImage" style="<%= pStyle %>" onclick="event.preventDefault(); removeImage('profileImage');">❌ Clear</button>
            </label>
            <input type="file" id="inp-profileImage" name="profile[profileImage]" accept="image/*">
          </div>
        </div>
        <div class="form-field">
          <label>Logo / Brand Image</label>
          <input type="hidden" name="profile[logoUrl]" id="hidden-logoUrl" value="<%= lImg %>">
          <div class="img-field-wrap">
            <label class="file-label" for="inp-logoUrl" id="lbl-logoUrl">
              <span id="txt-logoUrl"><%= lImg ? '✅ Change Logo' : '🖼️ Choose Logo' %></span>
              <img class="img-thumb" id="prev-logoUrl" style="<%= lStyle %>" src="<%= lImg %>" alt="">
              <button type="button" class="remove-img-btn" id="btn-rm-logoUrl" style="<%= lStyle %>" onclick="event.preventDefault(); removeImage('logoUrl');">❌ Clear</button>
            </label>
            <input type="file" id="inp-logoUrl" name="profile[logoUrl]" accept="image/*">
          </div>
        </div>
        <div class="form-field">
          <label>Cover / Banner Image</label>
          <input type="hidden" name="profile[coverImage]" id="hidden-coverImage" value="<%= cImg %>">
          <div class="img-field-wrap">
            <label class="file-label" for="inp-coverImage" id="lbl-coverImage">
              <span id="txt-coverImage"><%= cImg ? '✅ Change Banner' : '🖼️ Choose Banner' %></span>
              <img class="img-thumb" id="prev-coverImage" style="<%= cStyle %>" src="<%= cImg %>" alt="">
              <button type="button" class="remove-img-btn" id="btn-rm-coverImage" style="<%= cStyle %>" onclick="event.preventDefault(); removeImage('coverImage');">❌ Clear</button>
            </label>
            <input type="file" id="inp-coverImage" name="profile[coverImage]" accept="image/*">
          </div>
        </div>
        <div class="form-field" style="grid-column:span 2;">
          <label>Bio</label>
          <textarea name="profile[bio]"><%= (card.profile && card.profile.bio) || '' %></textarea>
        </div>
      </div>

      <!-- Custom Profile Fields -->
      <div style="margin-top:1.5rem;">
        <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:.4rem;">Custom Profile Fields</label>
        <div id="customFieldsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addCustomField()">+ Add Custom Field</button>
      </div>
    </div>
</div>

    <!-- 2. Contact & Hours -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">📞 Contact Information & Hours</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div class="field-grid">
        <div class="form-field"><label>Primary Phone</label><input type="tel" name="contact[primaryPhone]" value="<%= (card.contact && card.contact.primaryPhone) || '' %>"></div>
        <div class="form-field"><label>Primary Email</label><input type="email" name="contact[primaryEmail]" value="<%= (card.contact && card.contact.primaryEmail) || '' %>"></div>
        <div class="form-field"><label>Website</label><input type="url" name="contact[website]" value="<%= (card.contact && card.contact.website) || '' %>"></div>
        <div class="form-field"><label>Business Hours</label><input type="text" name="contact[businessHours]" value="<%= (card.contact && card.contact.businessHours) || '' %>"></div>
        <div class="form-field"><label>Address</label><input type="text" name="contact[location][address]" value="<%= (card.contact && card.contact.location && card.contact.location.address) || '' %>"></div>
        <div class="form-field"><label>Google Maps Embed URL</label><input type="url" name="contact[location][mapEmbedUrl]" value="<%= (card.contact && card.contact.location && card.contact.location.mapEmbedUrl) || '' %>"></div>
      </div>
      <!-- Additional contacts -->
      <div style="margin-top:1rem;">
        <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:.4rem;">Additional Contacts</label>
        <div id="additionalContactsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addAdditionalContact()">+ Add Contact</button>
      </div>
    </div>
</div>

    <!-- 3. Social Media -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🔗 Social Media Links</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="socialsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addSocial()">+ Add Social Link</button>
    </div>
</div>

    <!-- 4a. Hero Stats -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">⭐ Hero Stats (Top Section)</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="heroStatsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addHeroStat()">+ Add Hero Stat</button>
    </div>
</div>

    <!-- 4. Stats -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">📊 Highlights & Stats</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="statsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addStat()">+ Add Stat</button>
    </div>
</div>

    <!-- 5. Services / Offerings -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🛠️ Services / Offerings</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="servicesContainer"></div>
      <button type="button" class="add-row-btn" onclick="addService()">+ Add Service / Item</button>
    </div>
</div>

    <!-- 6. Pricing Plans -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">💰 Pricing Packages</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="pricingContainer"></div>
      <button type="button" class="add-row-btn" onclick="addPricing()">+ Add Package</button>
    </div>
</div>

    <!-- 7. Portfolio (Links/Videos) -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🎬 Portfolio / Media Links</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="portfolioContainer"></div>
      <button type="button" class="add-row-btn" onclick="addPortfolio()">+ Add Video / Link</button>
    </div>
</div>

    <!-- 8. Gallery (Images) -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🖼️ Gallery Images</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="galleryContainer"></div>
      <button type="button" class="add-row-btn" onclick="addGallery()">+ Add Gallery Image</button>
    </div>
</div>

    <!-- 9. Experience / Timeline -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">💼 Experience / Timeline</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="experienceContainer"></div>
      <button type="button" class="add-row-btn" onclick="addExperience()">+ Add Entry</button>
    </div>
</div>

    <!-- 10. Testimonials -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">⭐ Testimonials / Reviews</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="testimonialsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addTestimonial()">+ Add Review</button>
    </div>
</div>

    <!-- 11. Partners -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🤝 Partners / Affiliates</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="partnersContainer"></div>
      <button type="button" class="add-row-btn" onclick="addPartner()">+ Add Partner</button>
    </div>
</div>

    <!-- 12. Specializations -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">🗂️ Specializations (Secondary)</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <div id="specializationsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addSpecialization()">+ Add Specialization</button>
    </div>
</div>

    <!-- 13. Qualifications / Simple List -->
    <div class="card-block open">
  <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
    <h3 style="margin:0;">📜 Qualifications / Certifications</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
  </div>
  <div class="card-block-body">
      <p class="hint">Enter one per line.</p>
      <div class="form-field">
        <textarea name="qualifications" rows="4"><%= (card.qualifications || []).join('\n') %></textarea>
      </div>
    </div>
    </div>

    <!-- 14. Process -->
    <div class="card-block open">
      <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
        <h3 style="margin:0;">🔄 Process / Steps</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
      </div>
      <div class="card-block-body">
        <div id="processContainer"></div>
        <button type="button" class="add-row-btn" onclick="addProcess()">+ Add Step</button>
      </div>
    </div>

    <!-- 15. FAQs -->
    <div class="card-block open">
      <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
        <h3 style="margin:0;">❓ FAQs (Frequently Asked Questions)</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
      </div>
      <div class="card-block-body">
        <div id="faqsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addFaq()">+ Add FAQ</button>
      </div>
    </div>

    <!-- 16. Tags -->
    <div class="card-block open">
      <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
        <h3 style="margin:0;">🏷️ Tags / Keywords</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
      </div>
      <div class="card-block-body">
        <p class="hint">Type a keyword and press Enter or comma.</p>
        <div class="form-field f" style="max-width: 500px;">
          <div id="tagsWrapper" class="tags-input-wrapper">
            <input type="text" placeholder="Add a tag..." autocomplete="off">
            <input type="hidden" name="tags" id="tagsHidden" value="<%= (typeof card !== 'undefined' && card.tags ? JSON.stringify(card.tags) : '[]') %>">
          </div>
        </div>
      </div>
    </div>

    <!-- 17. Call to Action -->
    <div class="card-block open">
      <div class="card-block-header" onclick="this.parentElement.classList.toggle('open')">
        <h3 style="margin:0;">📣 Call To Action (Bottom Section)</h3><span style="font-size:0.8rem;color:#64748b;">▼ Toggle</span>
      </div>
      <div class="card-block-body">
        <div class="g2 field-grid">
          <div class="f form-field"><label>Title</label><input type="text" name="callToAction[title]" value="<%= (typeof card !== 'undefined' && card.callToAction && card.callToAction.title) ? card.callToAction.title : '' %>"></div>
          <div class="f form-field"><label>Button Text</label><input type="text" name="callToAction[buttonText]" value="<%= (typeof card !== 'undefined' && card.callToAction && card.callToAction.buttonText) ? card.callToAction.buttonText : '' %>"></div>
          <div class="f form-field"><label>Button Link</label><input type="url" name="callToAction[buttonLink]" value="<%= (typeof card !== 'undefined' && card.callToAction && card.callToAction.buttonLink) ? card.callToAction.buttonLink : '' %>"></div>
          <div class="f form-field" style="grid-column:1 / -1;"><label>Description</label><textarea name="callToAction[description]"><%= (typeof card !== 'undefined' && card.callToAction && card.callToAction.description) ? card.callToAction.description : '' %></textarea></div>
        </div>
      </div>
    </div>


    <!-- 18. Theme & Aliasing -->
    <div class="card-block open" style="border-color:#c4b5fd;">
      <div class="card-block-header" style="background:linear-gradient(135deg,#faf5ff,#ede9fe);" onclick="this.parentElement.classList.toggle('open')">
        <h3 style="margin:0;color:#7c3aed;">🎨 Theme & Section Titles</h3><span style="font-size:0.8rem;color:#7c3aed;">▼ Toggle</span>
      </div>
      <div class="card-block-body">
      <div class="field-grid col-3">
        <div class="form-field">
          <label>Primary Color</label>
          <input type="color" name="theme[primaryColor]" value="<%= (card.theme && card.theme.primaryColor) || '#1e40af' %>">
        </div>
        <div class="form-field">
          <label>Secondary Color</label>
          <input type="color" name="theme[secondaryColor]" value="<%= (card.theme && card.theme.secondaryColor) || '#0891b2' %>">
        </div>
        <div class="form-field">
          <label>Font Style</label>
          <select name="theme[fontStyle]">
            <% ['Inter','Roboto','Poppins','Merriweather','Lato','Outfit'].forEach(function(f) { %>
              <option value="<%= f %>" <%= ((card.theme && card.theme.fontStyle) === f) ? 'selected' : '' %>><%= f %></option>
            <% }); %>
          </select>
        </div>
      </div>
      <div class="field-grid" style="margin-top:1.5rem">
         <div class="form-field"><label>"Services" Section Title</label><input type="text" name="theme[sectionTitles][services]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.services) || 'Our Services' %>"></div>
         <div class="form-field"><label>"Services" Section Subtitle</label><input type="text" name="theme[sectionDescriptions][services]" value="<%= (card.theme && card.theme.sectionDescriptions && card.theme.sectionDescriptions.services) || '' %>"></div>
         <div class="form-field"><label>"Experience" Section Title</label><input type="text" name="theme[sectionTitles][experience]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.experience) || 'Experience' %>"></div>
         <div class="form-field"><label>"Gallery" Section Title</label><input type="text" name="theme[sectionTitles][gallery]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.gallery) || 'Gallery' %>"></div>
         <div class="form-field"><label>"Partners" Section Title</label><input type="text" name="theme[sectionTitles][partners]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.partners) || 'Our Partners' %>"></div>
         <div class="form-field"><label>"Stats" Section Title</label><input type="text" name="theme[sectionTitles][stats]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.stats) || 'Medical Excellence' %>"></div>
         <div class="form-field"><label>"Faqs" Title</label><input type="text" name="theme[sectionTitles][faqs]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.faqs) || 'Faqs' %>"></div>
         <div class="form-field"><label>"Faqs" Subtitle</label><input type="text" name="theme[sectionDescriptions][faqs]" value="<%= (card.theme && card.theme.sectionDescriptions && card.theme.sectionDescriptions.faqs) || '' %>"></div>

         <div class="form-field"><label>"Portfolio" Title</label><input type="text" name="theme[sectionTitles][portfolio]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.portfolio) || 'Portfolio' %>"></div>
         <div class="form-field"><label>"Portfolio" Subtitle</label><input type="text" name="theme[sectionDescriptions][portfolio]" value="<%= (card.theme && card.theme.sectionDescriptions && card.theme.sectionDescriptions.portfolio) || '' %>"></div>

         <div class="form-field"><label>"Process" Title</label><input type="text" name="theme[sectionTitles][process]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.process) || 'Process' %>"></div>
         <div class="form-field"><label>"Process" Subtitle</label><input type="text" name="theme[sectionDescriptions][process]" value="<%= (card.theme && card.theme.sectionDescriptions && card.theme.sectionDescriptions.process) || '' %>"></div>

         <div class="form-field"><label>"Pricing" Title</label><input type="text" name="theme[sectionTitles][pricing]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.pricing) || 'Pricing' %>"></div>
         <div class="form-field"><label>"Pricing" Subtitle</label><input type="text" name="theme[sectionDescriptions][pricing]" value="<%= (card.theme && card.theme.sectionDescriptions && card.theme.sectionDescriptions.pricing) || '' %>"></div>

         <div class="form-field"><label>"About" Title</label><input type="text" name="theme[sectionTitles][about]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.about) || 'About' %>"></div>
         <div class="form-field"><label>"About" Subtitle</label><input type="text" name="theme[sectionDescriptions][about]" value="<%= (card.theme && card.theme.sectionDescriptions && card.theme.sectionDescriptions.about) || '' %>"></div>
      </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="edit-actions">
      <button type="button" class="btn-delete" onclick="confirmDelete()">🗑️ Delete Card</button>
      <div class="right">
        <a href="/dashboard<%= slugSegment %>/visiting-cards" class="btn-cancel">Cancel</a>
        <button type="submit" class="btn-save">💾 Save Changes</button>
      </div>
    </div>
  </form>

  <!-- Delete form -->
  <form id="deleteForm" action="/dashboard<%= slugSegment %>/visiting-cards/<%= card._id %>/delete" method="POST" style="display:none;">
    <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>
  </form>
</div>

<script src="/js/vcard-ui.js"></script>
<script>
// Pre-loaded data from server
const _customFields = JSON.parse(decodeURIComponent(`<%- _customFields %>`));
const _heroStats   = JSON.parse(decodeURIComponent(`<%- _heroStats %>`));
const _socials     = JSON.parse(decodeURIComponent(`<%- _socials %>`));
const _stats       = JSON.parse(decodeURIComponent(`<%- _stats %>`));
const _services    = JSON.parse(decodeURIComponent(`<%- _services %>`));
const _pricingPlans= JSON.parse(decodeURIComponent(`<%- _pricingPlans %>`));
const _portfolio   = JSON.parse(decodeURIComponent(`<%- _portfolio %>`));
const _gallery     = JSON.parse(decodeURIComponent(`<%- _gallery %>`));
const _experience  = JSON.parse(decodeURIComponent(`<%- _experience %>`));

function addCustomField(key='', value='') {
  const i = customFieldIdx++;
  const row = document.createElement('div');
  row.className = 'array-row'; row.style.gridTemplateColumns = '1fr 2fr auto';
  row.innerHTML = `
    <div class="form-field"><label>Field Key Name</label><input type="text" class="cf-key" value="${esc(key)}" oninput="updateCustomFieldName(this)" placeholder="e.g. shortDescription"></div>
    <div class="form-field"><label>Field Value</label><input type="text" class="cf-value" value="${esc(value)}" name="${key ? 'profile[customFields]['+esc(key)+']' : ''}"></div>
    <button type="button" class="del-row" onclick="this.closest('.array-row').remove()">✕</button>`;
  document.getElementById('customFieldsContainer').appendChild(row);

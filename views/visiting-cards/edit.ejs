<% layout('layouts/dashboard-boilerplate') %>
<% block('styles').append('<link rel="stylesheet" href="/css/visiting-cards/index.css">') %>
<%
  const slugSegment = (typeof slug !== 'undefined' && slug) ? '/' + encodeURIComponent(slug) : '';
  const tpl = (card.templateId) || {};
  // Pre-load arrays as JSON for JS hydration
  const _customFields = encodeURIComponent(JSON.stringify((card.profile && card.profile.customFields) || {}));
  const _heroStats   = encodeURIComponent(JSON.stringify(card.heroStats || []));
  const _socials     = encodeURIComponent(JSON.stringify(card.socials || []));
  const _stats       = encodeURIComponent(JSON.stringify(card.stats || []));
  const _services    = encodeURIComponent(JSON.stringify(card.services || []));
  const _pricingPlans= encodeURIComponent(JSON.stringify(card.pricingPlans || []));
  const _portfolio   = encodeURIComponent(JSON.stringify(card.portfolio || []));
  const _gallery     = encodeURIComponent(JSON.stringify(card.gallery || []));
  const _experience  = encodeURIComponent(JSON.stringify(card.experience || []));
  const _testimonials= encodeURIComponent(JSON.stringify(card.testimonials || []));
  const _partners    = encodeURIComponent(JSON.stringify(card.partners || []));
  const _specializations = encodeURIComponent(JSON.stringify(card.specializations || []));
  const _additionals = encodeURIComponent(JSON.stringify((card.contact && card.contact.additionalContacts) || []));
%>

<style>
  .edit-root { max-width: 960px; margin: 0 auto; padding: 1.5rem; }
  .edit-header { margin-bottom: 2rem; }
  .edit-header h1 { font-size: 1.8rem; font-weight: 700; color: #1e293b; }
  .edit-header .template-badge { display:inline-flex; align-items:center; gap:0.5rem; background:#ede9fe; color:#7c3aed; padding:0.3rem 0.8rem; border-radius:20px; font-size:0.8rem; font-weight:600; margin-top:0.5rem; }
  .form-section-block { background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:1.5rem; margin-bottom:1.2rem; }
  .form-section-block h3 { font-size:1rem; font-weight:700; color:#1e293b; margin:0 0 1rem; display:flex; align-items:center; gap:0.5rem; }
  .field-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  .field-grid.col-3 { grid-template-columns:1fr 1fr 1fr; }
  .form-field { display:flex; flex-direction:column; gap:0.35rem; }
  .form-field label { font-size:0.8rem; font-weight:600; color:#374151; }
  .form-field input, .form-field textarea, .form-field select {
    padding:0.6rem 0.8rem; border:1.5px solid #e2e8f0; border-radius:8px; font-size:0.9rem;
    color:#1e293b; transition:border-color .2s; background:#fafafa; width:100%;
  }
  .form-field textarea { resize:vertical; min-height:80px; }
  .form-field input:focus, .form-field textarea:focus, .form-field select:focus { outline:none; border-color:#6366f1; background:#fff; }

  /* Dynamic array rows */
  .array-row { display:grid; gap:.6rem; align-items:end; background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:.8rem; margin-bottom:.6rem; position:relative; }
  .del-row { position:absolute; top:.4rem; right:.4rem; background:none; border:none; cursor:pointer; font-size:1rem; color:#94a3b8; line-height:1; padding:0; }
  .del-row:hover { color:#ef4444; }
  .add-row-btn { display:inline-flex; align-items:center; gap:.4rem; padding:.45rem 1rem; background:#f5f3ff; border:1.5px dashed #a78bfa; border-radius:8px; font-size:.82rem; font-weight:600; color:#7c3aed; cursor:pointer; transition:.2s; margin-top:.2rem; }
  .add-row-btn:hover { background:#ede9fe; border-color:#8b5cf6; }

  .slug-display { font-size:0.8rem; color:#64748b; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:0.5rem 0.8rem; margin-top:0.3rem; font-family:monospace; }
  .hint { font-size:.72rem; color:#94a3b8; }

  .edit-actions { display:flex; align-items:center; justify-content:space-between; margin-top:2rem; gap:1rem; }
  .edit-actions .right { display:flex; gap:0.8rem; }
  .btn-save { padding:0.75rem 2rem; background:linear-gradient(135deg,#6366f1,#8b5cf6); color:#fff; border:none; border-radius:10px; font-size:0.9rem; font-weight:700; cursor:pointer; box-shadow:0 4px 12px rgba(99,102,241,.35); transition:all .2s; }
  .btn-save:hover { transform:translateY(-1px); box-shadow:0 6px 18px rgba(99,102,241,.5); }
  .btn-cancel { padding:0.75rem 1.5rem; background:#f1f5f9; color:#475569; border:none; border-radius:10px; font-size:0.9rem; font-weight:600; cursor:pointer; text-decoration:none; display:inline-block; }
  .btn-delete { padding:0.75rem 1.5rem; background:#fef2f2; color:#dc2626; border:1px solid #fecaca; border-radius:10px; font-size:0.9rem; font-weight:600; cursor:pointer; }
  .btn-delete:hover { background:#fee2e2; }
  @media(max-width:600px) { .field-grid,.field-grid.col-3 { grid-template-columns:1fr; } }
</style>

<div class="edit-root">
  <div class="edit-header">
    <h1>✏️ Edit vCard</h1>
    <div class="template-badge">🎨 Template: <%= tpl.name || 'Unknown' %></div>
    <div class="slug-display">Public URL: /visiting-card/<%= card.slug %></div>
  </div>

  <form id="editVcardForm"
        action="/dashboard<%= slugSegment %>/visiting-cards/<%= card._id %>?_method=PUT"
        method="POST"
        enctype="multipart/form-data">
    <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>

    <!-- 1. Profile / Identity -->
    <div class="form-section-block">
      <h3>👤 Core Identity</h3>
      <div class="field-grid">
        <div class="form-field">
          <label>Full Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="profile[fullName]" required value="<%= (card.profile && card.profile.fullName) || '' %>">
        </div>
        <div class="form-field">
          <label>Designation</label>
          <input type="text" name="profile[designation]" value="<%= (card.profile && card.profile.designation) || '' %>">
        </div>
        <div class="form-field">
          <label>Company / Firm Name</label>
          <input type="text" name="profile[companyName]" value="<%= (card.profile && card.profile.companyName) || '' %>">
        </div>
        <div class="form-field">
          <label>Profile Image</label>
          <input type="hidden" name="profile[profileImage]" value="<%= (card.profile && card.profile.profileImage) || '' %>">
          <% if (card.profile && card.profile.profileImage) { %>
            <img src="<%= card.profile.profileImage %>" style="width:40px;height:40px;object-fit:cover;border-radius:4px;margin-bottom:.3rem;">
          <% } %>
          <input type="file" name="profile[profileImage]" accept="image/*">
        </div>
        <div class="form-field">
          <label>Logo / Brand Image</label>
          <input type="hidden" name="profile[logoUrl]" value="<%= (card.profile && card.profile.logoUrl) || '' %>">
          <% if (card.profile && card.profile.logoUrl) { %>
            <img src="<%= card.profile.logoUrl %>" style="width:40px;height:40px;object-fit:contain;border-radius:4px;margin-bottom:.3rem;">
          <% } %>
          <input type="file" name="profile[logoUrl]" accept="image/*">
        </div>
        <div class="form-field">
          <label>Cover / Banner Image</label>
          <input type="hidden" name="profile[coverImage]" value="<%= (card.profile && card.profile.coverImage) || '' %>">
          <% if (card.profile && card.profile.coverImage) { %>
            <img src="<%= card.profile.coverImage %>" style="width:70px;height:40px;object-fit:cover;border-radius:4px;margin-bottom:.3rem;">
          <% } %>
          <input type="file" name="profile[coverImage]" accept="image/*">
        </div>
        <div class="form-field" style="grid-column:span 2;">
          <label>Bio</label>
          <textarea name="profile[bio]"><%= (card.profile && card.profile.bio) || '' %></textarea>
        </div>
      </div>

      <!-- Custom Profile Fields -->
      <div style="margin-top:1.5rem;">
        <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:.4rem;">Custom Profile Fields</label>
        <div id="customFieldsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addCustomField()">+ Add Custom Field</button>
      </div>
    </div>

    <!-- 2. Contact & Hours -->
    <div class="form-section-block">
      <h3>📞 Contact Information & Hours</h3>
      <div class="field-grid">
        <div class="form-field"><label>Primary Phone</label><input type="tel" name="contact[primaryPhone]" value="<%= (card.contact && card.contact.primaryPhone) || '' %>"></div>
        <div class="form-field"><label>Primary Email</label><input type="email" name="contact[primaryEmail]" value="<%= (card.contact && card.contact.primaryEmail) || '' %>"></div>
        <div class="form-field"><label>Website</label><input type="url" name="contact[website]" value="<%= (card.contact && card.contact.website) || '' %>"></div>
        <div class="form-field"><label>Business Hours</label><input type="text" name="contact[businessHours]" value="<%= (card.contact && card.contact.businessHours) || '' %>"></div>
        <div class="form-field"><label>Address</label><input type="text" name="contact[location][address]" value="<%= (card.contact && card.contact.location && card.contact.location.address) || '' %>"></div>
        <div class="form-field"><label>Google Maps Embed URL</label><input type="url" name="contact[location][mapEmbedUrl]" value="<%= (card.contact && card.contact.location && card.contact.location.mapEmbedUrl) || '' %>"></div>
      </div>
      <!-- Additional contacts -->
      <div style="margin-top:1rem;">
        <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:.4rem;">Additional Contacts</label>
        <div id="additionalContactsContainer"></div>
        <button type="button" class="add-row-btn" onclick="addAdditionalContact()">+ Add Contact</button>
      </div>
    </div>

    <!-- 3. Social Media -->
    <div class="form-section-block">
      <h3>🔗 Social Media Links</h3>
      <div id="socialsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addSocial()">+ Add Social Link</button>
    </div>

    <!-- 4a. Hero Stats -->
    <div class="form-section-block">
      <h3>⭐ Hero Stats (Top Section)</h3>
      <div id="heroStatsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addHeroStat()">+ Add Hero Stat</button>
    </div>

    <!-- 4. Stats -->
    <div class="form-section-block">
      <h3>📊 Highlights & Stats</h3>
      <div id="statsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addStat()">+ Add Stat</button>
    </div>

    <!-- 5. Services / Offerings -->
    <div class="form-section-block">
      <h3>🛠️ Services / Offerings</h3>
      <div id="servicesContainer"></div>
      <button type="button" class="add-row-btn" onclick="addService()">+ Add Service / Item</button>
    </div>

    <!-- 6. Pricing Plans -->
    <div class="form-section-block">
      <h3>💰 Pricing Packages</h3>
      <div id="pricingContainer"></div>
      <button type="button" class="add-row-btn" onclick="addPricing()">+ Add Package</button>
    </div>

    <!-- 7. Portfolio (Links/Videos) -->
    <div class="form-section-block">
      <h3>🎬 Portfolio / Media Links</h3>
      <div id="portfolioContainer"></div>
      <button type="button" class="add-row-btn" onclick="addPortfolio()">+ Add Video / Link</button>
    </div>

    <!-- 8. Gallery (Images) -->
    <div class="form-section-block">
      <h3>🖼️ Gallery Images</h3>
      <div id="galleryContainer"></div>
      <button type="button" class="add-row-btn" onclick="addGallery()">+ Add Gallery Image</button>
    </div>

    <!-- 9. Experience / Timeline -->
    <div class="form-section-block">
      <h3>💼 Experience / Timeline</h3>
      <div id="experienceContainer"></div>
      <button type="button" class="add-row-btn" onclick="addExperience()">+ Add Entry</button>
    </div>

    <!-- 10. Testimonials -->
    <div class="form-section-block">
      <h3>⭐ Testimonials / Reviews</h3>
      <div id="testimonialsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addTestimonial()">+ Add Review</button>
    </div>

    <!-- 11. Partners -->
    <div class="form-section-block">
      <h3>🤝 Partners / Affiliates</h3>
      <div id="partnersContainer"></div>
      <button type="button" class="add-row-btn" onclick="addPartner()">+ Add Partner</button>
    </div>

    <!-- 12. Specializations -->
    <div class="form-section-block">
      <h3>🗂️ Specializations (Secondary)</h3>
      <div id="specializationsContainer"></div>
      <button type="button" class="add-row-btn" onclick="addSpecialization()">+ Add Specialization</button>
    </div>

    <!-- 13. Qualifications / Simple List -->
    <div class="form-section-block">
      <h3>📜 Qualifications / Certifications</h3>
      <p class="hint">Enter one per line.</p>
      <div class="form-field">
        <textarea name="qualifications" rows="4"><%= (card.qualifications || []).join('\n') %></textarea>
      </div>
    </div>

    <!-- 14. Theme & Aliasing -->
    <div class="form-section-block" style="background:linear-gradient(135deg,#faf5ff,#ede9fe);border-color:#c4b5fd;">
      <h3 style="color:#7c3aed;">🎨 Theme & Section Titles</h3>
      <div class="field-grid col-3">
        <div class="form-field">
          <label>Primary Color</label>
          <input type="color" name="theme[primaryColor]" value="<%= (card.theme && card.theme.primaryColor) || '#1e40af' %>">
        </div>
        <div class="form-field">
          <label>Secondary Color</label>
          <input type="color" name="theme[secondaryColor]" value="<%= (card.theme && card.theme.secondaryColor) || '#0891b2' %>">
        </div>
        <div class="form-field">
          <label>Font Style</label>
          <select name="theme[fontStyle]">
            <% ['Inter','Roboto','Poppins','Merriweather','Lato','Outfit'].forEach(function(f) { %>
              <option value="<%= f %>" <%= ((card.theme && card.theme.fontStyle) === f) ? 'selected' : '' %>><%= f %></option>
            <% }); %>
          </select>
        </div>
      </div>
      <div class="field-grid" style="margin-top:1.5rem">
         <div class="form-field"><label>"Services" Section Title</label><input type="text" name="theme[sectionTitles][services]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.services) || 'Our Services' %>"></div>
         <div class="form-field"><label>"Services" Section Subtitle</label><input type="text" name="theme[sectionDescriptions][services]" value="<%= (card.theme && card.theme.sectionDescriptions && card.theme.sectionDescriptions.services) || '' %>"></div>
         <div class="form-field"><label>"Experience" Section Title</label><input type="text" name="theme[sectionTitles][experience]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.experience) || 'Experience' %>"></div>
         <div class="form-field"><label>"Gallery" Section Title</label><input type="text" name="theme[sectionTitles][gallery]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.gallery) || 'Gallery' %>"></div>
         <div class="form-field"><label>"Partners" Section Title</label><input type="text" name="theme[sectionTitles][partners]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.partners) || 'Our Partners' %>"></div>
         <div class="form-field"><label>"Stats" Section Title</label><input type="text" name="theme[sectionTitles][stats]" value="<%= (card.theme && card.theme.sectionTitles && card.theme.sectionTitles.stats) || 'Medical Excellence' %>"></div>
      </div>
    </div>

    <!-- Actions -->
    <div class="edit-actions">
      <button type="button" class="btn-delete" onclick="confirmDelete()">🗑️ Delete Card</button>
      <div class="right">
        <a href="/dashboard<%= slugSegment %>/visiting-cards" class="btn-cancel">Cancel</a>
        <button type="submit" class="btn-save">💾 Save Changes</button>
      </div>
    </div>
  </form>

  <!-- Delete form -->
  <form id="deleteForm" action="/dashboard<%= slugSegment %>/visiting-cards/<%= card._id %>/delete" method="POST" style="display:none;">
    <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>
  </form>
</div>

<script>
// Pre-loaded data from server
const _customFields = JSON.parse(decodeURIComponent('<%- _customFields %>'));
const _heroStats   = JSON.parse(decodeURIComponent('<%- _heroStats %>'));
const _socials     = JSON.parse(decodeURIComponent('<%- _socials %>'));
const _stats       = JSON.parse(decodeURIComponent('<%- _stats %>'));
const _services    = JSON.parse(decodeURIComponent('<%- _services %>'));
const _pricingPlans= JSON.parse(decodeURIComponent('<%- _pricingPlans %>'));
const _portfolio   = JSON.parse(decodeURIComponent('<%- _portfolio %>'));
const _gallery     = JSON.parse(decodeURIComponent('<%- _gallery %>'));
const _experience  = JSON.parse(decodeURIComponent('<%- _experience %>'));
const _testimonials= JSON.parse(decodeURIComponent('<%- _testimonials %>'));
const _partners    = JSON.parse(decodeURIComponent('<%- _partners %>'));
const _specializations = JSON.parse(decodeURIComponent('<%- _specializations %>'));
const _additionals = JSON.parse(decodeURIComponent('<%- _additionals %>'));

// ── Index counters ──
let heroStatIdx=0, socialIdx=0, statIdx=0, serviceIdx=0, pricingIdx=0, portIdx=0;
let galleryIdx=0, expIdx=0, testIdx=0, partnerIdx=0, specIdx=0, acIdx=0;

// ── Hydration Functions ──

let customFieldIdx = 0;
function addCustomField(key='', value='') {
  const i = customFieldIdx++;
  const row = document.createElement('div');
  row.className = 'array-row'; row.style.gridTemplateColumns = '1fr 2fr auto';
  row.innerHTML = `
    <div class="form-field"><label>Field Key Name</label><input type="text" class="cf-key" value="${esc(key)}" oninput="updateCustomFieldName(this)" placeholder="e.g. shortDescription"></div>
    <div class="form-field"><label>Field Value</label><input type="text" class="cf-value" value="${esc(value)}" name="${key ? 'profile[customFields]['+esc(key)+']' : ''}"></div>
    <button type="button" class="del-row" onclick="this.closest('.array-row').remove()">✕</button>`;
  document.getElementById('customFieldsContainer').appendChild(row);
}

function updateCustomFieldName(input) {
  const safeName = input.value.trim().replace(/[^a-zA-Z0-9_]/g, '');
  const valInput = input.closest('.array-row').querySelector('.cf-value');
  if (safeName) {
      valInput.name = 'profile[customFields][' + safeName + ']';
  } else {
      valInput.name = '';
  }
}

function addHeroStat(label='', value='') {
  const i = heroStatIdx++;
  const row = document.createElement('div');
  row.className = 'array-row'; row.style.gridTemplateColumns = '2fr 1fr auto';
  row.innerHTML = `<div class="form-field"><label>Label</label><input type="text" name="heroStats[${i}][label]" value="${esc(label)}"></div>
    <div class="form-field"><label>Value</label><input type="text" name="heroStats[${i}][value]" value="${esc(value)}"></div>
    <button type="button" class="del-row" onclick="this.closest('.array-row').remove()">✕</button>`;
  document.getElementById('heroStatsContainer').appendChild(row);
}

function addSocial(platform='', url='', icon='') {
  const i = socialIdx++;
  const row = document.createElement('div');
  row.className = 'array-row'; row.style.gridTemplateColumns = '1fr 2fr auto';
  row.innerHTML = `<div class="form-field"><label>Platform</label><input type="text" name="socials[${i}][platform]" value="${esc(platform)}"></div>
    <div class="form-field"><label>URL</label><input type="url" name="socials[${i}][url]" value="${esc(url)}"></div>
    <div class="form-field"><label>Icon Class</label><input type="text" name="socials[${i}][icon]" value="${esc(icon)}"></div>
    <button type="button" class="del-row" onclick="this.closest('.array-row').remove()">✕</button>`;
  document.getElementById('socialsContainer').appendChild(row);
}

function addStat(label='', value='', icon='') {
  const i = statIdx++;
  const row = document.createElement('div');
  row.className = 'array-row'; row.style.gridTemplateColumns = '2fr 1fr 1fr auto';
  row.innerHTML = `<div class="form-field"><label>Label</label><input type="text" name="stats[${i}][label]" value="${esc(label)}"></div>
    <div class="form-field"><label>Value</label><input type="text" name="stats[${i}][value]" value="${esc(value)}"></div>
    <div class="form-field"><label>Icon Class</label><input type="text" name="stats[${i}][icon]" value="${esc(icon)}"></div>
    <button type="button" class="del-row" onclick="this.closest('.array-row').remove()">✕</button>`;
  document.getElementById('statsContainer').appendChild(row);
}

function addService(title='', desc='', price='', icon='', image='', actionLink='') {
  const i = serviceIdx++;
  const row = document.createElement('div');
  row.className = 'array-row'; row.style.gridTemplateColumns = '1fr 1fr 1fr';
  row.innerHTML = `
    <div class="form-field"><label>Title</label><input type="text" name="services[${i}][title]" value="${esc(title)}"></div>
    <div class="form-field"><label>Price</label><input type="text" name="services[${i}][price]" value="${esc(price)}"></div>
    <div class="form-field"><label>Icon Class</label><input type="text" name="services[${i}][icon]" value="${esc(icon)}"></div>
    <div class="form-field">
      <label>Item Image</label>
      <input type="hidden" name="services[${i}][image]" value="${esc(image)}">
      ${image ? `<img src="${esc(image)}" style="width:40px;height:40px;object-fit:cover;border-radius:4px;margin-bottom:.3rem;">` : ''}
      <input type="file" name="services[${i}][image]" accept="image/*">
    </div>
    <div class="form-field"><label>Action Link</label><input type="url" name="services[${i}][actionLink]" value="${esc(actionLink)}"></div>
    <div class="form-field" style="grid-column:1 / span 3"><label>Description</label><textarea name="services[${i}][description]">${esc(desc)}</textarea></div>
    <button type="button" class="del-row" onclick="this.closest('.array-row').remove()">✕</button>`;
  document.getElementById('servicesContainer').appendChild(row);
}

function addPricing(planName='', price='', duration='', features=[], actionLink='') {
  const i = pricingIdx++;
  const row = document.createElement('div');
  const featureText = Array.isArray(features) ? features.join('\\n') : features;
  row.className = 'array-row'; row.style.gridTemplateColumns = '1fr 1fr 1fr';
  row.innerHTML = `
    <div class="form-field"><label>Plan Name</label><input type="text" name="pricingPlans[${i}][planName]" value="${esc(planName)}"></div>
    <div class="form-field"><label>Price</label><input type="text" name="pricingPlans[${i}][price]" value="${esc(price)}"></div>
    <div class="form-field"><label>Duration</label><input type="text" name="pricingPlans[${i}][duration]" value="${esc(duration)}" placeholder="per month"></div>
    <div class="form-field" style="grid-column:1 / span 2"><label>Features (1 per line)</label><textarea name="pricingPlans[${i}][features]">${esc(featureText)}</textarea></div>
    <div class="form-field"><label>Action Link</label><input type="url" name="pricingPlans[${i}][actionLink]" value="${esc(actionLink)}"></div>
    <button type="button" class="del-row" onclick="this.closest('.array-row').remove()">✕</button>`;
  document.getElementById('pricingContainer').appendChild(row);
}

function addPortfolio(title='', mediaType='image', mediaUrl='', desc='') {
  const i = portIdx++;
  const row = document.createElement('div');
  row.className = 'array-row'; row.style.gridTemplateColumns = '1fr 1fr 1fr';
  row.innerHTML = `
    <div class="form-field"><label>Title</label><input type="text" name="portfolio[${i}][title]" value="${esc(title)}"></div>

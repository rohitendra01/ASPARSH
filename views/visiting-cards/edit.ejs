      <option value="image" ${mediaType==='image'?'selected':''}>Image URL</option>
      <option value="video" ${mediaType==='video'?'selected':''}>Video URL</option>
      <option value="youtube-embed" ${mediaType==='youtube-embed'?'selected':''}>YouTube Embed</option>
      <option value="link" ${mediaType==='link'?'selected':''}>General Link</option>
    </select></div>
    <div class="form-field"><label>Media URL</label><input type="url" name="portfolio[${i}][mediaUrl]" value="${esc(mediaUrl)}"></div>
    <div class="form-field" style="grid-column:1 / span 3"><label>Description</label><textarea name="portfolio[${i}][description]">${esc(desc)}</textarea></div>
    <button type="button" class="del-row" onclick="this.closest('.array-row').remove()">✕</button>`;
  document.getElementById('portfolioContainer').appendChild(row);
}


// ── HTML escape helper ──
function esc(s) { 
    if(!s) return '';
    return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); 
}

// ── Hydrate existing data ──
document.addEventListener('DOMContentLoaded', function() {
  if (_customFields && typeof _customFields === 'object') {
     Object.keys(_customFields).forEach(k => addCustomField(k, _customFields[k]));
  }
  _heroStats.forEach(s => addHeroStat(s.label, s.value));
  _socials.forEach(s => addSocial(s.platform, s.url, s.icon));
  _stats.forEach(s => addStat(s.label, s.value, s.icon));
  _services.forEach(s => addService(s.title, s.description, s.price, s.icon, s.image, s.actionLink));
  _pricingPlans.forEach(p => addPricing(p.planName, p.price, p.duration, Array.isArray(p.features) ? p.features.join('\n') : p.features, p.actionLink));
  _portfolio.forEach(p => addPortfolio(p.title, p.mediaType, p.mediaUrl, p.description));
  _gallery.forEach(g => addGallery(g.image, g.title));
  _experience.forEach(e => addExperience(e.title, e.organization, e.duration, e.description));
  _testimonials.forEach(t => addTestimonial(t.clientName, t.context, t.quote, t.rating, t.avatar));
  _partners.forEach(p => addPartner(p.name, p.logo, p.websiteUrl));
  _specializations.forEach(s => addSpecialization(s.title, s.icon, s.description));
  _additionals.forEach(a => addAdditionalContact(a.platform, a.value, a.link, a.icon));
});

function confirmDelete() {
  if (confirm('Delete this visiting card? The public link /visiting-card/<%= card.slug %> will stop working.')) {
    document.getElementById('deleteForm').submit();
  }
}
</script>

                                                    <h2 class="section-title">
                                                        <%= card.theme?.sectionTitles?.testimonials || 'Client Love' %>
                                                    </h2>
                                                    <div class="testimonials-slider" id="testimonialWrapper">
                                                        <div class="slider-track" id="testimonialTrack">
                                                            <% card.testimonials.forEach(test=> { %>
                                                                <div class="slider-slide testimonial-slide">
                                                                    <div class="stars">

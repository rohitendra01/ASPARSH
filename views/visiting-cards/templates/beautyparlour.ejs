                                                                                    <script id="vcard-data"
                                                                                        type="application/json">
        <%- JSON.stringify({
            fullName: card.profile?.fullName || 'Contact',
            companyName: card.profile?.companyName || '',
            designation: card.profile?.designation || '',
            email: card.contact?.primaryEmail || '',
            phone: card.contact?.primaryPhone || '',
            address: card.contact?.location?.address || '',
            website: card.contact?.website || '',
            bio: card.profile?.bio || ''
        }) %>
    </script>

                                                                                    <script>
                                                                                        // Generic Slider State
                                                                                        const sliders = {
                                                                                            portfolioTrack: { index: 0 },
                                                                                            testimonialTrack: { index: 0 }
                                                                                        };

                                                                                        function changeSlide(trackId, direction, maxSlides) {
                                                                                            let nextIndex = sliders[trackId].index + direction;
                                                                                            if (nextIndex >= maxSlides) nextIndex = 0;
                                                                                            if (nextIndex < 0) nextIndex = maxSlides - 1;
                                                                                            currentSlide(trackId, nextIndex, maxSlides);
                                                                                        }

                                                                                        function currentSlide(trackId, index, maxSlides) {
                                                                                            sliders[trackId].index = index;
                                                                                            const track = document.getElementById(trackId);
                                                                                            if (track) {
                                                                                                track.style.transform = `translateX(-${index * 100}%)`;
                                                                                            }

                                                                                            // Update dots
                                                                                            const dotsContainerId = trackId === 'portfolioTrack' ? 'portfolioDots' : 'testimonialDots';
                                                                                            const dotsContainer = document.getElementById(dotsContainerId);
                                                                                            if (dotsContainer) {
                                                                                                const dots = dotsContainer.querySelectorAll('.dot');
                                                                                                dots.forEach(d => d.classList.remove('active'));
                                                                                                if (dots[index]) dots[index].classList.add('active');
                                                                                            }
                                                                                        }

                                                                                        // Auto-advance
                                                                                        setInterval(() => {
                                                                                            const pTrack = document.getElementById('portfolioTrack');
                                                                                            if (pTrack) {
                                                                                                const count = pTrack.children.length;
                                                                                                if (count > 1) changeSlide('portfolioTrack', 1, count);
                                                                                            }
                                                                                        }, 5000);

                                                                                        setInterval(() => {
                                                                                            const tTrack = document.getElementById('testimonialTrack');
                                                                                            if (tTrack) {
                                                                                                const count = tTrack.children.length;
                                                                                                if (count > 1) changeSlide('testimonialTrack', 1, count);
                                                                                            }
                                                                                        }, 7000);

                                                                                        // Toggle FAQ
                                                                                        function toggleFAQ(element) {
                                                                                            const wasActive = element.classList.contains('active');
                                                                                            document.querySelectorAll('.faq-item').forEach(item => item.classList.remove('active'));
                                                                                            if (!wasActive) element.classList.add('active');
                                                                                        }

                                                                                        // Save Contact
                                                                                        function saveContact() {
                                                                                            const vCardPayload = JSON.parse(document.getElementById('vcard-data').textContent);
                                                                                            const vCardData = `BEGIN:VCARD\nVERSION:3.0\nFN:${vCardPayload.fullName}\nORG:${vCardPayload.companyName}\nTITLE:${vCardPayload.designation}\nEMAIL:${vCardPayload.email}\nTEL:${vCardPayload.phone}\nADR:;;${vCardPayload.address}\nURL:${vCardPayload.website}\nNOTE:${vCardPayload.bio.replace(/\n/g, ' ')}\nEND:VCARD`;
                                                                                            const blob = new Blob([vCardData], { type: "text/vcard" });
                                                                                            const url = window.URL.createObjectURL(blob);
                                                                                            const link = document.createElement("a");
                                                                                            link.href = url;
                                                                                            link.download = `${vCardPayload.fullName.replace(/\s+/g, '_')}_Contact.vcf`;
                                                                                            link.click();
                                                                                            window.URL.revokeObjectURL(url);
                                                                                        }

                                                                                        // Screenshot 
                                                                                        function takeScreenshot(button) {
                                                                                            const originalText = button.innerHTML;
                                                                                            button.innerHTML = 'Saving...';
                                                                                            button.disabled = true;

                                                                                            const screenshotArea = document.getElementById('capture-area');
                                                                                            const vCardPayload = JSON.parse(document.getElementById('vcard-data').textContent);

                                                                                            html2canvas(screenshotArea, {
                                                                                                useCORS: true,
                                                                                                scale: 2,
                                                                                                backgroundColor: null
                                                                                            }).then(canvas => {
                                                                                                const link = document.createElement('a');
                                                                                                link.download = `${vCardPayload.fullName.replace(/\s+/g, '_')}_Profile.png`;
                                                                                                link.href = canvas.toDataURL('image/png');
                                                                                                link.click();
                                                                                                button.innerHTML = originalText;
                                                                                                button.disabled = false;
                                                                                            }).catch(err => {
                                                                                                console.error(err);
                                                                                                button.innerHTML = originalText;
                                                                                                button.disabled = false;
                                                                                            });
                                                                                        }
                                                                                    </script>
</body>

</html>
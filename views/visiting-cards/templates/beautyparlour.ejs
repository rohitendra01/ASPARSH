                                                                                <p
                                                                                    style="font-size: 0.9rem; color: #666;">
                                                                                    <%= test.context %>
                                                                                </p>
                                                                                <% } %>
                                                                </div>
                                                                <% }); %>
                                                        </div>
                                                        <% if(card.testimonials.length> 1) { %>
                                                            <button class="slider-nav prev"
                                                                onclick="changeSlide('testimonialTrack', -1, <%= card.testimonials.length %>)">‹</button>
                                                            <button class="slider-nav next"
                                                                onclick="changeSlide('testimonialTrack', 1, <%= card.testimonials.length %>)">›</button>
                                                            <div class="slider-indicators" id="testimonialDots">
                                                                <% card.testimonials.forEach((_, index)=> { %>
                                                                    <span class="dot <%= index === 0 ? 'active' : '' %>"
                                                                        onclick="currentSlide('testimonialTrack', <%= index %>, <%= card.testimonials.length %>)"></span>
                                                                    <% }); %>
                                                            </div>

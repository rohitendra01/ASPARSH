                                                                        style="display: flex; flex-wrap: wrap; justify-content: center; gap: 2rem;">
                                                                        <% card.partners.forEach(partner=> { %>
                                                                            <div style="text-align: center;">
                                                                                <% if(partner.logo) { %>
                                                                                    <img src="<%= partner.logo %>"
                                                                                        alt="<%= partner.name %>"

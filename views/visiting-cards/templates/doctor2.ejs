                        <% } %>

                            <% if(card.specializations && card.specializations.length> 0) { %>
                                <section id="specializations" class="section">

                                    <div class="container">
                                        <div class="section-header animate-on-scroll">

                                            <p class="section-subtitle">Areas of Expertise</p>
                                            <h2 class="section-title">Specializations</h2>
                                        </div>

                                        <div class="grid-cards">
                                            <% card.specializations.forEach(spec=> { %>

                                                <div class="card-modern animate-on-scroll">

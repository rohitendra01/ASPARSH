<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= card.profile?.fullName || 'Doctor Profile' %> - <%= card.profile?.designation || '' %>
    </title>
    <meta name="description" content="<%= card.profile?.bio || 'Professional Medical Profile' %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=<%= card.theme?.fontStyle || 'Plus+Jakarta+Sans' %>:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap"
        rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        :root {
            /* Theme Colors - Dynamic via Schema */
            --primary: <%=card.theme?.primaryColor || '#1e3a8a' %>;
            /* Deep Trust Blue */
            --secondary: <%=card.theme?.secondaryColor || '#0ea5e9' %>;
            /* Clinical Teal */
            --accent: #f0f9ff;

            /* UI Colors */
            --bg-body: #f8fafc;
            --bg-surface: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border-soft: rgba(0, 0, 0, 0.05);

            /* Structural */
            --radius-lg: 24px;
            --radius-md: 16px;
            --radius-sm: 8px;
            --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: '<%= card.theme?.fontStyle || "Plus Jakarta Sans" %>', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            line-height: 1.7;
            overflow-x: hidden;
            overflow-wrap: break-word;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        /* Navigation (Glassmorphism) */
        .premium-nav {
            position: fixed;
            top: 1rem;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            padding: 0.8rem 2rem;
            border-radius: 50px;
            box-shadow: var(--shadow-sm);
            border: 1px solid rgba(255, 255, 255, 0.3);
            z-index: 1000;
            display: flex;
            gap: 1.5rem;
            width: max-content;
            max-width: 90%;
            overflow-x: auto;
        }

        .premium-nav a {
            color: var(--text-main);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: var(--transition);
            white-space: nowrap;
        }

        .premium-nav a:hover {
            color: var(--primary);
        }

        /* Hero Parallax Section */
        .hero {
            position: relative;
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-top: 5rem;
            background: linear-gradient(to bottom, rgba(15, 23, 42, 0.7), rgba(15, 23, 42, 0.9)),
                url('<%= card.profile?.coverImage || "https://images.unsplash.com/photo-1551076805-e1869033e561" %>') center/cover fixed;
            color: #fff;
            text-align: center;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 800px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .profile-img-wrapper {
            position: relative;
            margin-bottom: 2rem;
        }

        .profile-img {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 0 0 8px rgba(255, 255, 255, 0.1);
            background-color: var(--bg-surface);
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            letter-spacing: -0.5px;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(8px);
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-weight: 500;
            font-size: 1rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        /* Floating Hero Stats */
        .floating-stats-container {
            transform: translateY(-50%);
            position: relative;
            z-index: 10;
        }

        .floating-stats {
            background: var(--bg-surface);
            border-radius: var(--radius-lg);
            padding: 2rem;
            box-shadow: var(--shadow-lg);
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 2rem;
        }

        .f-stat {
            text-align: center;
        }

        .f-stat-val {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--primary);
            font-family: 'Playfair Display', serif;
            line-height: 1;
        }

        .f-stat-lbl {
            font-size: 0.85rem;
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 0.5rem;
        }

        /* Action Buttons */
        .hero-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .btn {
            padding: 0.8rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            text-decoration: none;
        }

        .btn-primary {
            background: var(--secondary);
            color: #fff;
            box-shadow: 0 4px 15px rgba(14, 165, 233, 0.3);
        }

        .btn-primary:hover {
            background: var(--primary);
            transform: translateY(-2px);
        }

        .btn-outline {
            background: transparent;
            color: #fff;
            border: 2px solid rgba(255, 255, 255, 0.5);
        }

        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: #fff;
        }

        /* Shared Section Styles */
        .section {
            padding: 4rem 0;
        }

        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            color: var(--text-main);
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .section-subtitle {
            color: var(--secondary);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-size: 0.85rem;
        }

        /* Cards Grid (Services/Specializations) */
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .modern-card {
            background: var(--bg-surface);
            border-radius: var(--radius-lg);
            padding: 2.5rem 2rem;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-soft);
            transition: var(--transition);
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .modern-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
            border-color: rgba(14, 165, 233, 0.2);
        }

        .card-icon-wrap {
            width: 60px;
            height: 60px;
            border-radius: var(--radius-md);
            background: var(--accent);
            color: var(--secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
        }

        .modern-card h3 {
            font-size: 1.2rem;
            color: var(--text-main);
            margin-bottom: 0.8rem;
            font-weight: 700;
        }

        .modern-card p {
            color: var(--text-muted);
            font-size: 0.95rem;
            flex-grow: 1;
        }

        /* Timeline (Experience) */
        .timeline-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .timeline-node {
            display: flex;
            gap: 2rem;
            margin-bottom: 2rem;
            position: relative;
        }

        .timeline-node::before {
            content: '';
            position: absolute;
            left: 24px;
            top: 50px;
            bottom: -20px;
            width: 2px;
            background: var(--accent);
        }

        .timeline-node:last-child::before {
            display: none;
        }

        .t-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--bg-surface);
            border: 2px solid var(--secondary);
            color: var(--secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            z-index: 2;
            flex-shrink: 0;
        }

        .t-content {
            background: var(--bg-surface);
            padding: 1.5rem;
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-soft);
            flex-grow: 1;
        }

        .t-content h3 {
            color: var(--primary);
            font-size: 1.1rem;
            margin-bottom: 0.2rem;
        }

        .t-content .t-org {
            font-weight: 600;
            color: var(--text-main);
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }

        .t-content p {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* Contact Details Layout */
        .contact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            background: var(--primary);
            border-radius: var(--radius-lg);
            padding: 3rem;
            color: #fff;
        }

        .contact-box {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
        }

        .c-icon {
            font-size: 1.5rem;
            color: var(--secondary);
            margin-top: 0.2rem;
        }

        .c-info h4 {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.7;
            margin-bottom: 0.2rem;
        }

        .c-info p,
        .c-info a {
            color: #fff;
            font-size: 1rem;
            font-weight: 500;
            text-decoration: none;
            transition: 0.3s;
        }

        .c-info a:hover {
            color: var(--secondary);
        }

        .screenshot-area {
            background-color: var(--bg-body);
        }

        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.2rem;
            }

            .floating-stats {
                gap: 1rem;
                padding: 1.5rem;
            }

            .f-stat-val {
                font-size: 1.6rem;
            }

            .premium-nav {
                padding: 0.6rem 1.2rem;
                gap: 1rem;
            }

            .contact-grid {
                padding: 2rem;
            }
        }
    </style>
</head>

<body>

    <nav class="premium-nav">
        <a href="#about">About</a>
        <% if(card.services && card.services.length> 0) { %><a href="#services">Services</a>
            <% } %>
                <% if(card.experience && card.experience.length> 0) { %><a href="#experience">Experience</a>
                    <% } %>
                        <a href="#contact">Contact</a>
    </nav>

    <div class="screenshot-area" id="capture-area">

        <header class="hero">
            <div class="hero-content container">
                <div class="profile-img-wrapper">
                    <img src="<%= card.profile?.profileImage || 'https://via.placeholder.com/200' %>" alt="Profile"
                        class="profile-img">
                </div>

                <h1 class="hero-title">
                    <%= card.profile?.fullName || 'Doctor Profile' %>
                </h1>

                <div class="hero-badge">
                    <i class="fas fa-stethoscope" style="color: var(--secondary);"></i>
                    <%= card.profile?.designation || 'Medical Professional' %>
                        <% if(card.profile?.companyName) { %> | <%= card.profile.companyName %>
                                <% } %>
                </div>

                <% if(card.profile?.bio) { %>
                    <p class="hero-description">
                        <%= card.profile.bio %>
                    </p>
                    <% } %>

                        <div class="hero-actions">
                            <button class="btn btn-primary" onclick="saveContact()">
                                <i class="fas fa-download"></i> Save Contact
                            </button>
                            <button class="btn btn-outline" onclick="takeScreenshot()">
                                <i class="fas fa-share-nodes"></i> Share Profile
                            </button>
                        </div>

                        <% if(card.socials && Array.isArray(card.socials) && card.socials.length> 0) { %>
                            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                                <% card.socials.forEach(social=> { %>
                                    <a href="<%= social.url %>" target="_blank"
                                        style="color: #fff; font-size: 1.4rem; opacity: 0.8; transition: 0.3s;"
                                        onmouseover="this.style.opacity='1'; this.style.color='var(--secondary)';"
                                        onmouseout="this.style.opacity='0.8'; this.style.color='#fff';">
                                        <i class="<%= social.icon || 'fas fa-link' %>"></i>
                                    </a>
                                    <% }); %>
                            </div>
                            <% } %>
            </div>
        </header>

        <% if(card.heroStats && Array.isArray(card.heroStats) && card.heroStats.length> 0) { %>
            <div class="container floating-stats-container">
                <div class="floating-stats">
                    <% card.heroStats.forEach(stat=> { %>
                        <div class="f-stat">
                            <div class="f-stat-val">
                                <%= stat.value %>
                            </div>
                            <div class="f-stat-lbl">
                                <%= stat.label %>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
            <% } %>

                <section id="about" class="section container"
                    style="<%= (!card.heroStats || card.heroStats.length === 0) ? 'padding-top: 4rem;' : 'padding-top: 1rem;' %>">
                    <div class="section-header">
                        <div class="section-subtitle">Credentials</div>
                        <h2 class="section-title">Professional Background</h2>
                    </div>

                    <% if(card.qualifications && Array.isArray(card.qualifications) && card.qualifications.length> 0) {
                        %>
                        <div class="grid-3" style="max-width: 900px; margin: 0 auto;">
                            <% card.qualifications.forEach(qual=> { %>
                                <div
                                    style="background: var(--bg-surface); padding: 1.2rem; border-radius: var(--radius-sm); border-left: 4px solid var(--secondary); box-shadow: var(--shadow-sm); font-weight: 500; color: var(--text-main);">
                                    <i class="fas fa-check-circle"
                                        style="color: var(--secondary); margin-right: 0.5rem;"></i>
                                    <%= qual %>
                                </div>
                                <% }); %>
                        </div>
                        <% } %>
                </section>

                <% if(card.services && Array.isArray(card.services) && card.services.length> 0) { %>
                    <section id="services" class="section container">
                        <div class="section-header">
                            <div class="section-subtitle">
                                <%= card.theme?.sectionDescriptions?.services || 'What We Offer' %>
                            </div>
                            <h2 class="section-title">
                                <%= card.theme?.sectionTitles?.services || 'Clinical Services' %>
                            </h2>
                        </div>

                        <div class="grid-3">
                            <% card.services.forEach(service=> { %>
                                <div class="modern-card">
                                    <div class="card-icon-wrap"><i
                                            class="<%= service.icon || 'fas fa-notes-medical' %>"></i></div>
                                    <h3>
                                        <%= service.title %>
                                    </h3>
                                    <% if(service.description) { %>
                                        <p>
                                            <%= service.description %>
                                        </p>
                                        <% } %>
                                </div>
                                <% }); %>
                        </div>
                    </section>
                    <% } %>

                        <% if(card.specializations && Array.isArray(card.specializations) &&
                            card.specializations.length> 0) { %>
                            <section class="section container" style="padding-top: 0;">
                                <div class="grid-3">
                                    <% card.specializations.forEach(spec=> { %>
                                        <div class="modern-card"
                                            style="background: var(--primary); color: #fff; border: none;">
                                            <div class="card-icon-wrap"
                                                style="background: rgba(255,255,255,0.1); color: #fff;"><i
                                                    class="<%= spec.icon || 'fas fa-star' %>"></i></div>
                                            <h3 style="color: #fff;">
                                                <%= spec.title %>
                                            </h3>
                                            <% if(spec.description) { %>
                                                <p style="color: rgba(255,255,255,0.8);">
                                                    <%= spec.description %>
                                                </p>
                                                <% } %>
                                        </div>
                                        <% }); %>
                                </div>
                            </section>
                            <% } %>

                                <% if(card.experience && Array.isArray(card.experience) && card.experience.length> 0) {
                                    %>
                                    <section id="experience" class="section container">
                                        <div class="section-header">
                                            <div class="section-subtitle">Career Journey</div>
                                            <h2 class="section-title">
                                                <%= card.theme?.sectionTitles?.experience || 'Experience' %>
                                            </h2>
                                        </div>

                                        <div class="timeline-container">
                                            <% card.experience.forEach(exp=> { %>
                                                <div class="timeline-node">
                                                    <div class="t-icon"><i class="fas fa-briefcase-medical"></i></div>
                                                    <div class="t-content">
                                                        <h3>
                                                            <%= exp.title %>
                                                        </h3>
                                                        <div class="t-org">
                                                            <%= exp.organization %> | <span
                                                                    style="color: var(--secondary);">
                                                                    <%= exp.duration %>
                                                                </span>
                                                        </div>
                                                        <% if(exp.description) { %>
                                                            <p>
                                                                <%= exp.description %>
                                                            </p>
                                                            <% } %>
                                                    </div>
                                                </div>
                                                <% }); %>
                                        </div>
                                    </section>
                                    <% } %>

                                        <section id="contact" class="section container">
                                            <div class="section-header">
                                                <div class="section-subtitle">Get In Touch</div>
                                                <h2 class="section-title">Contact & Location</h2>
                                            </div>

                                            <div class="contact-grid">
                                                <% if(card.contact?.primaryPhone) { %>
                                                    <div class="contact-box">
                                                        <div class="c-icon"><i class="fas fa-phone-alt"></i></div>
                                                        <div class="c-info">
                                                            <h4>Direct Line</h4>
                                                            <a href="tel:<%= card.contact.primaryPhone %>">
                                                                <%= card.contact.primaryPhone %>
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <% } %>

                                                        <% if(card.contact?.primaryEmail) { %>
                                                            <div class="contact-box">
                                                                <div class="c-icon"><i class="fas fa-envelope"></i>
                                                                </div>
                                                                <div class="c-info">
                                                                    <h4>Email Address</h4>
                                                                    <a href="mailto:<%= card.contact.primaryEmail %>">
                                                                        <%= card.contact.primaryEmail %>
                                                                    </a>
                                                                </div>
                                                            </div>
                                                            <% } %>

                                                                <% if(card.contact?.location?.address) { %>
                                                                    <div class="contact-box">
                                                                        <div class="c-icon"><i
                                                                                class="fas fa-map-marker-alt"></i></div>
                                                                        <div class="c-info">
                                                                            <h4>Clinic Location</h4>
                                                                            <p>
                                                                                <%= card.contact.location.address %>
                                                                            </p>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>

                                                                        <% if(card.contact?.businessHours) { %>
                                                                            <div class="contact-box">
                                                                                <div class="c-icon"><i
                                                                                        class="fas fa-clock"></i></div>
                                                                                <div class="c-info">
                                                                                    <h4>Working Hours</h4>
                                                                                    <p>
                                                                                        <%= card.contact.businessHours
                                                                                            %>
                                                                                    </p>
                                                                                </div>
                                                                            </div>
                                                                            <% } %>
                                            </div>
                                        </section>

    </div>
    <script id="vcard-data" type="application/json">
        <%- JSON.stringify({
            fullName: card.profile?.fullName || 'Contact',
            companyName: card.profile?.companyName || '',
            designation: card.profile?.designation || '',
            email: card.contact?.primaryEmail || '',
            phone: card.contact?.primaryPhone || '',
            address: card.contact?.location?.address || '',
            website: card.contact?.website || '',
            bio: card.profile?.bio || ''
        }) %>
    </script>

    <script>
        // 1. Safely Parse Data Bridge
        const vCardPayload = JSON.parse(document.getElementById('vcard-data').textContent);

        // 2. SAVE CONTACT (.vcf)
        function saveContact() {
            const vCardData = "BEGIN:VCARD\n" +
                "VERSION:3.0\n" +
                "FN:" + vCardPayload.fullName + "\n" +
                "ORG:" + vCardPayload.companyName + "\n" +
                "TITLE:" + vCardPayload.designation + "\n" +
                "EMAIL:" + vCardPayload.email + "\n" +
                "TEL:" + vCardPayload.phone + "\n" +
                "ADR:;;" + vCardPayload.address + "\n" +
                "URL:" + vCardPayload.website + "\n" +
                "NOTE:" + vCardPayload.bio.replace(/\n/g, ' ') + "\n" +
                "END:VCARD";

            const blob = new Blob([vCardData], { type: "text/vcard" });
            const url = window.URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.download = vCardPayload.fullName.replace(/\s+/g, '_') + "_Contact.vcf";
            link.click();
            window.URL.revokeObjectURL(url);
        }

        // 3. SCREENSHOT GENERATOR
        function takeScreenshot() {
            const button = event.currentTarget;
            const originalText = button.innerHTML;
            button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
            button.disabled = true;

            const screenshotArea = document.getElementById('capture-area');
            html2canvas(screenshotArea, {
                useCORS: true,
                scale: 2,
                backgroundColor: '#f8fafc' // Matches body bg
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = vCardPayload.fullName.replace(/\s+/g, "_") + "_Profile.png";
                link.href = canvas.toDataURL('image/png');
                link.click();
                button.innerHTML = originalText;
                button.disabled = false;
            }).catch(err => {
                console.error('Screenshot error:', err);
                button.innerHTML = originalText;
                button.disabled = false;
            });
        }
    </script>
</body>

</html>
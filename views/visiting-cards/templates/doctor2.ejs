<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= card.profile?.fullName || 'Professional Profile' %> - <%= card.profile?.designation || '' %>
    </title>
    <meta name="description" content="<%= card.profile?.bio || 'Professional Digital Visiting Card' %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=<%= card.theme?.fontStyle?.replace(/ /g, '+') || 'Inter' %>:wght@300;400;500;600;700;800&family=Merriweather:wght@300;400;700&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="/css/fa-all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        :root {
            /* Dynamic Theme Variables from Schema */
            --primary-blue: <%=card.theme?.primaryColor || '#2563eb' %>;
            --secondary-teal: <%=card.theme?.secondaryColor || '#0891b2' %>;
            --primary-dark: #1e3a8a;

            /* Enhanced Static Design Variables */
            --accent-green: #10b981;
            --bg-glass: rgba(255, 255, 255, 0.85);
            --bg-glass-hover: rgba(255, 255, 255, 0.95);
            --border-glass: rgba(255, 255, 255, 0.4);

            --neutral-50: #f8fafc;
            --neutral-100: #f1f5f9;
            --neutral-500: #64748b;
            --neutral-600: #475569;
            --neutral-700: #334155;
            --neutral-800: #1e293b;
            --white: #ffffff;

            --border-radius-sm: 12px;
            --border-radius-md: 20px;
            --border-radius-lg: 30px;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --shadow-soft: 0 10px 40px -10px rgba(0, 0, 0, 0.1);
            --shadow-hover: 0 20px 40px -10px rgba(0, 0, 0, 0.2);

            /* Gradients based on theme */
            --gradient-primary: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-teal) 100%);
            --gradient-medical: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: '<%= card.theme?.fontStyle || "Inter" %>', sans-serif;
            line-height: 1.6;
            color: var(--neutral-700);
            background: var(--neutral-50);
            overflow-x: hidden;
            position: relative;
        }

        /* Ambient Background Design */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--gradient-medical);
            opacity: 0.6;
            z-index: -2;
        }

        body::after {
            content: '';
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at center, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
            z-index: -1;
            animation: pulseBg 15s infinite alternate ease-in-out;
        }

        @keyframes pulseBg {
            0% {
                transform: scale(1) translate(0, 0);
            }

            100% {
                transform: scale(1.1) translate(2%, 2%);
            }
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        /* Sticky Navigation */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-glass);
            z-index: 1000;
            transition: var(--transition);
            transform: translateY(-100%);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }

        .navbar.visible {
            transform: translateY(0);
            background: rgba(255, 255, 255, 0.98);
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.5rem;
            position: relative;
        }

        .logo {
            font-family: 'Merriweather', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-dark);
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        /* Hamburger Menu Icon */
        .menu-toggle {
            display: none;
            font-size: 1.5rem;
            color: var(--primary-dark);
            cursor: pointer;
            transition: var(--transition);
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        .nav-links a {
            color: var(--neutral-600);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            padding: 0.5rem 0;
            position: relative;
            transition: var(--transition);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--primary-blue);
            transition: var(--transition);
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--primary-blue);
        }

        .nav-links a:hover::after,
        .nav-links a.active::after {
            width: 100%;
        }

        /* Hero Section */
        .hero {
            padding: 8rem 0 4rem;
            position: relative;
        }

        .hero-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3rem;
            position: relative;
            z-index: 2;
        }

        .profile-section {
            display: flex;
            align-items: center;
            gap: 4rem;
            flex-wrap: wrap;
            justify-content: center;
            width: 100%;
            max-width: 1000px;
        }

        .profile-image {
            width: 280px;
            height: 280px;
            border-radius: var(--border-radius-lg);
            background: url("<%= card.profile?.profileImage || 'https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400&h=400&fit=crop' %>") center/cover;
            border: 6px solid var(--white);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15), inset 0 0 0 1px rgba(0, 0, 0, 0.05);
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            flex-shrink: 0;
        }

        .profile-image:hover {
            transform: scale(1.03) translateY(-10px);
            box-shadow: 0 35px 60px rgba(0, 0, 0, 0.2);
        }

        .hero-text {
            flex: 1;
            min-width: 300px;
            color: var(--neutral-800);
            text-align: left;
        }

        /* Subtitles Update */
        .hero-subtitle-container {
            display: flex;
            gap: 1rem;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .hero-designation {
            font-size: 1rem;
            font-weight: 600;
            color: var(--primary-blue);
            background: rgba(37, 99, 235, 0.1);
            padding: 0.5rem 1.2rem;
            border-radius: 50px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .hero-company {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--neutral-600);
            background: var(--white);
            padding: 0.5rem 1.2rem;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .hero-title {
            font-family: 'Merriweather', serif;
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 800;
            margin-bottom: 1.5rem;
            line-height: 1.1;
            color: var(--neutral-800);
        }

        .hero-description {
            font-size: 1.15rem;
            margin-bottom: 2rem;
            color: var(--neutral-600);
            line-height: 1.7;
        }

        .hero-stats {
            display: flex;
            gap: 2.5rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .stat {
            display: flex;
            flex-direction: column;
        }

        .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--primary-blue);
            line-height: 1;
            margin-bottom: 0.25rem;
        }

        .stat-label {
            font-size: 0.9rem;
            color: var(--neutral-500);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Action Buttons */
        .action-buttons {
            display: flex;
            gap: 1.2rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .action-btn {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            background: var(--white);
            color: var(--primary-blue);
            border: none;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1.05rem;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.15);
            min-width: 220px;
            justify-content: center;
        }

        .action-btn:first-child {
            background: var(--gradient-primary);
            color: var(--white);
        }

        .action-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(37, 99, 235, 0.25);
        }

        .action-btn:first-child:hover {
            filter: brightness(1.1);
        }

        /* Social Links */
        .social-links {
            display: flex;
            gap: 1.2rem;
            justify-content: center;
        }

        .social-links a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 50px;
            height: 50px;
            background: var(--white);
            color: var(--primary-blue);
            border-radius: 50%;
            text-decoration: none;
            transition: var(--transition);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            font-size: 1.2rem;
        }

        .social-links a:hover {
            transform: translateY(-4px) scale(1.05);
            background: var(--gradient-primary);
            color: var(--white);
            box-shadow: 0 12px 25px rgba(37, 99, 235, 0.25);
        }

        /* Contact Details Card */
        .contact-details-card {
            background: var(--bg-glass);
            padding: 3.5rem;
            border-radius: var(--border-radius-lg);
            box-shadow: var(--shadow-soft);
            backdrop-filter: blur(20px);
            margin: 0 auto 4rem;
            max-width: 900px;
            border: 1px solid var(--border-glass);
        }

        .contact-details-card h3 {
            text-align: center;
            color: var(--neutral-800);
            margin-bottom: 3rem;
            font-size: 2rem;
            font-family: 'Merriweather', serif;
            font-weight: 800;
        }

        /* Contact items grid layout */
        .contact-grid-wrapper {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            padding: 1.5rem;
            background: var(--white);
            border-radius: var(--border-radius-md);
            text-decoration: none;
            color: inherit;
            border: 1px solid rgba(0, 0, 0, 0.03);
            transition: var(--transition);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        }

        .contact-item:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-hover);
            border-color: rgba(37, 99, 235, 0.2);
        }

        .contact-icon {
            width: 50px;
            height: 50px;
            background: rgba(37, 99, 235, 0.08);
            border-radius: var(--border-radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-blue);
            font-size: 1.25rem;
            flex-shrink: 0;
            transition: var(--transition);
        }

        .contact-item:hover .contact-icon {
            background: var(--gradient-primary);
            color: var(--white);
        }

        .contact-info {
            display: flex;
            flex-direction: column;
        }

        .contact-label {
            font-size: 0.85rem;
            margin-bottom: 0.2rem;
            font-weight: 600;
            color: var(--neutral-500);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .contact-value {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--neutral-800);
        }

        /* Sections General */
        .section {
            padding: 5rem 0;
            position: relative;
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
            max-width: 800px;
            margin: 0 auto 4rem;
        }

        .section-subtitle {
            color: var(--primary-blue);
            font-weight: 700;
            margin-bottom: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-size: 0.9rem;
        }

        .section-title {
            font-family: 'Merriweather', serif;
            font-size: clamp(2.2rem, 4vw, 3rem);
            font-weight: 800;
            color: var(--neutral-800);
        }

        /* Grids for Cards */
        .grid-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
        }

        /* Reusable Card Styles */
        .card-modern {
            background: var(--bg-glass);
            border-radius: var(--border-radius-md);
            padding: 3rem 2.5rem;
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--border-glass);
            transition: var(--transition);
            text-align: center;
        }

        .card-modern:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-hover);
        }

        /* Stats Main Section */
        .stats {
            padding: 5rem 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 2rem;
        }

        /* Service & Specialization Cards */
        .service-icon,
        .specialization-icon {
            width: 80px;
            height: 80px;
            background: rgba(37, 99, 235, 0.08);
            border-radius: var(--border-radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-blue);
            font-size: 2.2rem;
            margin: 0 auto 1.8rem;
            transition: var(--transition);
        }

        .card-modern:hover .service-icon,
        .card-modern:hover .specialization-icon {
            background: var(--gradient-primary);
            color: var(--white);
            transform: scale(1.1) rotate(5deg);
        }

        .card-modern h3 {
            color: var(--neutral-800);
            margin-bottom: 1rem;
            font-size: 1.4rem;
            font-weight: 700;
        }

        .card-modern p {
            color: var(--neutral-600);
            line-height: 1.7;
        }

        /* Testimonial Cards */
        .testimonial-card {
            text-align: left;
            position: relative;
            padding-top: 4rem;
        }

        .testimonial-card::before {
            content: '\f10d';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            top: 2rem;
            left: 2.5rem;
            font-size: 3rem;
            color: rgba(37, 99, 235, 0.1);
        }

        .testimonial-text {
            font-style: italic;
            margin-bottom: 2rem;
            color: var(--neutral-700);
            font-size: 1.1rem;
            line-height: 1.8;
            position: relative;
            z-index: 1;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            border-top: 1px solid rgba(0, 0, 0, 0.05);
            padding-top: 1.5rem;
        }

        .testimonial-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
            background: var(--gradient-primary);
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            font-weight: bold;
            font-size: 1.2rem;
        }

        .author-info h5 {
            color: var(--neutral-800);
            font-size: 1.1rem;
            font-weight: 700;
        }

        .author-info p {
            color: var(--neutral-500);
            font-size: 0.9rem;
        }

        /* Gallery Section */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
        }

        .gallery-item {
            border-radius: var(--border-radius-md);
            overflow: hidden;
            position: relative;
            cursor: pointer;
            aspect-ratio: 4/3;
            box-shadow: var(--shadow-soft);
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .gallery-item:hover img {
            transform: scale(1.08);
        }

        .gallery-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(15, 23, 42, 0.9) 0%, transparent 100%);
            color: var(--white);
            display: flex;
            align-items: flex-end;
            padding: 2rem;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .gallery-item:hover .gallery-overlay {
            opacity: 1;
        }

        .gallery-overlay h4 {
            font-size: 1.2rem;
            font-weight: 600;
            transform: translateY(20px);
            transition: transform 0.4s ease;
        }

        .gallery-item:hover .gallery-overlay h4 {
            transform: translateY(0);
        }

        /* Qualifications List */
        .qualifications {
            background: var(--white);
            padding: 3rem;
            border-radius: var(--border-radius-lg);
            box-shadow: var(--shadow-soft);
            max-width: 900px;
            margin: 0 auto;
        }

        .qualifications ul {
            list-style: none;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .qualifications li {
            position: relative;
            padding-left: 2.5rem;
            color: var(--neutral-700);
            font-size: 1.1rem;
            font-weight: 500;
        }

        .qualifications li::before {
            content: '\f00c';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            left: 0;
            top: 2px;
            color: var(--accent-green);
            background: rgba(16, 185, 129, 0.1);
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
        }

        /* Animations */
        .animate-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .animate-on-scroll.animated {
            opacity: 1;
            transform: translateY(0);
        }

        /* Responsive Design */
        @media (max-width: 992px) {
            .profile-section {
                flex-direction: column;
                text-align: center;
                gap: 2.5rem;
            }

            .hero-subtitle-container {
                justify-content: center;
            }

            .hero-text {
                text-align: center;
            }

            .hero-stats {
                justify-content: center;
            }

            .contact-details-card {
                padding: 2.5rem;
            }
        }

        @media (max-width: 768px) {
            .nav-container {
                padding: 1rem 1.5rem;
            }

            .menu-toggle {
                display: block;
            }

            .nav-links {
                position: absolute;
                top: 100%;
                left: 0;
                right: 0;
                background: rgba(255, 255, 255, 0.98);
                flex-direction: column;
                gap: 1rem;
                padding: 1.5rem;
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
                transition: var(--transition);
                transform: translateY(-150%);
                opacity: 0;
                pointer-events: none;
            }

            .nav-links.active {
                transform: translateY(0);
                opacity: 1;
                pointer-events: auto;
            }

            .logo {
                margin-right: 0;
            }

            .hero {
                padding-top: 6rem;
            }

            .hero-title {
                font-size: 2.5rem;
            }

            .profile-image {
                width: 240px;
                height: 240px;
            }

            /* Buttons side by side update */
            .action-buttons {
                flex-direction: row;
                width: 100%;
                gap: 0.5rem;
                flex-wrap: nowrap;
            }

            .action-btn {
                width: auto;
                min-width: 0;
                flex: 1;
                padding: 0.8rem 0.5rem;
                font-size: 0.85rem;
                white-space: nowrap;
            }

            .contact-details-card {
                margin: 2rem 1rem;
                padding: 1.5rem;
            }

            .section {
                padding: 4rem 0;
            }
        }
    </style>
</head>

<body>

    <nav class="navbar">
        <div class="nav-container">
            <a href="#home" class="logo">
                <%= card.profile?.fullName || 'Profile' %>
            </a>

            <div class="menu-toggle" id="mobile-menu">
                <i class="fas fa-bars"></i>
            </div>

            <ul class="nav-links" id="nav-links">
                <li><a href="#home" class="active">Home</a></li>
                <% if(card.qualifications?.length> 0) { %><li><a href="#about">About</a></li>
                    <% } %>

                        <% if(card.services?.length> 0) { %>
                            <li><a href="#services">
                                    <%= card.theme?.sectionTitles?.services || 'Services' %>
                                </a></li>
                            <% } %>
                                <% if(card.specializations?.length> 0) { %>

                                    <li><a href="#specializations">Specializations</a></li>
                                    <% } %>

                                        <% if(card.testimonials?.length> 0) { %>
                                            <li><a href="#testimonials">Testimonials</a></li>

                                            <% } %>
                                                <% if(card.gallery?.length> 0) { %>

                                                    <li><a href="#gallery">
                                                            <%= card.theme?.sectionTitles?.gallery || 'Gallery' %>
                                                        </a></li>

                                                    <% } %>
            </ul>
        </div>
    </nav>

    <div class="screenshot-area" id="capture-area">
        <section id="home" class="hero">
            <div class="container">
                <div class="hero-content">


                    <div class="profile-section">
                        <div class="profile-image"></div>
                        <div class="hero-text">

                            <div class="hero-subtitle-container">
                                <span class="hero-designation">
                                    <%= card.profile?.designation %>
                                </span>
                                <% if(card.profile?.companyName) { %>
                                    <span class="hero-company">
                                        <i class="fas fa-building"></i>
                                        <%= card.profile.companyName %>
                                    </span>
                                    <% } %>
                            </div>

                            <h1 class="hero-title">
                                <%= card.profile?.fullName %>

                            </h1>
                            <% if(card.profile?.bio) { %>
                                <p class="hero-description">

                                    <%= card.profile.bio %>
                                </p>
                                <% } %>


                                    <% if(card.heroStats && card.heroStats.length> 0) { %>
                                        <div class="hero-stats">

                                            <% card.heroStats.forEach(stat=> { %>
                                                <div class="stat">

                                                    <div class="stat-number">
                                                        <%= stat.value %>


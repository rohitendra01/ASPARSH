<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= card.profile?.fullName || 'Digital Profile' %> - <%= card.profile?.designation || '' %>
    </title>
    <meta name="description" content="<%= card.profile?.bio || 'Digital Business Card' %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=<%= card.theme?.fontStyle || 'Inter' %>:wght@300;400;500;600;700&family=Merriweather:wght@300;400;700&display=swap"
        rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        :root {
            --primary-blue: <%=card.theme?.primaryColor || '#1e40af' %>;
            --secondary-teal: <%=card.theme?.secondaryColor || '#0891b2' %>;
            --primary-light: #3b82f6;
            --accent-green: #10b981;
            --light-blue: #eff6ff;
            --neutral-50: #fafafa;
            --neutral-100: #f5f5f5;
            --neutral-200: #e5e5e5;
            --neutral-300: #d4d4d4;
            --neutral-500: #737373;
            --neutral-600: #525252;
            --neutral-700: #404040;
            --neutral-800: #262626;
            --white: #ffffff;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
            --border-radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --gradient-primary: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-teal) 100%);
            --gradient-light: linear-gradient(135deg, #eff6ff 0%, #dbeafe 50%, #f0f9ff 100%);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: '<%= card.theme?.fontStyle || "Inter" %>', sans-serif;
            line-height: 1.6;
            color: var(--neutral-700);
            background: var(--gradient-light);
            overflow-x: hidden;
            position: relative;
            /* Global text wrapping for resilience */
            overflow-wrap: break-word;
            word-wrap: break-word;
        }

        /* Background Design */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 30%, rgba(30, 64, 175, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 70%, rgba(8, 145, 178, 0.08) 0%, transparent 50%), radial-gradient(circle at 40% 80%, rgba(16, 185, 129, 0.06) 0%, transparent 40%), linear-gradient(135deg, #eff6ff 0%, #dbeafe 50%, #f0f9ff 100%);
            z-index: -2;
        }

        .container {
            max-width: 100%;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .section {
            padding: 2rem 0;
            margin: 0 1rem;
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            padding: 2rem 0;
        }

        .hero-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 1.5rem;
            width: 100%;
        }

        .profile-image {
            width: 200px;
            height: 200px;
            border-radius: 25%;
            background-size: cover;
            background-position: center;
            border: 3px solid var(--white);
            box-shadow: 0 20px 40px rgba(30, 64, 175, 0.2), 0 0 0 8px rgba(255, 255, 255, 0.8);
            transition: transform 0.3s ease;
        }

        .profile-image:hover {
            transform: scale(1.05);
        }

        .hero-title {
            font-family: 'Merriweather', serif;
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--primary-blue);
            margin-bottom: 0.5rem;
            line-height: 1.2;
        }

        /* IMPROVED UI: Designation & Company Layout */
        .hero-subtitle-group {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            width: 100%;
        }

        .hero-designation {
            font-size: 1rem;
            color: var(--primary-blue);
            background: var(--light-blue);
            border: 1px solid rgba(30, 64, 175, 0.1);
            padding: 0.4rem 1.2rem;
            border-radius: 25px;
            font-weight: 600;
            display: inline-block;
            max-width: 90%;
        }

        .hero-company {
            font-size: 0.95rem;
            color: var(--neutral-600);
            font-weight: 500;
            max-width: 90%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .hero-description {
            font-size: 0.95rem;
            color: var(--neutral-600);
            margin: 1rem auto;
            line-height: 1.6;
            max-width: 600px;
        }

        /* General UI Elements */
        .section-title {
            font-family: 'Merriweather', serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--neutral-800);
            margin-bottom: 1rem;
            text-align: center;
        }

        .section-description {
            text-align: center;
            color: var(--neutral-600);
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }

        /* Stats */
        .hero-stats {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            justify-content: center;
            width: 100%;
        }

        .stat {
            text-align: center;
            background: var(--white);
            padding: 1rem;
            border-radius: 12px;
            box-shadow: var(--shadow-md);
            flex: 1;
            min-width: 90px;
            max-width: 150px;
            border: 1px solid var(--neutral-200);
        }

        .stat-number {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--primary-blue);
            line-height: 1;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--neutral-500);
            margin-top: 0.4rem;
            font-weight: 500;
            line-height: 1.2;
        }

        .stats-section {
            background: var(--white);
            margin: 1rem;
            padding: 1.5rem;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--neutral-200);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 1rem;
        }

        .stat-item {
            text-align: center;
            padding: 1.5rem 1rem;
            background: var(--light-blue);
            border-radius: 12px;
            border: 1px solid var(--neutral-200);
        }

        /* Buttons & Socials */
        .action-buttons {
            display: flex;
            gap: 0.8rem;
            justify-content: center;
            width: 100%;
            max-width: 400px;
            flex-wrap: wrap;
        }

        .action-btn {
            flex: 1;
            min-width: 160px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            background: var(--white);
            color: var(--primary-blue);
            border: 2px solid var(--primary-blue);
            padding: 0.9rem 1.2rem;
            border-radius: 25px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            box-shadow: var(--shadow-md);
        }

        .action-btn:hover {
            background: var(--primary-blue);
            color: var(--white);
            transform: translateY(-2px);
        }

        .social-links {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .social-links a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            background: var(--white);
            color: var(--primary-blue);
            border-radius: 50%;
            text-decoration: none;
            transition: var(--transition);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--neutral-200);
            font-size: 1.2rem;
        }

        .social-links a:hover {
            background: var(--primary-blue);
            color: var(--white);
            transform: translateY(-2px);
        }

        /* Contact Details */
        .contact-details-card {
            background: var(--white);
            margin: 1.5rem 1rem;
            padding: 1.5rem;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--neutral-200);
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
            padding: 1rem;
            background: var(--neutral-50);
            border-radius: 12px;
            transition: var(--transition);
            text-decoration: none;
            color: inherit;
            border: 1px solid var(--neutral-200);
        }

        .contact-item:hover {
            background: var(--light-blue);
            transform: translateY(-1px);
        }

        .contact-icon {
            width: 45px;
            height: 45px;
            background: var(--gradient-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--white);
            flex-shrink: 0;
        }

        .contact-info {
            flex: 1;
            min-width: 0;
        }

        .contact-label {
            font-size: 0.8rem;
            color: var(--neutral-500);
            margin-bottom: 0.2rem;
            font-weight: 600;
        }

        .contact-value {
            font-size: 0.95rem;
            color: var(--neutral-800);
            font-weight: 500;
        }

        /* Content Grids */
        .grid-layout {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .content-card {
            background: var(--white);
            border-radius: var(--border-radius);
            padding: 1.5rem;
            box-shadow: var(--shadow-md);
            border: 1px solid var(--neutral-200);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .content-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary-blue);
        }

        .card-icon {
            width: 55px;
            height: 55px;
            background: var(--gradient-primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .card-text h3 {
            color: var(--neutral-800);
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .card-text p {
            color: var(--neutral-600);
            font-size: 0.9rem;
            line-height: 1.6;
        }

        /* Timeline & Qualifications */
        .timeline {
            padding-left: 1rem;
            border-left: 2px solid var(--primary-blue);
            margin-left: 1rem;
        }

        .timeline-item {
            position: relative;
            padding-bottom: 2rem;
            padding-left: 1.5rem;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -1.9rem;
            top: 0;
            width: 12px;
            height: 12px;
            background: var(--white);
            border: 3px solid var(--primary-blue);
            border-radius: 50%;
        }

        .qualifications {
            background: var(--light-blue);
            padding: 1.5rem;
            border-radius: 12px;
            margin-top: 1rem;
        }

        .qualifications ul {
            list-style: none;
        }

        .qualifications li {
            padding: 0.4rem 0 0.4rem 1.5rem;
            position: relative;
            color: var(--neutral-700);
            font-weight: 500;
        }

        .qualifications li::before {
            content: '\f00c';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            left: 0;
            color: var(--accent-green);
        }

        /* Carousels (Testimonials & Gallery) */
        .carousel-container {
            position: relative;
            overflow: hidden;
            border-radius: var(--border-radius);
            background: var(--white);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--neutral-200);
        }

        .carousel-track {
            display: flex;
            transition: transform 0.4s ease;
        }

        .carousel-slide {
            min-width: 100%;
            padding: 2rem;
        }

        .testimonial-text {
            font-size: 1rem;
            color: var(--neutral-600);
            font-style: italic;
            margin-bottom: 1.5rem;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .testimonial-avatar {
            width: 50px;
            height: 50px;
            background: var(--gradient-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-weight: bold;
            overflow: hidden;
            flex-shrink: 0;
        }

        .testimonial-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .author-info {
            min-width: 0;
        }

        .author-info h5 {
            color: var(--neutral-800);
            font-size: 1rem;
            margin-bottom: 0.2rem;
        }

        .author-info p {
            color: var(--primary-blue);
            font-size: 0.85rem;
        }

        .gallery-slide {
            padding: 0;
            position: relative;
        }

        .gallery-slide img {
            width: 100%;
            height: 300px;
            object-fit: cover;
            display: block;
        }

        .gallery-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
            color: var(--white);
            padding: 1.5rem;
            text-align: center;
        }

        .carousel-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255, 255, 255, 0.9);
            color: var(--primary-blue);
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: var(--shadow-md);
            z-index: 10;
        }

        .carousel-nav:hover {
            background: var(--primary-blue);
            color: var(--white);
        }

        .carousel-nav.prev {
            left: 10px;
        }

        .carousel-nav.next {
            right: 10px;
        }

        .carousel-dots {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            padding: 1rem;
            background: var(--white);
            border-top: 1px solid var(--neutral-100);
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--neutral-300);
            cursor: pointer;
            transition: var(--transition);
        }

        .dot.active {
            background: var(--primary-blue);
            transform: scale(1.2);
        }

        .screenshot-area {
            background: var(--gradient-light);
            padding-bottom: 2rem;
        }

        .back-to-top {
            position: fixed;
            bottom: 1rem;
            right: 1rem;
            width: 50px;
            height: 50px;
            background: var(--gradient-primary);
            color: var(--white);
            border: none;
            border-radius: 50%;
            cursor: pointer;
            opacity: 0;
            visibility: hidden;
            transition: var(--transition);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            box-shadow: var(--shadow-lg);
        }

        .back-to-top.visible {
            opacity: 1;
            visibility: visible;
        }
    </style>
</head>

<body>
    <div class="screenshot-area" id="capture-area">

        <section class="hero">
            <div class="container">
                <div class="hero-content">
                    <div class="profile-image"
                        style="background-image: url('<%= card.profile?.profileImage || `https://via.placeholder.com/200` %>')">
                    </div>

                    <div class="hero-text">
                        <h1 class="hero-title">
                            <%= card.profile?.fullName || 'Professional Profile' %>
                        </h1>

                        <div class="hero-subtitle-group">
                            <% if (card.profile?.designation) { %>
                                <div class="hero-designation">
                                    <%= card.profile.designation %>
                                </div>
                                <% } %>
                                    <% if (card.profile?.companyName) { %>
                                        <div class="hero-company">
                                            <i class="fas fa-building"
                                                style="color: var(--primary-blue); opacity: 0.8;"></i>
                                            <%= card.profile.companyName %>
                                        </div>
                                        <% } %>
                        </div>

                        <% if(card.profile?.bio) { %>
                            <p class="hero-description">
                                <%= card.profile.bio %>
                            </p>
                            <% } %>

                                <% if(typeof card.heroStats !=='undefined' && Array.isArray(card.heroStats) &&
                                    card.heroStats.length> 0) { %>
                                    <div class="hero-stats">
                                        <% card.heroStats.forEach(stat=> { %>
                                            <div class="stat">
                                                <div class="stat-number">
                                                    <%= stat.value %>
                                                </div>
                                                <div class="stat-label">
                                                    <%= stat.label %>
                                                </div>
                                            </div>
                                            <% }); %>
                                    </div>
                                    <% } %>
                    </div>

                    <div class="action-buttons">
                        <button class="action-btn" onclick="saveContact()">
                            <i class="fas fa-address-card"></i> Save Contact
                        </button>
                        <button class="action-btn" onclick="takeScreenshot()"
                            style="background: var(--primary-blue); color: var(--white);">
                            <i class="fas fa-share-nodes"></i> Share Profile
                        </button>
                    </div>

                    <% if(typeof card.socials !=='undefined' && Array.isArray(card.socials) && card.socials.length> 0) {
                        %>
                        <div class="social-links">
                            <% card.socials.forEach(social=> { %>
                                <a href="<%= social.url %>" target="_blank" title="<%= social.platform %>">
                                    <i class="<%= social.icon || 'fas fa-link' %>"></i>
                                </a>
                                <% }); %>
                        </div>
                        <% } %>
                </div>
            </div>
        </section>

        <% if(card.contact) { %>
            <div class="container">
                <div class="contact-details-card">
                    <h3 class="section-title" style="font-size: 1.4rem; margin-bottom: 1.5rem;">Contact Information</h3>

                    <% if(card.contact.primaryPhone) { %>
                        <a href="tel:<%= card.contact.primaryPhone %>" class="contact-item">
                            <div class="contact-icon"><i class="fas fa-phone"></i></div>
                            <div class="contact-info">
                                <div class="contact-label">Primary Phone</div>
                                <div class="contact-value">
                                    <%= card.contact.primaryPhone %>
                                </div>
                            </div>
                        </a>
                        <% } %>

                            <% if(card.contact.primaryEmail) { %>
                                <a href="mailto:<%= card.contact.primaryEmail %>" class="contact-item">
                                    <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                                    <div class="contact-info">
                                        <div class="contact-label">Email Address</div>
                                        <div class="contact-value">
                                            <%= card.contact.primaryEmail %>
                                        </div>
                                    </div>
                                </a>
                                <% } %>

                                    <% if(card.contact.location && card.contact.location.address) { %>
                                        <a href="<%= card.contact.location.mapEmbedUrl || '#' %>" target="_blank"
                                            class="contact-item">
                                            <div class="contact-icon"><i class="fas fa-map-marker-alt"></i></div>
                                            <div class="contact-info">
                                                <div class="contact-label">Location</div>
                                                <div class="contact-value">
                                                    <%= card.contact.location.address %>
                                                </div>
                                            </div>
                                        </a>
                                        <% } %>

                                            <% if(card.contact.businessHours) { %>
                                                <div class="contact-item">
                                                    <div class="contact-icon"><i class="fas fa-clock"></i></div>
                                                    <div class="contact-info">
                                                        <div class="contact-label">Business Hours</div>
                                                        <div class="contact-value">
                                                            <%= card.contact.businessHours %>
                                                        </div>
                                                    </div>
                                                </div>
                                                <% } %>

                                                    <% if(typeof card.contact.additionalContacts !=='undefined' &&
                                                        Array.isArray(card.contact.additionalContacts) &&
                                                        card.contact.additionalContacts.length> 0) { %>
                                                        <% card.contact.additionalContacts.forEach(ac=> { %>
                                                            <a href="<%= ac.link || '#' %>" target="_blank"
                                                                class="contact-item">
                                                                <div class="contact-icon"><i
                                                                        class="<%= ac.icon || 'fas fa-link' %>"></i>
                                                                </div>
                                                                <div class="contact-info">
                                                                    <div class="contact-label">
                                                                        <%= ac.platform %>
                                                                    </div>
                                                                    <div class="contact-value">
                                                                        <%= ac.value %>
                                                                    </div>
                                                                </div>
                                                            </a>
                                                            <% }); %>
                                                                <% } %>
                </div>
            </div>
            <% } %>

                <% if(typeof card.stats !=='undefined' && Array.isArray(card.stats) && card.stats.length> 0) { %>
                    <section class="section container">
                        <div class="stats-section">
                            <h2 class="section-title">
                                <%= card.theme?.sectionTitles?.stats || 'Highlights & Excellence' %>
                            </h2>
                            <div class="stats-grid">
                                <% card.stats.forEach(stat=> { %>
                                    <div class="stat-item">
                                        <i class="<%= stat.icon || 'fas fa-star' %>"
                                            style="font-size: 1.5rem; color: var(--primary-blue); margin-bottom: 0.5rem;"></i>
                                        <div class="stat-number">
                                            <%= stat.value %>
                                        </div>
                                        <div class="stat-label">
                                            <%= stat.label %>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                        </div>
                    </section>
                    <% } %>

                        <% if(card.profile?.bio || (typeof card.qualifications !=='undefined' &&
                            Array.isArray(card.qualifications) && card.qualifications.length> 0)) { %>
                            <section class="section container">
                                <h2 class="section-title">About</h2>
                                <div class="contact-details-card" style="margin: 0;">
                                    <% if(card.profile?.bio) { %>
                                        <p style="color: var(--neutral-600); margin-bottom: 1.5rem;">
                                            <%= card.profile.bio %>
                                        </p>
                                        <% } %>

                                            <% if(typeof card.qualifications !=='undefined' &&
                                                Array.isArray(card.qualifications) && card.qualifications.length> 0) {
                                                %>
                                                <div class="qualifications">
                                                    <h4
                                                        style="color: var(--neutral-800); margin-bottom: 1rem; font-size: 1.1rem;">
                                                        Credentials & Qualifications</h4>
                                                    <ul>
                                                        <% card.qualifications.forEach(qual=> { %>
                                                            <li>
                                                                <%= qual %>
                                                            </li>
                                                            <% }); %>
                                                    </ul>
                                                </div>
                                                <% } %>
                                </div>
                            </section>
                            <% } %>

                                <% if(typeof card.services !=='undefined' && Array.isArray(card.services) &&
                                    card.services.length> 0) { %>
                                    <section class="section container">
                                        <h2 class="section-title">
                                            <%= card.theme?.sectionTitles?.services || 'Our Services' %>
                                        </h2>
                                        <% if(card.theme?.sectionDescriptions?.services) { %>
                                            <p class="section-description">
                                                <%= card.theme.sectionDescriptions.services %>
                                            </p>
                                            <% } %>

                                                <div class="grid-layout">
                                                    <% card.services.forEach(service=> { %>
                                                        <div class="content-card">
                                                            <div style="display: flex; align-items: center; gap: 1rem;">
                                                                <div class="card-icon"><i
                                                                        class="<%= service.icon || 'fas fa-stethoscope' %>"></i>
                                                                </div>
                                                                <h3
                                                                    style="color: var(--neutral-800); font-weight: 700; margin:0;">
                                                                    <%= service.title %>
                                                                </h3>
                                                            </div>
                                                            <% if(service.description) { %>
                                                                <p style="color: var(--neutral-600);">
                                                                    <%= service.description %>
                                                                </p>
                                                                <% } %>
                                                        </div>
                                                        <% }); %>
                                                </div>
                                    </section>
                                    <% } %>

                                        <% if(typeof card.specializations !=='undefined' &&
                                            Array.isArray(card.specializations) && card.specializations.length> 0) { %>
                                            <section class="section container">
                                                <h2 class="section-title">Specializations</h2>
                                                <div class="grid-layout">
                                                    <% card.specializations.forEach(spec=> { %>
                                                        <div class="content-card"
                                                            style="background: var(--gradient-primary); color: var(--white); border: none; text-align: center; align-items: center;">
                                                            <i class="<%= spec.icon || 'fas fa-heartbeat' %>"
                                                                style="font-size: 2.5rem; margin-bottom: 0.5rem;"></i>
                                                            <h3
                                                                style="color: var(--white); font-weight: 700; font-size: 1.2rem; margin:0;">
                                                                <%= spec.title %>
                                                            </h3>
                                                            <% if(spec.description) { %>
                                                                <p style="color: rgba(255,255,255,0.9);">
                                                                    <%= spec.description %>
                                                                </p>
                                                                <% } %>
                                                        </div>
                                                        <% }); %>
                                                </div>
                                            </section>
                                            <% } %>

                                                <% if(typeof card.experience !=='undefined' &&
                                                    Array.isArray(card.experience) && card.experience.length> 0) { %>
                                                    <section class="section container">
                                                        <h2 class="section-title">
                                                            <%= card.theme?.sectionTitles?.experience
                                                                || 'Experience & Journey' %>
                                                        </h2>
                                                        <div class="contact-details-card" style="margin: 0;">
                                                            <div class="timeline">
                                                                <% card.experience.forEach(exp=> { %>
                                                                    <div class="timeline-item">
                                                                        <h3
                                                                            style="color: var(--neutral-800); font-weight: 700; margin-bottom: 0.3rem;">
                                                                            <%= exp.title %>
                                                                        </h3>
                                                                        <div
                                                                            style="color: var(--primary-blue); font-weight: 600; font-size: 0.9rem; margin-bottom: 0.5rem;">
                                                                            <%= exp.organization %> | <%= exp.duration
                                                                                    %>
                                                                        </div>
                                                                        <% if(exp.description) { %>
                                                                            <p style="color: var(--neutral-600);">
                                                                                <%= exp.description %>
                                                                            </p>
                                                                            <% } %>
                                                                    </div>
                                                                    <% }); %>
                                                            </div>
                                                        </div>
                                                    </section>
                                                    <% } %>

                                                        <% if(typeof card.testimonials !=='undefined' &&
                                                            Array.isArray(card.testimonials) &&
                                                            card.testimonials.length> 0) { %>
                                                            <section class="section container">
                                                                <h2 class="section-title">Client Reviews</h2>
                                                                <div class="carousel-container">
                                                                    <div class="carousel-track" id="testimonialsTrack">
                                                                        <% card.testimonials.forEach(test=> { %>
                                                                            <div class="carousel-slide">
                                                                                <i class="fas fa-quote-left"
                                                                                    style="font-size: 2rem; color: var(--primary-light); opacity: 0.2; margin-bottom: 1rem; display: block;"></i>
                                                                                <p class="testimonial-text">"<%=
                                                                                        test.quote %>"</p>
                                                                                <div class="testimonial-author">
                                                                                    <div class="testimonial-avatar">
                                                                                        <%- test.avatar ? `<img
                                                                                            src="${test.avatar}"
                                                                                            alt="Avatar">` :
                                                                                            test.clientName.substring(0,
                                                                                            2).toUpperCase() %>
                                                                                    </div>
                                                                                    <div class="author-info">
                                                                                        <h5
                                                                                            style="font-weight: 700; margin:0;">
                                                                                            <%= test.clientName %>
                                                                                        </h5>
                                                                                        <% if(test.context) { %>
                                                                                            <p style="margin:0;">
                                                                                                <%= test.context %>
                                                                                            </p>
                                                                                            <% } %>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                            <% }); %>
                                                                    </div>
                                                                    <div class="carousel-dots">
                                                                        <% card.testimonials.forEach((_, index)=> { %>
                                                                            <span
                                                                                class="dot <%= index === 0 ? 'active' : '' %>"
                                                                                onclick="moveCarousel('testimonialsTrack', <%= index %>)"></span>
                                                                            <% }); %>
                                                                    </div>
                                                                </div>
                                                            </section>
                                                            <% } %>

                                                                <% if(typeof card.gallery !=='undefined' &&
                                                                    Array.isArray(card.gallery) && card.gallery.length>
                                                                    0) { %>
                                                                    <section class="section container">
                                                                        <h2 class="section-title">
                                                                            <%= card.theme?.sectionTitles?.gallery
                                                                                || 'Gallery' %>
                                                                        </h2>
                                                                        <div class="carousel-container"
                                                                            style="position: relative;">
                                                                            <div class="carousel-track"
                                                                                id="galleryTrack">
                                                                                <% card.gallery.forEach(img=> { %>
                                                                                    <div
                                                                                        class="carousel-slide gallery-slide">
                                                                                        <img src="<%= img.image %>"
                                                                                            alt="<%= img.title || 'Gallery Image' %>">
                                                                                        <% if(img.title) { %>
                                                                                            <div
                                                                                                class="gallery-overlay">
                                                                                                <h4 style="margin:0;">
                                                                                                    <%= img.title %>
                                                                                                </h4>
                                                                                            </div>
                                                                                            <% } %>
                                                                                    </div>
                                                                                    <% }); %>
                                                                            </div>
                                                                            <button class="carousel-nav prev"
                                                                                onclick="shiftGallery(-1)"><i
                                                                                    class="fas fa-chevron-left"></i></button>
                                                                            <button class="carousel-nav next"
                                                                                onclick="shiftGallery(1)"><i
                                                                                    class="fas fa-chevron-right"></i></button>
                                                                            <div class="carousel-dots">
                                                                                <% card.gallery.forEach((_, index)=> {
                                                                                    %>
                                                                                    <span
                                                                                        class="dot <%= index === 0 ? 'active' : '' %>"
                                                                                        onclick="moveCarousel('galleryTrack', <%= index %>)"></span>
                                                                                    <% }); %>
                                                                            </div>
                                                                        </div>
                                                                    </section>
                                                                    <% } %>

    </div>

    <button class="back-to-top" aria-label="Back to top">
        <i class="fas fa-chevron-up"></i>
    </button>

    <script>
        // 1. EXTRACT DATA SAFELY: No EJS inside JS template literals to fix "Expression Expected" IDE errors.
        const vCardPayload = {
            fullName: "<%- (card.profile?.fullName || '').replace(/'/g, '&apos;').replace(/\"/g, '&quot;') %>",
            companyName: "<%- (card.profile?.companyName || '').replace(/'/g, '&apos;').replace(/\"/g, '&quot;') %>",
            designation: "<%- (card.profile?.designation || '').replace(/'/g, '&apos;').replace(/\"/g, '&quot;') %>",
            email: "<%- (card.contact?.primaryEmail || '').replace(/'/g, '&apos;').replace(/\"/g, '&quot;') %>",
            phone: "<%- (card.contact?.primaryPhone || '').replace(/'/g, '&apos;').replace(/\"/g, '&quot;') %>",
            address: "<%- (card.contact?.location?.address || '').replace(/'/g, '&apos;').replace(/\"/g, '&quot;') %>",
            website: "<%- (card.contact?.website || '').replace(/'/g, '&apos;').replace(/\"/g, '&quot;') %>",
            bio: "<%- (card.profile?.bio || '').replace(/\\n/g, ' ').replace(/'/g, '&apos;').replace(/\"/g, '&quot;') %>"
        };

        // Safely extract counts via parseInt
        const tCount = parseInt("<%= (typeof card.testimonials !== 'undefined' && Array.isArray(card.testimonials)) ? card.testimonials.length : 0 %>", 10);
        const gCount = parseInt("<%= (typeof card.gallery !== 'undefined' && Array.isArray(card.gallery)) ? card.gallery.length : 0 %>", 10);

        // 2. SAVE CONTACT (.vcf)
        function saveContact() {
            const vCardData = "BEGIN:VCARD\n" +
                "VERSION:3.0\n" +
                "FN:" + vCardPayload.fullName + "\n" +
                "ORG:" + vCardPayload.companyName + "\n" +
                "TITLE:" + vCardPayload.designation + "\n" +
                "EMAIL:" + vCardPayload.email + "\n" +
                "TEL:" + vCardPayload.phone + "\n" +
                "ADR:;;" + vCardPayload.address + "\n" +
                "URL:" + vCardPayload.website + "\n" +
                "NOTE:" + vCardPayload.bio + "\n" +
                "END:VCARD";

            const blob = new Blob([vCardData], { type: "text/vcard" });
            const url = window.URL.createObjectURL(blob);
            const link = document.createElement("a");
            const safeName = (vCardPayload.fullName || "Contact").replace(/\s+/g, '_');
            link.href = url;
            link.download = safeName + "_Contact.vcf";
            link.click();
            window.URL.revokeObjectURL(url);
        }

        // 3. SCREENSHOT GENERATOR
        function takeScreenshot() {
            const button = event.currentTarget;
            const originalText = button.innerHTML;
            button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
            button.disabled = true;

            const screenshotArea = document.getElementById('capture-area');
            html2canvas(screenshotArea, {
                useCORS: true,
                scale: 2,
                backgroundColor: null
            }).then(canvas => {
                const link = document.createElement('a');
                const safeName = (vCardPayload.fullName || "Profile").replace(/\s+/g, "_");
                link.download = safeName + "_Profile.png";
                link.href = canvas.toDataURL('image/png');
                link.click();
                button.innerHTML = originalText;
                button.disabled = false;
            }).catch(err => {
                console.error('Screenshot error:', err);
                button.innerHTML = originalText;
                button.disabled = false;
            });
        }

        // 4. UNIVERSAL CAROUSEL LOGIC
        let state = { testimonialsTrack: 0, galleryTrack: 0 };

        function moveCarousel(trackId, index) {
            const track = document.getElementById(trackId);
            if (!track) return;

            const container = track.parentElement;
            const dots = container.querySelectorAll('.carousel-dots .dot');

            state[trackId] = index;
            track.style.transform = `translateX(-${index * 100}%)`;

            dots.forEach(d => d.classList.remove('active'));
            if (dots[index]) dots[index].classList.add('active');
        }

        function shiftGallery(direction) {
            if (gCount === 0) return;
            let newIndex = state.galleryTrack + direction;
            if (newIndex >= gCount) newIndex = 0;
            if (newIndex < 0) newIndex = gCount - 1;
            moveCarousel('galleryTrack', newIndex);
        }

        if (tCount > 1) {
            setInterval(() => {
                let newIndex = state.testimonialsTrack + 1;
                if (newIndex >= tCount) newIndex = 0;
                moveCarousel('testimonialsTrack', newIndex);
            }, 5000);
        }

        // 5. UI INTERACTIVITY
        window.addEventListener('scroll', function () {
            const backToTop = document.querySelector('.back-to-top');
            if (window.scrollY > 300) backToTop.classList.add('visible');
            else backToTop.classList.remove('visible');
        });

        document.querySelector('.back-to-top').addEventListener('click', function () {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        document.querySelectorAll('.contact-item').forEach(item => {
            item.addEventListener('click', function (e) {
                const href = this.getAttribute('href');
                if (href && href !== '#') {
                    window.open(href, href.startsWith('tel:') || href.startsWith('mailto:') ? '_self' : '_blank');
                }
            });
        });

        window.addEventListener('load', () => { document.body.style.opacity = '1'; });
        document.body.style.opacity = '0';
        document.body.style.transition = 'opacity 0.5s ease';
    </script>
</body>

</html>
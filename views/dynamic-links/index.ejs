<% layout('layouts/dashboard-boilerplate') -%>
    <% block('styles').append(`<link rel="stylesheet" href="/css/dynamic-links/index.css" />`) %>

    <div class="dashboard-header-row">
        <form class="search-form" onsubmit="return filterLinks(event)">
            <input type="text" id="linkSearch" name="linkSearch" placeholder="Search Links" required>
            <button type="submit">Search</button>
        </form>
        <a href="/dashboard/<%= currentUser.slug %>/dynamic-links/new" class="create-link-btn create-link-btn-fixed">+
            Create New Link</a>
    </div>

    <div class="link-list-container">
        <% if (links && links.length> 0) { %>
            <div class="link-cards-grid">
                <% links.forEach(link=> { %>
                    <div class="link-card" data-link-name="<%= link.name %>" data-link-slug="<%= link.slug %>">
                        <div class="link-card-qr">
                            <!-- QR Code will be loaded via JS -->
                            <img src="https://placehold.co/200x200?text=Loading+QR" alt="QR Code" class="qr-img"
                                data-id="<%= link._id %>" data-slug="<%= link.slug %>">
                        </div>
                        <div class="link-card-body">
                            <h2 class="link-card-title">
                                <%= link.name %>
                            </h2>
                            <p class="link-card-url"><a href="/q/<%= link.slug %>" target="_blank">/q/<%= link.slug %>
                                </a></p>
                            <p class="link-card-stats"><i class="bi bi-bar-chart"></i>
                                <%= link.clicks %> Clicks
                            </p>

                            <div class="link-card-links">
                                <a href="/dashboard/<%= currentUser.slug %>/dynamic-links/<%= link._id %>/edit"
                                    class="link-card-btn edit-btn" title="Edit Link">
                                    <i class="bi bi-pencil">Edit</i>
                                </a>

                                <button class="link-card-btn copy-btn"
                                    data-clipboard-text="<%= req.protocol %>://<%= req.get('host') %>/q/<%= link.slug %>"
                                    title="Copy Link">
                                    <i class="bi bi-clipboard">Copy</i>
                                </button>

                                <a href="#" download="<%= link.name.replace(/[^a-z0-9]/gi, '_').toLowerCase() %>_qr.png"
                                    class="link-card-btn download-btn" title="Download QR"
                                    style="pointer-events: none; opacity: 0.6;">
                                    <i class="bi bi-download">Download</i>
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>
            <% } else { %>
                <div class="text-center mt-5">
                    <p class="lead">No dynamic links created yet.</p>
                </div>
                <% } %>
    </div>

    <script>
        // Filter Script
        function filterLinks(event) {
            event.preventDefault();
            const input = document.getElementById('linkSearch').value.trim().toLowerCase();
            const cards = document.querySelectorAll('.link-card');

            if (!input) {
                cards.forEach(card => card.style.display = '');
                return false;
            }

            cards.forEach(card => {
                const name = card.getAttribute('data-link-name') || '';
                const slug = card.getAttribute('data-link-slug') || '';

                if (name.toLowerCase().includes(input) || slug.toLowerCase().includes(input)) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
            return false;
        }

        // Lazy Load QR Codes
        document.addEventListener('DOMContentLoaded', function () {
            const qrImages = document.querySelectorAll('.qr-img');
            const options = {
                root: null,
                rootMargin: '0px',
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        loadQr(entry.target);
                        observer.unobserve(entry.target);
                    }
                });
            }, options);

            qrImages.forEach(img => observer.observe(img));

            function loadQr(img) {
                const id = img.getAttribute('data-id');
                fetch(`/dashboard/<%= currentUser.slug %>/dynamic-links/${id}/qr`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.qrCodeImage) {
                            img.src = data.qrCodeImage;

                            // Enable download button
                            const card = img.closest('.link-card');
                            const downloadBtn = card.querySelector('.download-btn');
                            if (downloadBtn) {
                                downloadBtn.href = data.qrCodeImage;
                                downloadBtn.style.pointerEvents = 'auto';
                                downloadBtn.style.opacity = '1';
                            }
                        } else {
                            img.src = 'https://placehold.co/200x200?text=Error';
                        }
                    })
                    .catch(err => {
                        console.error('Failed to load QR', err);
                        img.src = 'https://placehold.co/200x200?text=Error';
                    });
            }

            // Initialize Clipboard
            // Assuming ClipboardJS is available in dashboard boilerplate, otherwise basic fallback?
            // The previous index.ejs used a copy-btn class, so I assume there is some global script handling it.
            // If not, I'll add a simple click handler.
            document.querySelectorAll('.copy-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    const text = this.getAttribute('data-clipboard-text');
                    navigator.clipboard.writeText(text).then(() => {
                        const original = this.innerHTML;
                        this.innerHTML = '<i class="bi bi-check"></i>';
                        setTimeout(() => this.innerHTML = original, 2000);
                    });
                });
            });
        });
    </script>
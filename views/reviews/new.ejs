<% layout('layouts/dashboard-boilerplate') %>

<% const slugSegment = (typeof slug !== 'undefined' && slug) ? '/' + encodeURIComponent(slug) : ''; %>

<style>
  :root {
    --bg: #f5f7fb;
    --card: #ffffff;
    --muted: #6b7280;
    --accent-start: #6366f1;
    --accent-end: #8b5cf6;
    --border: #e5e7eb;
    --success: #10b981;
    --danger: #ef4444;
    --radius: 12px;
    --transition: 180ms ease;
  }

  /* Page */
  body {
    background: var(--bg);
    color: #111827;
  }

  .page-container {
    padding: 2rem 0;
    background: linear-gradient(180deg, var(--bg), #ffffff);
  }

  /* Card styling */
  .card, .panel-card {
    border-radius: var(--radius);
    background: var(--card);
    border: 1px solid var(--border);
    box-shadow: 0 6px 20px rgba(0,0,0,0.05);
    transition: box-shadow var(--transition);
  }

  .card:hover, .panel-card:hover {
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
  }

  /* Headings */
  h2.section-title, h5 {
    font-weight: 700;
    background: linear-gradient(90deg, var(--accent-start), var(--accent-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Inputs */
  .form-control {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 12px;
    height: 44px;
    transition: border var(--transition), box-shadow var(--transition);
  }

  .form-control:focus {
    border-color: var(--accent-start);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    outline: none;
  }

  /* Buttons */
  .btn-primary, .btn-accent {
    background: linear-gradient(90deg, var(--accent-start), var(--accent-end));
    border: none;
    color: #fff;
    font-weight: 600;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(99,102,241,0.3);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .btn-primary:hover, .btn-accent:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(99,102,241,0.35);
  }

  .btn-outline-muted {
    border: 1px solid var(--border);
    color: #111827;
    background: transparent;
    border-radius: 10px;
  }

  .btn-outline-muted:hover {
    background: #f9fafb;
  }

  .btn-outline-danger {
    border: 1px solid rgba(239,68,68,0.15);
    color: var(--danger);
    background: transparent;
  }

  .btn-outline-danger:hover {
    background: rgba(239,68,68,0.05);
  }

  /* Profile search dropdown */
  .input-group {
    position: relative;
  }

  #searchResults {
    position: absolute;
    top: calc(100% + 5px);
    left: 0;
    width: 100%;
    z-index: 1000;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    display: none;
    max-height: 300px;
    overflow-y: auto;
  }

  #searchResults::-webkit-scrollbar {
    width: 6px;
  }
  #searchResults::-webkit-scrollbar-thumb {
    background: rgba(156,163,175,0.4);
    border-radius: 4px;
  }

  .list-group-item {
    display: block;
    padding: 10px 14px;
    border: none;
    border-bottom: 1px solid rgba(229,231,235,0.7);
    background: transparent;
    cursor: pointer;
    transition: background var(--transition), transform var(--transition);
  }

  .list-group-item:last-child {
    border-bottom: none;
  }

  .list-group-item:hover {
    background: linear-gradient(90deg, rgba(99,102,241,0.08), rgba(139,92,246,0.06));
    transform: translateX(2px);
  }

  .list-group-item strong {
    display: block;
    font-size: 1rem;
    color: #111827;
  }

  .list-group-item small {
    display: block;
    color: var(--muted);
    font-size: 0.85rem;
  }

  /* Selected profile info */
  .selected-profile, #selectedProfileDisplay {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid rgba(16,185,129,0.2);
    background: rgba(16,185,129,0.05);
    border-radius: 10px;
    padding: 10px 14px;
  }

  .selected-profile strong {
    font-weight: 700;
  }

  /* Alerts */
  .alert {
    border-radius: 10px;
    border: none;
    box-shadow: 0 4px 18px rgba(0,0,0,0.05);
  }

  /* Responsive adjustments */
  @media (max-width: 576px) {
    .form-control { font-size: 0.95rem; }
    .btn { padding: 8px 12px; font-size: 0.95rem; }
  }
</style>


<div class="container page-container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h2 class="section-title mb-4">Create Review Link</h2>
      
      <form id="reviewLinkForm" method="POST" action="/reviews" class="needs-validation panel-card" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <input type="hidden" id="profileSlugField" name="profileSlug" value="">

        
        <div class="mb-4">
          <h5 class="mb-3">1. Select or Search Profile</h5>

          <div id="profileSearchSection" class="suggestions-container d-block">
            <label for="profile-search" class="form-label">Search Profile</label>
            <input id="profile-search" type="search" class="form-control" placeholder="Search profile by name, email or slug..." autocomplete="off">
            <div id="profile-suggestions" class="suggestions"></div>
          </div>
          
          <div id="profileDisplay" class="d-none">
  <div class="alert alert-info d-flex justify-content-between align-items-center">
    <div>
      <strong id="selectedProfileName"></strong><br>
      <small class="text-muted" id="selectedProfileDetails"></small>
    </div>
    <button type="button" class="btn btn-sm btn-outline-secondary" id="changeProfileBtn">
      Change Profile
    </button>
  </div>
</div>


        </div>

        <div class="mb-4">
          <h5 class="mb-3">2. Choose Link Destination</h5>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="linkType" id="linkTypeGoogle" value="google_review" checked>
            <label class="form-check-label" for="linkTypeGoogle">
              Google Review (Direct Link)
            </label>
          </div>
          <div id="googleUrlField" class="mt-2">
            <label for="googleReviewUrl" class="form-label">Google Review URL / Place ID</label>
            <input type="text" class="form-control" id="googleReviewUrl" name="googleReviewUrl" placeholder="https://g.page/your-place/review" required>
            <div class="form-text text-muted">Paste the direct Google review link or the Google Place ID.</div>
          </div>

          <div class="form-check mt-3">
            <input class="form-check-input" type="radio" name="linkType" id="linkTypeCustom" value="custom_form">
            <label class="form-check-label" for="linkTypeCustom">
              Custom Form (External URL)
            </label>
          </div>
          <div id="customUrlField" class="mt-2" style="display: none;">
            <label for="customFormUrl" class="form-label">External Form URL</label>
            <input type="url" class="form-control" id="customFormUrl" name="customFormUrl" placeholder="https://forms.gle/yourform">
            <div class="form-text text-muted">Direct customers to an external form (e.g., Google Forms).</div>
          </div>
        </div>
        
        <div class="mb-4">
          <h5 class="mb-3">3. Link Details</h5>
          <label for="reviewTitle" class="form-label">Review Title</label>
          <input type="text" class="form-control" id="reviewTitle" name="reviewTitle" placeholder="Share Your Experience">
          <div class="form-text text-muted">This is the public title on the review page.</div>
        </div>
        
        <div class="d-grid mt-4">
          <button type="submit" class="btn btn-primary" id="submitBtn">Create Review Link</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // ==========================================================
  // 1. PROFILE SELECTION LOGIC
  // ==========================================================
  ;(function() {
    const searchInput = document.getElementById('profile-search');
    const suggestionsContainer = document.getElementById('profile-suggestions');
    const profileSlugField = document.getElementById('profileSlugField');
    const profileSearchSection = document.getElementById('profileSearchSection');
    const profileDisplay = document.getElementById('profileDisplay');
    const selectedProfileName = document.getElementById('selectedProfileName');
    const selectedProfileDetails = document.getElementById('selectedProfileDetails');
    const changeProfileBtn = document.getElementById('changeProfileBtn');
    
    let timeout = null;

    function selectProfile(profile) {
      profileSlugField.value = profile.slug;
      
      // Update display
      selectedProfileName.textContent = profile.name;
      selectedProfileDetails.innerHTML = profile.category 
        ? profile.category + (profile.subcategory ? ' - ' + profile.subcategory : '')
        : '';

      profileSearchSection.classList.add('d-none');
      profileDisplay.classList.remove('d-none');
      
      // Clear input and suggestions
      searchInput.value = '';
      suggestionsContainer.innerHTML = '';
    }

    
    // Event listener for changing profile
    changeProfileBtn.addEventListener('click', () => {
        profileSlugField.value = '';
        profileDisplay.classList.add('d-none');
        profileSearchSection.classList.remove('d-none');
        searchInput.focus();
    });

    // Event listener for search input
    searchInput.addEventListener('input', () => {
      clearTimeout(timeout);
      const q = searchInput.value.trim();
      
      if (!q || q.length < 2) {
        suggestionsContainer.innerHTML = '';
        return;
      }

      timeout = setTimeout(async () => {
        try {
          // Use the correct mounted route for the search controller
          const res = await fetch('/reviews/search-profiles?q=' + encodeURIComponent(q));
          if (!res.ok) throw new Error('Failed to fetch profiles');
          
          const result = await res.json();
          const profiles = result.profiles || [];

          suggestionsContainer.innerHTML = '';
          
          if (profiles.length === 0) {
            suggestionsContainer.innerHTML = '<div class="suggestion-item text-muted">No profiles found.</div>';
            return;
          }

          profiles.forEach(p => {
            const div = document.createElement('div');
            div.className = 'suggestion-item';
            div.innerHTML = `<strong>${p.name}</strong> <small class="text-muted">(${p.slug})</small>`;
            div.dataset.slug = p.slug;
            
            div.addEventListener('click', () => selectProfile(p));
            
            suggestionsContainer.appendChild(div);
          });
        } catch (err) {
          console.error('Profile search error', err);
          suggestionsContainer.innerHTML = '<div class="suggestion-item text-danger">Error searching.</div>';
        }
      }, 300); // Debounce search
    });
  })();

  // ==========================================================
  // 2. LINK TYPE TOGGLE LOGIC
  // ==========================================================
  ;(function() {
    const googleRadio = document.getElementById('linkTypeGoogle');
    const customRadio = document.getElementById('linkTypeCustom');
    const googleField = document.getElementById('googleReviewUrl');
    const customField = document.getElementById('customFormUrl');
    const googleUrlField = document.getElementById('googleUrlField');
    const customUrlField = document.getElementById('customUrlField');

    function toggleFields() {
      if (googleRadio.checked) {
        googleUrlField.style.display = 'block';
        customUrlField.style.display = 'none';
        googleField.setAttribute('required', 'required');
        customField.removeAttribute('required');
      } else {
        googleUrlField.style.display = 'none';
        customUrlField.style.display = 'block';
        googleField.removeAttribute('required');
        customField.setAttribute('required', 'required');
      }
    }

    googleRadio.addEventListener('change', toggleFields);
    customRadio.addEventListener('change', toggleFields);

    // Initial run
    toggleFields();
  })();


  // ==========================================================
  // 3. AJAX SUBMISSION LOGIC
  // ==========================================================
  ;(function() {
    const form = document.getElementById('reviewLinkForm');
    const submitBtn = document.getElementById('submitBtn');

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Manual validation check for required fields
      if (!form.checkValidity()) {
        form.classList.add('was-validated');
        return;
      }
      
      const profileSlugField = document.getElementById('profileSlugField');
      if (!profileSlugField.value) {
        showAlert('danger', 'Please select a Profile before creating the link.');
        return;
      }

      submitBtn.disabled = true;
      const originalHtml = submitBtn.innerHTML;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Creating...';

      const formData = new FormData(form);
      const payload = {
        _csrf: formData.get('_csrf'),
        profileSlug: formData.get('profileSlug'),
        linkType: formData.get('linkType'),
        reviewTitle: formData.get('reviewTitle') || 'Share Your Experience',
        googleReviewUrl: formData.get('linkType') === 'google_review' ?
            formData.get('googleReviewUrl') : undefined,
        customFormUrl: formData.get('linkType') === 'custom_form' ?
            formData.get('customFormUrl') : undefined,
      };

      fetch(form.action, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(payload)
      })
      .then(function(res) {
        if (!res.ok) {
          // If response is not ok, parse the error and throw
          return res.json().then(function(err) {
            throw err;
          });
        }
        return res.json();
      })
      .then(function(result) {
        if (result && result.ok) {
          showAlert('success', 'Review link created successfully!');
          // redirect to reviews list for that profile using the slug returned from the controller
          setTimeout(function() {
            // Use payload.profileSlug for navigation
            window.location.href = '/dashboard/' + encodeURIComponent(payload.profileSlug) + '/reviews';
          }, 900);
        } else {
          // This catches errors where res.ok was true but the result structure was wrong
          throw new Error(result.error || 'Unexpected error');
        }
      })
      .catch(function(err) {
        console.error(err);
        var msg = (err && err.error) ? err.error : (err.message || 'Failed to create review link');
        showAlert('danger', msg);
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalHtml;
      });
    });
  })();


  function showAlert(type, message) {
    var wrapper = document.createElement('div');
    wrapper.className = 'alert alert-' + (type === 'success' ? 'success' : 'danger') + ' alert-dismissible fade show';
    wrapper.role = 'alert';
    wrapper.innerHTML = message + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
    
    var container = document.querySelector('.container.page-container');
    var existingAlert = container.querySelector('.alert');
    if (existingAlert) {
      existingAlert.remove();
    }
    
    // Insert new alert before the form
    var form = document.getElementById('reviewLinkForm');
    container.insertBefore(wrapper, form);
    wrapper.scrollIntoView({ behavior: 'smooth' });
  }
</script>
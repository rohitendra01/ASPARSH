<% layout('layouts/dashboard-boilerplate') %>

    <% block('styles').append('<link rel="stylesheet" href="/css/review/index.css">') %>

        <div class="dashboard-header-row">
            <form class="search-form" onsubmit="return filterReviews(event)">
                <input type="text" id="reviewSearch" name="reviewSearch" placeholder="Search Reviews" required>
                <button type="submit">Search</button>
            </form>
            <a href="/dashboard/<%= slug %>/reviews/new" class="create-review-btn create-review-btn-fixed">
                + Create New Link
            </a>
        </div>

        <% if (reviewLinks && reviewLinks.length> 0) { %>
            <div class="links-container">
                <% reviewLinks.forEach(link=> { %>
                    <div class="link-card">
                        <div class="link-info">
                            <h3>
                                <% if (!link.isActive) { %>
                                    <span title="Inactive" style="color: #a0aec0;">[PAUSED]</span>
                                    <% } %>
                                        <%= link.reviewTitle %>
                            </h3>

                            <div class="link-url">
                                <b>
                                    <%= link.businessCategory %>
                                </b> / <%= link.slug %>
                            </div>

                            <div class="link-stats-grid">
                                <div class="stat-item">
                                    👁️ <span>
                                        <%= link.viewCount %>
                                    </span> views
                                </div>
                                <div class="stat-item">
                                    ✨ <span>
                                        <%= link.generationCount %>
                                    </span> gens
                                </div>
                                <div class="stat-item">
                                    📤 <span>
                                        <%= link.submissionCount %>
                                    </span> posts
                                </div>
                                <div class="stat-item">
                                    <span class="badge <%= link.isActive ? 'badge-active' : 'badge-inactive' %>">
                                        <%= link.isActive ? 'Active' : 'Inactive' %>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="link-actions">
                            <a href="/reviews/<%= link.slug %>" class="action-btn btn-visit" target="_blank"
                                title="Visit public page">
                                Visit
                            </a>

                            <button class="action-btn btn-copy"
                                onclick="copyToClipboard('/reviews/<%= link.slug %>', this)" title="Copy link">
                                Copy
                            </button>

                            <a href="/dashboard/<%= link.profileSlug %>/reviews/<%= link._id %>/edit"
                                class="action-btn btn-edit" title="Edit link">
                                Edit
                            </a>

                            <form method="POST"
                                action="/dashboard/<%= link.profileSlug %>/reviews/<%= link._id %>/delete"
                                style="display: inline;">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="action-btn btn-delete"
                                    onclick="return confirm('Delete this review link?')" title="Delete">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-state-icon">🔗</div>
                    <h3>No review links created yet.</h3>
                    <a href="/dashboard/<%= slug %>/reviews/new" class="action-btn btn-visit mt-3">
                        ➕ Create Your Link
                    </a>
                </div>
                <% } %>

                    <script>
                        function filterReviews(event) {
                            event.preventDefault();
                            const input = document.getElementById('reviewSearch').value.trim().toLowerCase();
                            const cards = document.querySelectorAll('.link-card');

                            if (!input) {
                                cards.forEach(card => card.style.display = '');
                                return false;
                            }

                            cards.forEach(card => {
                                const title = card.querySelector('h3') ? card.querySelector('h3').textContent.toLowerCase() : '';
                                const slug = card.querySelector('.link-url') ? card.querySelector('.link-url').textContent.toLowerCase() : '';

                                if (title.includes(input) || slug.includes(input)) {
                                    card.style.display = '';
                                } else {
                                    card.style.display = 'none';
                                }
                            });
                            return false;
                        }

                        function copyToClipboard(text, button) {
                            const fullUrl = window.location.origin + text;
                            navigator.clipboard.writeText(fullUrl).then(() => {
                                const originalText = button.innerHTML;
                                button.innerHTML = '✅ Copied!';
                                button.disabled = true;
                                setTimeout(() => {
                                    button.innerHTML = originalText;
                                    button.disabled = false;
                                }, 2000);
                            }).catch(err => {
                                console.error('Copy failed:', err);
                                alert('Failed to copy');
                            });
                        }
                    </script>
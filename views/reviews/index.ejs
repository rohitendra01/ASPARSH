<% layout('layouts/dashboard-boilerplate') -%>
    <% block('styles').append('<link rel="stylesheet" href="/css/review/index.css" />') %>

    <% 
        // Safely extract locals to prevent parsing errors 
        const list = locals.reviewLinks || []; 
        const safeUserSlug = locals.slug || (locals.user && locals.user.slug) || ''; 
        const safeSlugSegment = safeUserSlug ? '/' + encodeURIComponent(safeUserSlug) : ''; 
        const csrf = locals.csrfToken || ''; 
    %>

        <div class="page-container">

            <div class="page-header-row">
                <div class="page-header-text">
                    <h1 class="page-title">Google Reviews</h1>
                    <p class="page-subtitle">Manage AI-powered review generation links for your businesses.</p>
                </div>

                <div class="page-header-actions">
                    <div class="search-wrapper">
                        <input type="text" id="liveSearchInput" placeholder="Search by title, category, or slug..."
                            onkeyup="filterReviewLinks()">
                    </div>
                    <a href="/dashboard<%= safeSlugSegment %>/reviews/new" class="btn-primary">+ Create New Link</a>
                </div>
            </div>

            <% if (list.length> 0) { %>
                <div class="quick-stats-row">
                    <div class="stat-card">
                        <span class="stat-value">
                            <%= list.length %>
                        </span>
                        <span class="stat-label">Active Links</span>
                    </div>
                </div>
                <% } %>

                    <div class="entity-list-container">
                        <% if (list.length> 0) { %>
                            <div class="compact-grid" id="entityGrid">

                                <% 
                                    list.forEach(function(link) { 
                                    // Safe Variables 
                                    const cTitle = link.reviewTitle || 'Untitled Link'; 
                                    const cCategory = link.businessCategory || 'Business'; 
                                    const cSlug = link.slug || ''; 
                                    const cViews = link.viewCount || 0; 
                                    const cGens = link.generationCount || 0; 
                                    const cPosts = link.submissionCount || 0; 
                                    const isActive = link.isActive; 
                                    const pSlug = link.profileSlug || safeUserSlug; 
                                    const cPublicUrl = '/reviews/' + cSlug; 
                                    const cEditTarget = '/dashboard/' + encodeURIComponent(pSlug) + '/reviews/' + link._id + '/edit'; 
                                    const cDeleteTarget = '/dashboard/' + encodeURIComponent(pSlug) + '/reviews/' + link._id + '/delete'; 
                                    const cSearchTerm = (cTitle + ' ' + cCategory + ' ' + cSlug).toLowerCase(); 
                                %>

                                    <div class="compact-card entity-card" data-search-term="<%= cSearchTerm %>">

                                        <div class="card-thumbnail">
                                            <div class="thumbnail-placeholder" style="color: #f59e0b;">
                                                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"
                                                    stroke="none">
                                                    <polygon
                                                        points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2">
                                                    </polygon>
                                                </svg>
                                            </div>
                                        </div>

                                        <div class="card-info">
                                            <div class="info-header">
                                                <h3 class="card-title text-truncate" title="<%= cTitle %>">
                                                    <% if (!isActive) { %>
                                                        <span
                                                            style="color: #ef4444; font-size: 0.85rem; margin-right: 4px;">[PAUSED]</span>
                                                        <% } %>
                                                            <%= cTitle %>
                                                </h3>
                                                <span class="badge">
                                                    <%= cCategory %>
                                                </span>
                                            </div>

                                            <div class="link-url-display text-truncate" title="<%= cSlug %>">
                                                /<%= cSlug %>
                                            </div>

                                            <div class="info-meta-grid stats-grid">
                                                <span class="meta-item" title="Page Views">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                        <circle cx="12" cy="12" r="3"></circle>
                                                    </svg>
                                                    <strong>
                                                        <%= cViews %>
                                                    </strong> views
                                                </span>

                                                <span class="meta-item" title="AI Generations">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round">
                                                        <path
                                                            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
                                                        </path>
                                                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                                                        <line x1="12" y1="22.08" x2="12" y2="12"></line>
                                                    </svg>
                                                    <strong>
                                                        <%= cGens %>
                                                    </strong> gens
                                                </span>

                                                <span class="meta-item" title="Successful Posts">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round">
                                                        <path d="M22 2L11 13"></path>
                                                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                                                    </svg>
                                                    <strong>
                                                        <%= cPosts %>
                                                    </strong> posts
                                                </span>
                                            </div>
                                        </div>

                                        <div class="card-actions">
                                            <a href="<%= cPublicUrl %>" target="_blank" class="action-icon-btn info-btn"
                                                title="Visit Public Page">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                    stroke-linejoin="round">
                                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6">
                                                    </path>
                                                    <polyline points="15 3 21 3 21 9"></polyline>
                                                    <line x1="10" y1="14" x2="21" y2="3"></line>
                                                </svg>
                                            </a>

                                            <button type="button" class="action-icon-btn copy-btn"
                                                onclick="copyToClipboard('<%= cPublicUrl %>', this)" title="Copy Link">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                    stroke-linejoin="round">
                                                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1">
                                                    </path>
                                                </svg>
                                            </button>

                                            <a href="<%= cEditTarget %>" class="action-icon-btn edit-btn"
                                                title="Edit Link">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                    stroke-linejoin="round">
                                                    <path
                                                        d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7">
                                                    </path>
                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z">
                                                    </path>
                                                </svg>
                                            </a>

                                            <form method="POST" action="<%= cDeleteTarget %>"
                                                style="margin: 0; padding: 0;">
                                                <input type="hidden" name="_csrf" value="<%= csrf %>">
                                                <button type="submit" class="action-icon-btn delete-btn"
                                                    onclick="return confirm('Are you sure you want to delete this review link?')"
                                                    title="Delete Link">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round">
                                                        <polyline points="3 6 5 6 21 6"></polyline>
                                                        <path
                                                            d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2">
                                                        </path>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>

                                    </div>
                                    <% }); %>

                            </div>

                            <% } else { %>

                                <div class="empty-state">
                                    <div class="empty-icon">⭐</div>
                                    <h2>No review links found</h2>
                                    <p>Create AI-powered Google Review links to make it effortless for your customers to
                                        leave 5-star feedback.</p>
                                    <a href="/dashboard<%= safeSlugSegment %>/reviews/new" class="btn-primary">+ Create
                                        Your First Link</a>
                                </div>

                                <% } %>
                    </div>
        </div>

        <script>
            function filterReviewLinks() {
                var input = document.getElementById('liveSearchInput').value.trim().toLowerCase();
                var cards = document.querySelectorAll('.entity-card');

                for (var i = 0; i < cards.length; i++) {
                    var card = cards[i];
                    var searchTerm = card.getAttribute('data-search-term') || '';
                    if (searchTerm.includes(input)) {
                        card.style.display = 'flex';
                    } else {
                        card.style.display = 'none';
                    }
                }
            }

            function copyToClipboard(text, button) {
                var fullUrl = window.location.origin + text;
                var originalHTML = button.innerHTML;

                navigator.clipboard.writeText(fullUrl).then(function () {
                    // Temporarily swap icon to a checkmark
                    button.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                    button.style.borderColor = '#10b981';

                    setTimeout(function () {
                        button.innerHTML = originalHTML;
                        button.style.borderColor = 'transparent';
                    }, 2000);
                }).catch(function (err) {
                    console.error('Copy failed:', err);
                    alert('Failed to copy link to clipboard.');
                });
            }
        </script>
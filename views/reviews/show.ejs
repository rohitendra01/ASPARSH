<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Review - <%= business.name %></title>
    
    <style>
        :root {
            --bg: #f5f7fb;
            --card: #ffffff;
            --muted: #6b7280;
            --text-dark: #1a202c;
            --accent-start: #6366f1;
            --accent-end: #8b5cf6;
            --border: #e5e7eb;
            --success: #10b981;
            --radius: 16px;
            --transition: 180ms ease;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: var(--bg);
            color: var(--text-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
            box-sizing: border-box;
            margin: 0;
        }

        .container {
            width: 100%;
            max-width: 500px;
            background: var(--card);
            border-radius: var(--radius);
            box-shadow: 0 10px 30px rgba(0,0,0,0.07);
            padding: 30px 35px;
            text-align: center;
        }

        h1 {
            font-size: 24px;
            font-weight: 700;
            margin: 0 0 8px;
        }

        .subtitle {
            font-size: 16px;
            color: var(--muted);
            margin: 0 0 15px;
        }

        .category-badge {
            display: inline-block;
            background: linear-gradient(90deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1));
            color: var(--accent-start);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 25px;
        }

        .review-box {
            background: #f9faff;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 25px;
            min-height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: left;
            color: #2d3748;
            font-size: 16px;
            line-height: 1.6;
            font-weight: 500;
            margin-bottom: 25px;
            transition: all 0.2s;
            
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            width: 100%;
            box-sizing: border-box; 
            resize: vertical;
        }
        .review-box:focus {
            outline: none;
            border-color: var(--accent-start);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
        }
        .review-box::placeholder {
            color: var(--muted);
            font-weight: 500;
        }

        .spinner {
            width: 24px;
            height: 24px;
            border: 3px solid rgba(99,102,241,0.2);
            border-top-color: var(--accent-start);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .button-group {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .btn-base {
            padding: 12px 20px;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition);
            width: 100%;
        }
        .btn-base:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn-regenerate {
            background: #f0f2f5;
            color: #4a5568;
            border: 1px solid var(--border);
        }
        .btn-regenerate:hover:not(:disabled) {
            background: #e9ecf0;
        }
        

        .btn-submit {
            background: linear-gradient(90deg, var(--accent-start), var(--accent-end));
            color: #fff;
            box-shadow: 0 4px 15px rgba(99,102,241,0.3);
        }
        .btn-submit:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 8px 22px rgba(99,102,241,0.35);
        }
        .btn-submit.copied {
            background: var(--success);
            box-shadow: 0 4px 15px rgba(16,185,129,0.3);
        }
        
        .notification {
            position: fixed;
            bottom: -100px;
            left: 50%;
            transform: translateX(-50%);
            padding: 12px 20px;
            border-radius: 10px;
            background: #323232;
            color: white;
            font-weight: 500;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            z-index: 100;
        }
        .notification.show {
            bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📝 <%= link.title %></h1>
        <p class="subtitle">Review for <%= business.name %></p>
        <p class="category-badge">
            📂 <%= business.category %> 
            <% if (business.city) { %>
                • 📍 <%= business.city %>
            <% } %>
        </p>

        <textarea id="reviewBox" class="review-box" placeholder="Generating review..." disabled></textarea>
        
        <div class="button-group">
            <button id="regenerateBtn" class="btn-base btn-regenerate" onclick="generateReview()">
                🔄 Refresh Review
            </button>
            
           
            
            <button id="submitBtn" class="btn-base btn-submit" onclick="copyAndPostReview()" disabled>
                ⭐ Copy & Post Review
            </button>
        </div>
    </div>
    
    <div id="notification" class="notification"></div>
    
<script>
    const LINK_SLUG = '<%= link.slug %>';
    const TARGET_URL = '<%= link.targetUrl %>';
    
    const reviewBox = document.getElementById('reviewBox');
    const regenerateBtn = document.getElementById('regenerateBtn');
    const submitBtn = document.getElementById('submitBtn');

    async function generateReview() {
        reviewBox.value = '';
        reviewBox.placeholder = 'Generating review...';
        reviewBox.disabled = true;
        
        regenerateBtn.disabled = true;
        submitBtn.disabled = true;

        try {
            const response = await fetch(`/reviews/${LINK_SLUG}/api/generate`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json();

            if (data.success && data.reviewText) {
                reviewBox.value = data.reviewText;
                reviewBox.disabled = false;
                
                submitBtn.disabled = false;
            } else {
                throw new Error(data.error || 'Generation failed');
            }
        } catch (error) {
            console.error('Error:', error);
            reviewBox.value = 'Error generating review. Please try again.';
            showNotification('Error: ' + error.message, 'error');
        } finally {
            regenerateBtn.disabled = false;
        }
    }

    function copyAndPostReview() {
        const currentReviewText = reviewBox.value;

        if (!currentReviewText) {
            showNotification('Please generate a review first!', 'error');
            return;
        }

        if (!TARGET_URL) {
            showNotification('Destination not configured', 'error');
            return;
        }

        navigator.clipboard.writeText(currentReviewText).then(() => {
            
            const originalText = submitBtn.textContent;
            submitBtn.textContent = '✅ Copied!';
            submitBtn.classList.add('copied');
            
            showNotification('Review copied! Redirecting...', 'success');

            fetch(`/reviews/<%= link.slug %>/api/submit`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ slug: LINK_SLUG, reviewText: currentReviewText })
            }).catch(err => console.error('Tracking error:', err));
            
            setTimeout(() => {
                window.open(TARGET_URL, '_blank');
                
                submitBtn.textContent = originalText;
                submitBtn.classList.remove('copied');
            }, 1500);

        }).catch(err => {
            console.error('Copy failed:', err);
            showNotification('Failed to copy text', 'error');
        });
    }
    
    function showNotification(message, type) {
        const notification = document.getElementById('notification');
        notification.textContent = message;
        if (type === 'error') {
            notification.style.background = '#f56565';
        } else {
            notification.style.background = '#323232'; 
        }
        
        notification.classList.add('show');
        setTimeout(() => {
            notification.classList.remove('show');
        }, 3000);
    }
    
    window.addEventListener('load', generateReview);
</script>
</body>
</html>
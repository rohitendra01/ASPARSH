<% layout('layouts/dashboard-boilerplate') -%>
  <% block('styles').append('<link rel="stylesheet" href="/css/profiles/edit.css">') %>

    <% const slugSegment=(typeof slug !=='undefined' && slug) ? '/' + encodeURIComponent(slug) : '' ; %>

      <div class="page-header">
        <h1 class="page-title">Edit Profile</h1>
        <p class="page-subtitle">Update your business identity or personal portfolio details.</p>
      </div>

      <div class="profile-form-container">
        <form id="editProfileForm" class="profile-form" method="POST"
          action="/dashboard<%= slugSegment %>/profiles/<%= encodeURIComponent(profile.slug) %>/edit"
          enctype="multipart/form-data" onsubmit="reindexSocialLinks()">

          <div class="form-section">
            <h3 class="section-title">Basic Information</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="name">Full Name <span class="text-danger">*</span></label>
                <input type="text" id="name" name="name" required value="<%= profile.name %>" class="form-control" />
              </div>
              <div class="form-group">
                <label for="email">Email Address <span class="text-danger">*</span></label>
                <input type="email" id="email" name="email" required value="<%= profile.email %>"
                  class="form-control" />
              </div>
              <div class="form-group">
                <label for="mobile">Mobile Number <span class="text-danger">*</span></label>
                <input type="text" id="mobile" name="mobile" required value="<%= profile.mobile %>"
                  class="form-control" />
              </div>
              <div class="form-group">
                <label for="image">Profile Image</label>
                <% if (profile.image) { %>
                  <div class="current-image-preview">
                    <img src="<%= profile.image %>" alt="Current Image" class="profile-image-thumbnail" />
                    <div class="delete-image-check">
                      <input type="checkbox" id="deleteImage" name="deleteImage" value="true" />
                      <label for="deleteImage">Delete current image</label>
                    </div>
                  </div>
                  <% } %>
                    <input type="file" id="image" name="image" accept="image/*" class="form-control file-input" />
              </div>
            </div>
          </div>

          <hr class="divider">

          <div class="form-section">
            <h3 class="section-title">Professional Details</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="occupation">Occupation</label>
                <input type="text" id="occupation" name="occupation" value="<%= profile.occupation || '' %>"
                  class="form-control" />
              </div>
              <div class="form-group">
                <label for="experience">Experience (years)</label>
                <input type="number" id="experience" name="experience" min="0" step="1"
                  value="<%= profile.experience || 0 %>" class="form-control" />
              </div>
              <div class="form-group">
                <label for="categorySelect">Category</label>
                <input type="text" id="categorySearch" placeholder="Search or type category" class="form-control mb-2"
                  autocomplete="off" />
                <select id="categorySelect" name="category" class="form-control">
                  <option value="">-- choose category --</option>
                </select>
              </div>
              <div class="form-group">
                <label for="subcategorySelect">Subcategory</label>
                <select id="subcategorySelect" name="subcategory" class="form-control" style="margin-top: 3.2rem;">
                  <option value="">-- choose subcategory --</option>
                </select>
              </div>
            </div>
          </div>

          <hr class="divider">

          <div class="form-section">
            <h3 class="section-title">Location</h3>
            <div class="form-group">
              <label for="addressLine">Street Address</label>
              <input type="text" id="addressLine" name="addressLine"
                value="<%= profile.address && profile.address.addressLine %>" class="form-control" />
            </div>
            <div class="form-grid">
              <div class="form-group">
                <label for="city">City</label>
                <input type="text" id="city" name="city" value="<%= profile.address && profile.address.city %>"
                  class="form-control" />
              </div>
              <div class="form-group">
                <label for="state">State</label>
                <input type="text" id="state" name="state" value="<%= profile.address && profile.address.state %>"
                  class="form-control" />
              </div>
              <div class="form-group">
                <label for="country">Country</label>
                <input type="text" id="country" name="country" value="<%= profile.address && profile.address.country %>"
                  class="form-control" />
              </div>
              <div class="form-group">
                <label for="postcode">Postcode</label>
                <input type="text" id="postcode" name="postcode"
                  value="<%= profile.address && profile.address.postcode %>" class="form-control" />
              </div>
            </div>
          </div>

          <hr class="divider">

          <div class="form-section" id="social-links-section">
            <div class="section-header-flex">
              <h3 class="section-title mb-0">Social Links</h3>
              <button id="add-social-link-btn" type="button" class="btn btn-outline-primary btn-sm">+ Add Link</button>
            </div>
            <div id="social-links-list">
              <% if (profile.socialLinks && profile.socialLinks.length) { %>
                <% profile.socialLinks.forEach(function(link, i) { %>
                  <div class="form-row social-row">
                    <div class="form-group flex-1">
                      <input type="text" name="socialLinks[<%= i %>][platform]" class="form-control"
                        value="<%= link.platform %>" placeholder="Platform" required />
                    </div>
                    <div class="form-group flex-2">
                      <input type="text" name="socialLinks[<%= i %>][url]" class="form-control" value="<%= link.url %>"
                        placeholder="https://…" required />
                    </div>
                    <button type="button" class="remove-social-link-btn btn-icon text-danger">×</button>
                  </div>
                  <% }) %>
                    <% } else { %>
                      <div class="form-row social-row">
                        <div class="form-group flex-1">
                          <input type="text" name="socialLinks[0][platform]" class="form-control" placeholder="Platform"
                            required />
                        </div>
                        <div class="form-group flex-2">
                          <input type="text" name="socialLinks[0][url]" class="form-control" placeholder="https://…"
                            required />
                        </div>
                        <button type="button" class="remove-social-link-btn btn-icon text-danger">×</button>
                      </div>
                      <% } %>
            </div>
          </div>
        </form>
        <div class="form-actions-wrapper">
          <form action="/dashboard<%= slugSegment %>/profiles/<%= encodeURIComponent(profile.slug) %>/delete"
            method="POST" class="delete-form">
            <button type="submit" class="btn btn-outline-danger"
              onclick="return confirm('Are you sure you want to delete this profile? This cannot be undone.');">Delete
              Profile</button>
          </form>

          <div class="primary-actions">
            <a href="/dashboard<%= slugSegment %>/profiles" class="btn btn-secondary">Cancel</a>
            <button type="submit" form="editProfileForm" class="btn btn-primary">Update Profile</button>
          </div>
        </div>
      </div>

      <script>
        // Social Links dynamic add/remove/reindex
        document.addEventListener('DOMContentLoaded', function () {
          const addBtn = document.getElementById('add-social-link-btn');
          const linksList = document.getElementById('social-links-list');

          addBtn.addEventListener('click', function () {
            const index = linksList.querySelectorAll('.social-row').length;
            const row = document.createElement('div');
            row.className = 'form-row social-row';
            row.innerHTML = `
        <div class="form-group flex-1">
          <input type="text" name="socialLinks[${index}][platform]" class="form-control" placeholder="Platform" required />
        </div>
        <div class="form-group flex-2">
          <input type="text" name="socialLinks[${index}][url]" class="form-control" placeholder="https://…" required />
        </div>
        <button type="button" class="remove-social-link-btn btn-icon text-danger">×</button>
      `;
            linksList.appendChild(row);
          });

          linksList.addEventListener('click', function (e) {
            if (e.target.matches('.remove-social-link-btn') || e.target.closest('.remove-social-link-btn')) {
              e.target.closest('.social-row').remove();
              reindexSocialLinks();
            }
          });
        });

        function reindexSocialLinks() {
          const rows = document.querySelectorAll('#social-links-list .social-row');
          rows.forEach(function (row, i) {
            const platformInput = row.querySelector('input[name^="socialLinks"][name$="[platform]"]');
            const urlInput = row.querySelector('input[name^="socialLinks"][name$="[url]"]');
            if (platformInput) platformInput.name = `socialLinks[${i}][platform]`;
            if (urlInput) urlInput.name = `socialLinks[${i}][url]`;
          });
        }
      </script>


        (function initCategoryUI() {
          document.addEventListener('DOMContentLoaded', function () {
            const CATEGORY_DATA_LOCAL = CATEGORY_DATA;
            const catSelect = document.getElementById('categorySelect');
            const catSearch = document.getElementById('categorySearch');
            const subSelect = document.getElementById('subcategorySelect');
            const existingCategory = `<%= (profile.category || '') %>`;
            const existingSub = `<%= (profile.subcategory || '') %>`;

            if (!catSelect || !catSearch || !subSelect) return;

            let datalist = document.getElementById('categoryDatalist');
            if (!datalist) {
              datalist = document.createElement('datalist');
              datalist.id = 'categoryDatalist';
              document.body.appendChild(datalist);
              catSearch.setAttribute('list', 'categoryDatalist');
            }

            function populateCategories(filter) {
              const keys = Object.keys(CATEGORY_DATA_LOCAL).filter(k => !filter || k.toLowerCase().includes(filter.toLowerCase()));
              catSelect.innerHTML = '<option value="">-- choose category --</option>' + keys.map(k => `<option value="${k}">${k}</option>`).join('');
              datalist.innerHTML = keys.map(k => `<option value="${k}"></option>`).join('');
              if (existingCategory && !filter) catSelect.value = existingCategory;
            }

            function populateSubcategories(category) {
              const items = CATEGORY_DATA_LOCAL[category] || [];
              subSelect.innerHTML = '<option value="">-- choose subcategory --</option>' + items.map(s => `<option value="${s}">${s}</option>`).join('');
              if (existingSub && category === existingCategory) subSelect.value = existingSub;
            }

            catSearch.addEventListener('input', (e) => { populateCategories(e.target.value); });
            catSearch.addEventListener('change', (e) => {
              const val = e.target.value;
              if (CATEGORY_DATA_LOCAL[val]) {
                catSelect.value = val;
                populateSubcategories(val);
              }
            });
            catSelect.addEventListener('change', (e) => { populateSubcategories(e.target.value); catSearch.value = e.target.value; });

            populateCategories();
            if (existingCategory) {
              catSearch.value = existingCategory;
              populateSubcategories(existingCategory);
            }
          });
        })();
        document.addEventListener('DOMContentLoaded', () => {
          const imageInput = document.getElementById('image');

          if (imageInput) {
            imageInput.addEventListener('change', async function (e) {
              const file = e.target.files[0];
              if (!file) return;

              const maxSizeInBytes = 9 * 1024 * 1024; // 9MB

              if (file.size > maxSizeInBytes) {
                // Provide visual feedback securely finding the correct label
                const label = this.closest('.form-group') ? this.closest('.form-group').querySelector('label[for="image"]') : null;
                const originalLabel = label ? label.innerText : '';
                if (label) label.innerText = 'Compressing image, please wait... ⏳';

                try {
                  const compressedFile = await compressImage(file);

                  // Replace the heavy file in the input with the compressed file
                  const dataTransfer = new DataTransfer();
                  dataTransfer.items.add(compressedFile);
                  e.target.files = dataTransfer.files;

                  if (label) label.innerText = 'Image successfully compressed! ✅';
                  setTimeout(() => {
                    if (label) label.innerText = originalLabel || 'Profile Image';
                  }, 3000);

                } catch (err) {
                  console.error('Client-side compression failed:', err);
                  alert('The image is too large and failed to compress. Please choose a smaller file.');
                  e.target.value = ''; // Clear the input
                  if (label) label.innerText = originalLabel || 'Profile Image';
                }
              }
            });
          }

          // Canvas-based compression function
          function compressImage(file) {
            return new Promise((resolve, reject) => {
              const reader = new FileReader();
              reader.readAsDataURL(file);
              reader.onload = event => {
                const img = new Image();
                img.src = event.target.result;
                img.onload = () => {
                  const canvas = document.createElement('canvas');
                  const ctx = canvas.getContext('2d');

                  // Scale down if dimensions are massive (max 1920px)
                  const MAX_WIDTH = 1920;
                  const MAX_HEIGHT = 1920;
                  let width = img.width;
                  let height = img.height;

                  if (width > height) {
                    if (width > MAX_WIDTH) {
                      height *= MAX_WIDTH / width;
                      width = MAX_WIDTH;
                    }
                  } else {
                    if (height > MAX_HEIGHT) {
                      width *= MAX_HEIGHT / height;
                      height = MAX_HEIGHT;
                    }
                  }

                  canvas.width = width;
                  canvas.height = height;
                  ctx.drawImage(img, 0, 0, width, height);

                  // Output as JPEG at 75% quality
                  canvas.toBlob((blob) => {
                    if (!blob) return reject(new Error('Canvas is empty'));
                    // Create a new File object to pass back to the form
                    let newFileName = file.name.replace(/\.[^/.]+$/, "") + "_compressed.jpg";
                    const newFile = new File([blob], newFileName, {
                      type: 'image/jpeg',
                      lastModified: Date.now()
                    });
                    resolve(newFile);
                  }, 'image/jpeg', 0.75);
                };
                img.onerror = error => reject(error);
              };
              reader.onerror = error => reject(error);
            });
          }
        });
      </script>
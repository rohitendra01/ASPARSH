<% layout('layouts/dashboard-boilerplate') -%>
<% block('styles').append('<link rel="stylesheet" href="/css/profiles/edit.css">') %>
<div class="profile-form-container">
<form class="profile-form"
      method="POST"
  <% const slugSegment = (typeof slug !== 'undefined' && slug) ? '/' + encodeURIComponent(slug) : ''; %>
  action="/dashboard<%= slugSegment %>/profiles/<%= encodeURIComponent(profile.slug) %>/edit"
      enctype="multipart/form-data"
      onsubmit="reindexSocialLinks()">
    <h2 class="form-title">Edit Profile</h2>
    <div class="form-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required value="<%= profile.name %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required value="<%= profile.email %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="mobile">Mobile</label>
      <input type="text" id="mobile" name="mobile" required value="<%= profile.mobile %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="occupation">Occupation</label>
      <input type="text" id="occupation" name="occupation" value="<%= profile.occupation || '' %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="categorySelect">Category</label>
      <input type="text" id="categorySearch" placeholder="Search or type category" class="form-control" autocomplete="off" />
      <select id="categorySelect" name="category" class="form-control" style="margin-top:.5rem;">
        <option value="">-- choose category --</option>
      </select>
    </div>
    <div class="form-group">
      <label for="subcategorySelect">Subcategory</label>
      <select id="subcategorySelect" name="subcategory" class="form-control">
        <option value="">-- choose subcategory --</option>
      </select>
    </div>
    <div class="form-group">
      <label for="experience">Experience (years)</label>
      <input type="number" id="experience" name="experience" min="0" step="1" value="<%= profile.experience || 0 %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="image">Profile Image</label>
      <% if (profile.image) { %>
        <img src="<%= profile.image %>" alt="Current Image" class="profile-image-preview" />
        <div>
          <input type="checkbox" id="deleteImage" name="deleteImage" value="true" />
          <label for="deleteImage">Delete current image</label>
        </div>
      <% } %>
      <input type="file" id="image" name="image" accept="image/*" class="form-control" />
    </div>
    <div class="form-group">
      <label for="addressLine">Address</label>
      <input type="text" id="addressLine" name="addressLine" value="<%= profile.address && profile.address.addressLine %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="city">City</label>
      <input type="text" id="city" name="city" value="<%= profile.address && profile.address.city %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="state">State</label>
      <input type="text" id="state" name="state" value="<%= profile.address && profile.address.state %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="country">Country</label>
      <input type="text" id="country" name="country" value="<%= profile.address && profile.address.country %>" class="form-control" />
    </div>
    <div class="form-group">
      <label for="postcode">Postcode</label>
      <input type="text" id="postcode" name="postcode" value="<%= profile.address && profile.address.postcode %>" class="form-control" />
    </div>
    <div id="social-links-section" class="form-group">
      <label>Social Links</label>
      <div id="social-links-list">
        <% if (profile.socialLinks && profile.socialLinks.length) { %>
          <% profile.socialLinks.forEach(function(link, i) { %>
            <div class="form-row">
              <div class="form-group">
                <input type="text" name="socialLinks[<%= i %>][platform]" class="form-control" value="<%= link.platform %>" placeholder="Platform (e.g. Facebook)" required />
              </div>
              <div class="form-group form-group-inline">
                <input type="text" name="socialLinks[<%= i %>][url]" class="form-control" value="<%= link.url %>" placeholder="https://…" required />
              </div>
              <button type="button" class="remove-social-link-btn btn btn-link text-danger">×</button>
            </div>
          <% }) %>
        <% } else { %>
          <div class="form-row">
            <div class="form-group">
              <input type="text" name="socialLinks[0][platform]" class="form-control" placeholder="Platform (e.g. Facebook)" required />
            </div>
            <div class="form-group form-group-inline">
              <input type="text" name="socialLinks[0][url]" class="form-control" placeholder="https://…" required />
            </div>
            <button type="button" class="remove-social-link-btn btn btn-link text-danger">×</button>
          </div>
        <% } %>
      </div>
      <button id="add-social-link-btn" type="button" class="btn btn-secondary">+ Add Social Link</button>
    </div>
    <button type="submit" class="btn btn-primary">Update Profile</button>
</form>
<form action="/dashboard<%= slugSegment %>/profiles/<%= encodeURIComponent(profile.slug) %>/delete" method="POST" style="display:inline;">
  <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this profile?');">Delete Profile</button>
</form>
</div>
<script>
// Social Links dynamic add/remove/reindex
document.addEventListener('DOMContentLoaded', function() {
  const addBtn = document.getElementById('add-social-link-btn');
  const linksList = document.getElementById('social-links-list');

  addBtn.addEventListener('click', function() {
    const index = linksList.querySelectorAll('.form-row').length;
    const row = document.createElement('div');
    row.className = 'form-row';
    row.innerHTML = `
      <div class="form-group">
        <input type="text" name="socialLinks[${index}][platform]" class="form-control" placeholder="Platform (e.g. Facebook)" required />
      </div>
      <div class="form-group form-group-inline">
        <input type="text" name="socialLinks[${index}][url]" class="form-control" placeholder="https://…" required />
      </div>
      <button type="button" class="remove-social-link-btn btn btn-link text-danger">×</button>
    `;
    linksList.appendChild(row);
  });

  linksList.addEventListener('click', function(e) {
    if (e.target.classList.contains('remove-social-link-btn')) {
      e.target.closest('.form-row').remove();
      reindexSocialLinks();
    }
  });
});

function reindexSocialLinks() {
  const rows = document.querySelectorAll('#social-links-list .form-row');
  rows.forEach(function(row, i) {
    const platformInput = row.querySelector('input[name^="socialLinks"][name$="[platform]"]');
    const urlInput = row.querySelector('input[name^="socialLinks"][name$="[url]"]');
    if (platformInput) platformInput.name = `socialLinks[${i}][platform]`;
    if (urlInput) urlInput.name = `socialLinks[${i}][url]`;
  });
}
</script>

<% layout('layouts/dashboard-boilerplate') -%>
<% block('styles').append('<link rel="stylesheet" href="/css/profiles/show.css">') %>
<div class="profile-details-container">
    <div class="profile-general-details-panel">
        <div class="profile-details">
            <div class="profile-details-header">
                <h2>Customer Profile</h2>
                <div class="created-at">Joined <%= profile.createdAt.toLocaleDateString() %></div>
            </div>
            <div class="profile-details-main">
                <div class="profile-image-wrapper">
                    <img src="<%= profile.image || '/assets/user-login.png' %>" alt="<%= profile.name %>" class="profile-image" />
                </div>
                <div class="profile-info">
                    <h3 class="profile-name"><%= profile.name %></h3>
                    <p class="profile-mobile"><%= profile.mobile || 'N/A' %></p>
                </div>
            </div>
        </div>
        <div class="profile-details">
            <div class="profile-details-header">
                <h2>Contact Information</h2>
            </div>
            <div class="profile-details-main">
                <p><strong>Email:</strong> <%= profile.email %></p>
                <p><strong>Mobile:</strong> <%= profile.mobile || 'N/A' %></p>
            </div>
        </div>
        <div class="profile-details">
          <div class="profile-details-header">
            <h2>Address </h2>
          </div>
          <div class="profile-details-main">
            <div class="profile-address-info">
              <% const addressFields = [
                { label: 'Address', key: 'addressLine' },
                { label: 'City', key: 'city' },
                { label: 'State', key: 'state' },
                { label: 'Country', key: 'country' },
                { label: 'Zip Code', key: 'postcode' }
              ]; %>
              <% addressFields.forEach(function(field) { %>
                <% if (profile.address && profile.address[field.key]) { %>
                  <p><strong><%= field.label %>:</strong> <%= profile.address[field.key] %></p>
                <% } %>
              <% }) %>
            </div>
          </div>
        </div>
        <div class="profile-details">
            <div class="profile-details-header">
                <h2>Social Links</h2>
            </div>
            <div class="profile-details-main">
                <ul class="social-links-list">
                  <% const platformIcons = {
                    facebook: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M22.675 0h-21.35C.6 0 0 .6 0 1.326v21.348C0 23.4.6 24 1.326 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.797.143v3.24l-1.918.001c-1.504 0-1.797.715-1.797 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116C23.4 24 24 23.4 24 22.674V1.326C24 .6 23.4 0 22.675 0'></path></svg>`,
                    twitter: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M24 4.557a9.83 9.83 0 0 1-2.828.775 4.932 4.932 0 0 0 2.165-2.724c-.951.555-2.005.959-3.127 1.184A4.916 4.916 0 0 0 16.616 3c-2.717 0-4.92 2.206-4.92 4.917 0 .386.044.762.127 1.124C7.728 8.77 4.1 6.797 1.671 3.149c-.423.722-.666 1.561-.666 2.475 0 1.708.87 3.216 2.188 4.099a4.904 4.904 0 0 1-2.229-.616c-.054 2.281 1.581 4.415 3.949 4.89a4.936 4.936 0 0 1-2.224.084c.627 1.956 2.444 3.377 4.6 3.417A9.867 9.867 0 0 1 0 21.543a13.94 13.94 0 0 0 7.548 2.212c9.058 0 14.009-7.513 14.009-14.009 0-.213-.005-.425-.014-.636A10.025 10.025 0 0 0 24 4.557z'></path></svg>`,
                    linkedin: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11.75 20h-3v-10h3v10zm-1.5-11.268c-.966 0-1.75-.784-1.75-1.75s.784-1.75 1.75-1.75 1.75.784 1.75 1.75-.784 1.75-1.75 1.75zm13.25 11.268h-3v-5.604c0-1.337-.026-3.063-1.868-3.063-1.868 0-2.156 1.459-2.156 2.967v5.7h-3v-10h2.881v1.367h.041c.401-.761 1.379-1.563 2.838-1.563 3.036 0 3.6 2.001 3.6 4.604v5.592z'></path></svg>`,
                    instagram: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.974.974 1.246 2.241 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.334 2.633-1.308 3.608-.974.974-2.241 1.246-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.334-3.608-1.308-.974-.974-1.246-2.241-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608.974-.974 2.241-1.246 3.608-1.308 1.266-.058 1.646-.07 4.85-.07zm0-2.163c-3.259 0-3.667.012-4.947.072-1.276.06-2.637.334-3.608 1.308-.974.974-1.246 2.241-1.308 3.608-.058 1.266-.07 1.646-.07 4.85s.012 3.584.07 4.85c.062 1.366.334 2.633 1.308 3.608.974.974 2.241 1.246 3.608 1.308 1.266.058 1.646.07 4.85.07s3.584-.012 4.85-.07c1.366-.062 2.633-.334 3.608-1.308.974-.974 1.246-2.241 1.308-3.608.058-1.266.07-1.646.07-4.85s-.012-3.584-.07-4.85c-.062-1.366-.334-2.633-1.308-3.608-.974-.974-2.241-1.246-3.608-1.308-1.266-.058-1.646-.07-4.85-.07zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a3.999 3.999 0 1 1 0-7.998 3.999 3.999 0 0 1 0 7.998zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z'></path></svg>`,
                    website: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.411 0-8-3.589-8-8 0-4.411 3.589-8 8-8 4.411 0 8 3.589 8 8 0 4.411-3.589 8-8 8zm0-14c-3.309 0-6 2.691-6 6 0 3.309 2.691 6 6 6 3.309 0 6-2.691 6-6 0-3.309-2.691-6-6-6z'></path></svg>`
                  };
                  let hasLinks = false;
                  if (profile.socialLinks && profile.socialLinks.length) {
                    profile.socialLinks.forEach(link => {
                      const key = link.platform.toLowerCase();
                      if (platformIcons[key] && link.url) {
                        hasLinks = true;
                  %>
                        <li>
                          <a href="<%= link.url %>" target="_blank" title="<%= link.platform %>">
                            <%- platformIcons[key] %>
                          </a>
                        </li>
                  <%   }
                    });
                  }
                  if (!hasLinks) { %>
                    <li><p>No social links available.</p></li>
                  <% } %>
                </ul>
            </div>
        </div>











    
    <div class="profile-services-details-panel" style="background-color: aqua;"></div>
</div>

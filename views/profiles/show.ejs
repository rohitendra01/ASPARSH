                    x: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M17.53 3.5h3.97l-7.02 8.06L22.5 20.5h-4.01l-5.13-5.89-5.13 5.89H3.5l7.02-8.06L1.5 3.5h4.01l5.13 5.89L17.53 3.5z'/></svg>`,
                    linkedin: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11.75 20h-3v-10h3v10zm-1.5-11.268c-.966 0-1.75-.784-1.75-1.75s.784-1.75 1.75-1.75 1.75.784 1.75 1.75-.784 1.75-1.75 1.75zm13.25 11.268h-3v-5.604c0-1.337-.026-3.063-1.868-3.063-1.868 0-2.156 1.459-2.156 2.967v5.7h-3v-10h2.881v1.367h.041c.401-.761 1.379-1.563 2.838-1.563 3.036 0 3.6 2.001 3.6 4.604v5.592z'/></svg>`,

    %>
  <% /* make slugSegment available to the whole template (modal is outside the loop) */ %>
  <% const slugSegment = (typeof slug !== 'undefined' && slug) ? '/' + encodeURIComponent(slug) : ''; %>
  </div>

    <div class="profile-details-header">
      <h2 id="services-subscriptions">Services & Subscriptions</h2>
    </div>
    <div class="hotels-list">
        <% if (hotels && hotels.length) { %>
          <ul class="hotel-names-list">
            <% hotels.forEach(function(hotel) { %>
              <li>
                <a href="/hotel/<%= hotel.hotelSlug %>"><strong><%= hotel.hotelName %></strong></a>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <div class="muted">No hotels created by this user.</div>
        <% } %>
      </div>

  <div class="services-grid">
    <% services.forEach(function(svc, idx){ %>
      <div class="service-card" data-key="<%= svc.key %>" data-enabled="<%= svc.enabled %>" data-note="<%= svc.note || '' %>">
        <div class="card-head">
          <div>
            <h4><%= svc.name %></h4>
            <p class="muted small"><%= svc.details %></p>
          </div>
          <div class="card-controls">
            <span class="badge <%= svc.enabled ? 'badge-active' : 'badge-off' %>">
              <%= svc.enabled ? 'Active' : 'Inactive' %>
            </span>
            <label class="switch">
              <input type="checkbox" class="service-toggle" <%= svc.enabled ? 'checked' : '' %> aria-label="Toggle <%= svc.name %>">
              <span class="slider"></span>
            </label>
          </div>
        </div>

        <div class="card-body">
            <div class="card-row">
            <button class="btn btn-outline configure-btn" data-idx="<%= idx %>">Configure</button>
            <a class="btn btn-primary manage-link" href="/dashboard<%= slugSegment %>/services/<%= encodeURIComponent(svc.key) %>">Manage</a>
            <% if (svc.subscribedPlan) { %>
              <div class="plan-pill">
                <small>Plan: <strong><%= svc.subscribedPlan.name %></strong></small>
                <% if (svc.subscribedPlan.expires) { %>
                  <small class="muted"> • Expires: <%= svc.subscribedPlan.expires %></small>
                <% } %>
              </div>
            <% } else { %>
              <button class="btn btn-ghost subscribe-btn" data-key="<%= svc.key %>">Subscribe</button>
            <% } %>
          </div>

          <% if (svc.pendingPayments && svc.pendingPayments.length) { %>
            <div class="pending-payments">
              <div class="pending-header">
                <small class="muted">Pending payments</small>
                <small class="muted">(<span class="pending-count"><%= svc.pendingPayments.length %></span>)</small>
              </div>
              <ul class="pending-list">
                <% svc.pendingPayments.forEach(function(inv){ %>
                  <li data-id="<%= inv.id %>">
                    <div>
                      <strong>₹ <%= inv.amount %></strong> — <span class="muted"><%= inv.descr %></span>
                      <% if (inv.due) { %> <small class="muted"> • due <%= inv.due %></small> <% } %>
                    </div>
                    <div class="pending-actions">
                      <button class="btn btn-sm mark-paid-btn">Mark paid</button>
                      <button class="btn btn-sm btn-outline">Invoice</button>
                    </div>
                  </li>
                <% }) %>
              </ul>
            </div>
          <% } else { %>
            <div class="no-pending small muted">No pending payments</div>
          <% } %>

          <% /* quick stats area (visual testing) */ %>
          <div class="service-stats small muted" style="margin-top:.6rem;">
            <% if (svc.usageStats) { %>
              <% for (const k in svc.usageStats) { %>
                <span style="margin-right: 1rem;"><strong><%= svc.usageStats[k] %></strong> <%= k %></span>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <div class="services-summary">
    <div class="summary-card">
      <h4>Quick Summary</h4>
      <p class="muted">Total services: <strong><%= services.length %></strong></p>
      <p class="muted">Active: <strong><%= services.filter(s=>s.enabled).length %></strong></p>
      <p class="muted">Pending payments: <strong><%= services.reduce((acc,s)=>acc + (s.pendingPayments? s.pendingPayments.length:0),0) %></strong></p>
      <div class="summary-actions">
        <button id="bulk-on" class="btn btn-sm">Enable all</button>
        <button id="bulk-off" class="btn btn-sm btn-outline">Disable all</button>
      </div>
    </div>

    <div class="summary-card plan-card">
      <h4>Subscription Center</h4>
      <p class="muted">Sample plans: Free • Pro • Business • Support Plus</p>
      <div class="plan-actions">
        <button class="btn btn-sm">Upgrade all to Pro</button>
        <button class="btn btn-sm btn-outline">Downgrade all to Free</button>
      </div>
    </div>
  </div>
</div>

<!-- Configure Modal (client-side) -->
<div id="configureModal" class="modal" aria-hidden="true">
  <div class="modal-inner" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <button class="modal-close" aria-label="Close">&times;</button>
    <h3 id="modalTitle">Configure Service</h3>
  <form id="configureForm" method="POST" action="/dashboard<%= slugSegment %>/services/configure">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="serviceKey" id="modalServiceKey">
      <div class="form-row">
        <label>Feature toggle</label>
        <label class="switch">
          <input id="modalFeatureToggle" type="checkbox">
          <span class="slider"></span>
        </label>
      </div>
      <div class="form-row">
        <label>Extra note</label>
        <textarea id="modalNote" name="note" placeholder="Admin note or configuration..."></textarea>
      </div>
      <div class="form-row modal-actions">
        <button type="button" id="saveConfig" class="btn btn-primary">Save</button>
        <button type="button" id="cancelConfig" class="btn btn-outline">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    const services = Array.from(document.querySelectorAll('.service-card'));
    const modal = document.getElementById('configureModal');
    const modalKey = document.getElementById('modalServiceKey');
    const modalNote = document.getElementById('modalNote');
    const modalToggle = document.getElementById('modalFeatureToggle');

    // toggle service enabled state (client-only)
    document.addEventListener('click', (e) => {
      if (e.target.matches('.service-toggle')) {
        const card = e.target.closest('.service-card');
        const badge = card.querySelector('.badge');
        if (e.target.checked) {
          badge.classList.remove('badge-off');
          badge.classList.add('badge-active');
          badge.textContent = 'Active';
        } else {
          badge.classList.remove('badge-active');
          badge.classList.add('badge-off');
          badge.textContent = 'Inactive';
        }
        // TODO: send fetch POST to API to persist change:
        // fetch(`/api/dashboard/${encodeURIComponent('<%= slug %>')}/services/${card.dataset.key}/toggle`, {method:'POST', body:JSON.stringify({enabled:e.target.checked}), headers:{'Content-Type':'application/json'}});
      }

      // open configure modal
      if (e.target.matches('.configure-btn')) {
        const idx = e.target.dataset.idx;
        const svcCard = document.querySelectorAll('.service-card')[idx];
        modalKey.value = svcCard.dataset.key;
        modalNote.value = svcCard.dataset.note || '';
        modalToggle.checked = svcCard.dataset.enabled === 'true' || svcCard.querySelector('.service-toggle').checked;
        modal.setAttribute('aria-hidden','false');
      }

      // subscribe action
      if (e.target.matches('.subscribe-btn')) {
        const key = e.target.dataset.key;
        alert('Subscribe flow for ' + key + ' (implement backend).');
      }

      // manage link clicked (for demo)
      if (e.target.matches('.manage-link')) {
        // allow normal anchor navigation
      }

      // mark paid
      if (e.target.matches('.mark-paid-btn')) {
        const li = e.target.closest('li');
        li.style.opacity = '.5';
        e.target.textContent = 'Paid';
        e.target.disabled = true;
        // optionally call backend to mark invoice paid
      }
    });

    // modal controls
    document.querySelector('.modal-close').addEventListener('click', closeModal);
    document.getElementById('cancelConfig').addEventListener('click', closeModal);
    document.getElementById('saveConfig').addEventListener('click', () => {
      // read values and update card UI (client-only)
      const key = modalKey.value;
      const enabled = modalToggle.checked;
      const note = modalNote.value;
      const card = document.querySelector(`.service-card[data-key="${key}"]`);
      if (card) {
        card.dataset.note = note;
        const toggle = card.querySelector('.service-toggle');
        toggle.checked = enabled;
        const badge = card.querySelector('.badge');
        badge.classList.toggle('badge-active', enabled);
        badge.classList.toggle('badge-off', !enabled);
        badge.textContent = enabled ? 'Active' : 'Inactive';
      }
      // TODO: send config to backend via fetch
      closeModal();
    });

    function closeModal() {
      modal.setAttribute('aria-hidden','true');
    }

    // Bulk actions
    document.getElementById('bulk-on').addEventListener('click', () => {
      document.querySelectorAll('.service-toggle').forEach(inp => { inp.checked = true; inp.dispatchEvent(new Event('change')); });
      alert('All services enabled (client-side). Hook this up to your API to persist.');
    });
    document.getElementById('bulk-off').addEventListener('click', () => {
      document.querySelectorAll('.service-toggle').forEach(inp => { inp.checked = false; inp.dispatchEvent(new Event('change')); });
      alert('All services disabled (client-side). Hook this up to your API to persist.');
    });
  })();
</script>

</div>

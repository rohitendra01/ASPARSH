                    whatsapp: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M12 0C5.373 0 0 5.373 0 12c0 2.21.577 4.27 1.58 6.07L0 24l5.93-1.58A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm6.75 17.25c-.15.45-1.05.9-1.65.9-.3 0-.6-.15-.9-.3-1.05-.6-4.2-2.25-4.2-5.25s3-4.65 3-4.65c1.05-1.05 2.25-.75 2.7-.6s1 .45 1 .9c0 .45-.15 3-1.35 4.35l-.15-.15c-.45-.45-1.05-.6-1.65-.3s-2.25 1.35-2.25 3c0 .9 1.05 2.25 2.55 3s2 .75 2 .75c1 .15 2 .15 2 .15s1 .15 1 .6c0 .45-.15 1-.3 1z'/></svg>`,
                    snapchat: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M12 0C5.373 0 0 5.373 0 12c0 4.418 3.582 8 8 8h1v2h-1c-5.523 0-10-4.477-10-10S6.477 2 12 2s10 4.477 10 10c0 .418-.042.828-.125 1.227l1.875-.625C23.958 11.172 24 11.084 24 11c0-6.627-5.373-12-12-12zM9.5 16c-.828 0-1.5-.672-1.5-1.5S8.672 13 9.5 13s1.5.672 1.5 1.5S10.328 16 9.5 16zm7 .5c0 .828-.672 1.5-1.5 1.5s-1.5-.672-1.5-1.5S14.172 15 15 15s1 .672 1 .5zm2-3c-.828 0-1-.672-1-1s-.672-1-1-1 .672-.672 1-.672h2c0 .828-.672 2-2 .672z'/></svg>`,
                    youtube: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M23.498 6.186c-.27-1.01-1.06-1.8-2.07-2.07C19.4 4 12 4 12 4s-7.4 0-9.43.116c-1.01.27-1.8 1.06-2.07 2.07C0 8.6 0 12 0 12s0 3.4.116 5.43c.27 1.01 1.06 1.8 2.07 2.07C4 20 12 20 12 20s7.4 0 9.43-.116c1.01-.27 1.8-1.06 2.07-2.07C24 15.4 24 12 24 12s0-3.4-.116-5.43zM9.75 15V9l6.25 3L9.75 15z'/></svg>`,
                    pinterest: `<svg width='24' height='24' fill='currentColor' viewBox='0 0 24 24'><path d='M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.396 7.646 11.093-.106-.942-.202-2.389.042-3.419.221-.956 1.423-6.096 1.423-6.096s-.362-.724-.362-1.797c0-1.684.976-2.942 2.188-2.942 1.032 0 1.531.775 1.531 1.704 0 1.039-.661 2.591-1.001 4.034-.285 1.207.604 2.192 1.789 2.192 2.147 0 3.797-2.266 3.797-5.537 0-2.892-2.08-4.915-5.054-4.915-3.453 0-5.482 2.588-5.482 5.263 0 1.045.403 2.168.907 2.777.101.122.115.229.084.352-.092.385-.299 1.207-.339 1.374-.053.221-.173.269-.401.163-1.497-.697-2.431-2.885-2.431-4.646 0-3.783 3.073-8.312 9.166-8.312 4.903 0 8.122 3.548 8.122 7.363 0 5.045-2.803 8.797-6.953 8.797-1.393 0-2.703-.753-3.148-1.604l-.857 3.263c-.26.991-.768 2.232-1.146 2.991.862.267 1.771.412 2.722.412 6.627 0 12-5.373 12-12S18.627 0 12 0z'/></svg>`,
                    website: `<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><ellipse cx="12" cy="12" rx="10" ry="4"/><path d="M2 12h20M12 2c2.5 3.5 2.5 14 0  20M12 2C9.5 5.5 9.5 18.5 12 22"/></svg>`
                  };
                  let hasLinks = false;
                  if (profile.socialLinks && profile.socialLinks.length) {
                    profile.socialLinks.forEach(link => {
                      const key = link.platform.toLowerCase();
                      if (platformIcons[key] && link.url) {
                        hasLinks = true;
                  %>
                        <li>
                          <a href="<%= link.url %>" target="_blank" title="<%= link.platform %>">
                            <%- platformIcons[key] %>
                          </a>
                        </li>
                  <%   }
                    });
                  }
                  if (!hasLinks) { %>
                    <li><p>No social links available.</p></li>
                  <% } %>
                </ul>
            </div>
        </div>
        <div class="profile-details">
          <div class="profile-details-header">
                <h2>Occupation</h2>
            </div>
            <div class="profile-details-main">
                <% if (profile.occupation) { %>
                      <p class="profile-occupation"><strong>Occupation:</strong> <%= profile.occupation %></p>
                    <% } %>
                    <% if (profile.category) { %>
                      <p class="profile-category"><strong>Category:</strong> <%= profile.category %></p>
                    <% } %>
                    <% if (profile.subcategory) { %>
                      <p class="profile-subcategory"><strong>Subcategory:</strong> <%= profile.subcategory %></p>
                    <% } %>
                    <p class="profile-experience"><strong>Experience:</strong> <%= (profile.experience || 0) %> year<%= (profile.experience == 1) ? '' : 's' %></p>
              </div>
        </div>
    </div>











    

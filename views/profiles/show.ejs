<% layout('layouts/dashboard-boilerplate') -%>
  <% block('styles').append('<link rel="stylesheet" href="/css/profiles/show.css">') %>

    <% const slugSegment=(typeof slug !=='undefined' && slug) ? '/' + encodeURIComponent(slug) : '' ; %>

      <div class="profile-dashboard">

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon hotels-icon">🏨</div>
            <div class="stat-info">
              <span class="stat-value">
                <%= typeof hotels !=='undefined' ? hotels.length : 0 %>
              </span>
              <span class="stat-label">Connected Hotels</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon portfolios-icon">💼</div>
            <div class="stat-info">
              <span class="stat-value">
                <%= typeof portfolios !=='undefined' ? portfolios.length : 0 %>
              </span>
              <span class="stat-label">Active Portfolios</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon vcard-icon">🪪</div>
            <div class="stat-info">
              <span class="stat-value">
                <%= typeof visitingCards !=='undefined' ? visitingCards.length : 0 %>
              </span>
              <span class="stat-label">Visiting Cards</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon reviews-icon">⭐</div>
            <div class="stat-info">
              <span class="stat-value">
                <%= typeof reviewLinks !=='undefined' ? reviewLinks.length : 0 %>
              </span>
              <span class="stat-label">Review Systems</span>
            </div>
          </div>
        </div>

        <div class="profile-content-grid">

          <div class="profile-sidebar">
            <div class="identity-card">
              <div class="identity-header">
                <div class="profile-avatar">
                  <img src="<%= profile.image || 'https://placehold.co/150x150?text=No+Image' %>"
                    alt="<%= profile.name %>" />
                </div>
                <h2 class="profile-name">
                  <%= profile.name %>
                </h2>
                <% if (profile.occupation || profile.category) { %>
                  <div class="profile-badges">
                    <% if (profile.occupation) { %><span class="badge badge-occupation">
                        <%= profile.occupation %>
                      </span>
                      <% } %>
                        <% if (profile.category) { %><span class="badge badge-category">
                            <%= profile.category %>
                          </span>
                          <% } %>
                  </div>
                  <% } %>
                    <p class="profile-joined">Joined <%= profile.createdAt.getFullYear() %>/<%=
                          String(profile.createdAt.getMonth() + 1).padStart(2, '0' ) %>/<%=
                            String(profile.createdAt.getDate()).padStart(2, '0' ) %>
                    </p>
              </div>

              <div class="identity-body">
                <div class="info-group">
                  <label>Email</label>
                  <p>
                    <%= profile.email || 'N/A' %>
                  </p>
                </div>
                <div class="info-group">
                  <label>Mobile</label>
                  <p>
                    <%= profile.mobile || 'N/A' %>
                  </p>
                </div>
                <div class="info-group">
                  <label>Experience</label>
                  <p>
                    <%= profile.experience || 0 %> Years
                  </p>
                </div>

                <div class="info-group">
                  <label>Address</label>
                  <% if (profile.address && (profile.address.city || profile.address.addressLine)) { %>
                    <p>
                      <%= profile.address.addressLine %><br>
                        <%= profile.address.city %>
                          <% if(profile.address.state) { %>, <%= profile.address.state %>
                              <% } %>
                                <%= profile.address.postcode %>
                    </p>
                    <% } else { %>
                      <p class="text-muted">No address provided</p>
                      <% } %>
                </div>
              </div>

              <div class="identity-actions">
                <a href="/dashboard<%= slugSegment %>/profiles/<%= encodeURIComponent(profile.slug) %>/edit"
                  class="btn btn-outline-primary btn-full">Edit Profile</a>
              </div>
            </div>
          </div>

          <div class="profile-modules">
            <div class="module-header">
              <h3>Active Services & Assets</h3>
              <p class="text-muted">Manage applications and links connected to this profile.</p>
            </div>

            <div class="modules-grid">

              <div class="module-card">
                <div class="module-card-header">
                  <h4>🏨 Hotels & Menus</h4>
                  <a href="/dashboard<%= slugSegment %>/hotels/new" class="btn-icon-small" title="Create New">+</a>
                </div>
                <div class="module-card-body">
                  <% if (typeof hotels !=='undefined' && hotels.length> 0) { %>
                    <ul class="asset-list">
                      <% hotels.forEach(h=> { %>
                        <li>
                          <div class="asset-info">
                            <strong>
                              <%= h.hotelName %>
                            </strong>
                            <span>
                              <%= h.hotelType %>
                            </span>
                          </div>
                          <a href="/hotel/<%= h.hotelSlug %>" target="_blank" class="btn btn-sm btn-secondary">View</a>
                        </li>
                        <% }) %>
                    </ul>
                    <% } else { %>
                      <div class="empty-state">No hotels connected yet.</div>
                      <% } %>
                </div>
              </div>

              <div class="module-card">
                <div class="module-card-header">
                  <h4>💼 Portfolios</h4>
                  <a href="/dashboard<%= slugSegment %>/portfolio/new" class="btn-icon-small" title="Create New">+</a>
                </div>
                <div class="module-card-body">
                  <% if (typeof portfolios !=='undefined' && portfolios.length> 0) { %>
                    <ul class="asset-list">
                      <% portfolios.forEach(p=> { %>
                        <li>
                          <div class="asset-info">
                            <strong>
                              <%= p.name %>
                            </strong>
                            <span>Template: <%= p.design ? p.design.name : 'Custom' %></span>
                          </div>
                          <a href="/portfolio/<%= p.slug %>" target="_blank" class="btn btn-sm btn-secondary">View</a>
                        </li>
                        <% }) %>
                    </ul>
                    <% } else { %>
                      <div class="empty-state">No portfolios created yet.</div>
                      <% } %>
                </div>
              </div>

              <div class="module-card">
                <div class="module-card-header">
                  <h4>🪪 Digital Visiting Cards</h4>
                  <a href="/dashboard<%= slugSegment %>/visiting-cards/new" class="btn-icon-small"
                    title="Create New">+</a>
                </div>
                <div class="module-card-body">
                  <% if (typeof visitingCards !=='undefined' && visitingCards.length> 0) { %>
                    <ul class="asset-list">
                      <% visitingCards.forEach(vc=> { %>
                        <li>
                          <div class="asset-info">
                            <strong>
                              <%= vc.title %>
                            </strong>
                            <span class="truncate">
                              <%= vc.description %>
                            </span>
                          </div>
                          <a href="/visiting-card/<%= profile.slug %>" target="_blank"
                            class="btn btn-sm btn-secondary">View</a>
                        </li>
                        <% }) %>
                    </ul>
                    <% } else { %>
                      <div class="empty-state">No visiting cards generated.</div>
                      <% } %>
                </div>
              </div>

              <div class="module-card">
                <div class="module-card-header">
                  <h4>⭐ AI Review Generators</h4>
                  <a href="/dashboard<%= slugSegment %>/reviews/new" class="btn-icon-small" title="Create New">+</a>
                </div>
                <div class="module-card-body">
                  <% if (typeof reviewLinks !=='undefined' && reviewLinks.length> 0) { %>
                    <ul class="asset-list">
                      <% reviewLinks.forEach(rl=> { %>
                        <li>
                          <div class="asset-info">
                            <strong>
                              <%= rl.businessName %>
                            </strong>
                            <span>
                              <%= rl.viewCount || 0 %> Views | <%= rl.generationCount || 0 %> Generated
                            </span>
                          </div>
                          <a href="/reviews/<%= rl.slug %>" target="_blank" class="btn btn-sm btn-secondary">View</a>
                        </li>
                        <% }) %>
                    </ul>
                    <% } else { %>
                      <div class="empty-state">No review links active.</div>
                      <% } %>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
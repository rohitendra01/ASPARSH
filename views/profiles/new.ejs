<% layout('layouts/dashboard-boilerplate') -%>
<% block('styles').append('<link rel="stylesheet" href="/css/profiles/new.css">') %>
<div class="profile-form-container">
  <form class="profile-form" method="POST" action="/dashboard/<%=currentUser.slug%>/profiles/new" enctype="multipart/form-data">
    <h2 class="form-title">Create New Profile</h2>
    <div class="form-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required placeholder="Full Name" class="form-control" />
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required placeholder="Email Address" class="form-control" />
    </div>
    <div class="form-group">
      <label for="mobile">Mobile</label>
      <input type="text" id="mobile" name="mobile" required placeholder="Mobile Number" class="form-control" />
    </div>
    <div class="form-group">
      <label for="image">Profile Image</label>
      <input type="file" id="image" name="image" accept="image/*" class="form-control" />
    </div>
    <div class="form-group">
      <label for="addressLine">Address</label>
      <input type="text" id="addressLine" name="addressLine" placeholder="Street Address" class="form-control" />
    </div>
    <div class="form-group">
      <label for="city">City</label>
      <input type="text" id="city" name="city" placeholder="City" class="form-control" />
    </div>
    <div class="form-group">
      <label for="state">State</label>
      <input type="text" id="state" name="state" placeholder="State" class="form-control" />
    </div>
    <div class="form-group">
      <label for="country">Country</label>
      <input type="text" id="country" name="country" placeholder="Country" class="form-control" />
    </div>
      <div class="form-group">
        <label for="postcode">Postcode</label>
        <input type="text" id="postcode" name="postcode" placeholder="Postcode" class="form-control" />
      </div>
    </div>
    <div id="social-links-section" class="form-group">
      <label>Social Links</label>
      <div id="social-links-list">
        <div class="form-row">
          <div class="form-group">
            <input type="text" name="socialLinks[0][type]"
                   placeholder="Type (e.g. Facebook)" class="form-control" required />
          </div>
          <div class="form-group" style="margin-left:1rem;">
            <input type="text" name="socialLinks[0][url]"
                   placeholder="https://… " class="form-control" required />
          </div>
          <button type="button" onclick="this.parentNode.remove()" class="btn btn-link text-danger">×</button>
        </div>
      </div>
      <button type="button" class="btn btn-secondary" onclick="addSocialLinkField()">+ Add Social Link</button>
    </div>

    <button type="submit" class="btn btn-primary">Create Profile</button>
  </form>
</div>

<script>
  function addSocialLinkField() {
    const list = document.getElementById('social-links-list');
    const idx = list.children.length;
    const wrapper = document.createElement('div');
    wrapper.className = 'form-row';
    wrapper.innerHTML = `
      <div class="form-group">
        <input type="text" name="socialLinks[${idx}][type]"
               placeholder="Type (e.g. Facebook)" class="form-control" required />
      </div>
      <div class="form-group" style="margin-left:1rem;">
        <input type="url" name="socialLinks[${idx}][url]"
               placeholder="https://… " class="form-control" required />
      </div>
      <button type="button" onclick="this.parentNode.remove()" class="btn btn-link text-danger">×</button>
    `;
    list.appendChild(wrapper);
  }
</script>

<style>
  #social-links-section { margin-bottom: 1.5rem; }
  .form-row { display: flex; align-items: center; margin-bottom: .75rem; }
  .form-row .form-group { flex: 1; }
</style>

<style>
.profile-form-container {
  max-width: 480px;
  margin: 2rem auto;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 4px 24px #007bff22;
  padding: 2rem 2.5rem;
}
.profile-form .form-title {
  text-align: center;
  font-size: 1.6rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
}
.form-group {
  margin-bottom: 1.2rem;
}
.form-row {
  display: flex;
  gap: 1rem;
}
.form-row .form-group {
  flex: 1;
  margin-bottom: 0;
}
.form-control {
  width: 100%;
  padding: 0.7rem 1rem;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 1em;
  background: #f9f9f9;
  transition: border-color 0.2s;
}
.form-control:focus {
  border-color: #007bff;
  background: #fff;
  outline: none;
}
.btn-primary {
  width: 100%;
  padding: 0.8rem;
  background: #007bff;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 1.1em;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.2s;
}
.btn-primary:hover {
  background: #0056b3;
}
</style>

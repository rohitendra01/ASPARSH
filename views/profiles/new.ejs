      "Marketing, Advertising & PR": ["digital marketing","SEO/SEM","social media managers","performance marketers","brand strategists","creative agencies","PR firms","content creators","influencer marketing","email marketing","event marketing"],
      "Sales & Business Development": ["B2B sales reps","account managers","channel partners","inside sales","sales engineers","CRM consultants","lead-gen agencies"],
      "Human Resources & Recruitment": ["recruiters","staffing agencies","HR consultants","payroll providers","L&D specialists","executive search","HR tech"],
      "Consulting & Strategy": ["management consultants","IT consultants","strategy consultants","operations consultants","sustainability consultants","supply chain consultants"],
      "Legal & Compliance Tech": ["regtech providers","contract management","compliance officers","AML/KYC consultants"],
      "Media, Publishing & Journalism": ["newspapers","magazines","online publishers","editors","reporters","copywriters","content strategists","podcast producers","newsletter writers"],
      "Film, Video & Photography": ["photographers","videographers","film producers","editors","cinematographers","studios","production houses","stock footage providers","event photographers"],
      "Music, Arts & Entertainment": ["musicians","bands","artists","galleries","art dealers","stage production","theatre companies","comedians","DJs"],
      "Gaming & Animation": ["game developers","animators","VFX studios","sound designers","game publishers","indie studios"],
      "Events & Weddings": ["event planners","wedding planners","decorators","caterers (event)","AV & production","sound & lighting","stage designers","ticketing platforms"],
      "Sports & Recreation": ["sports clubs","coaches","personal trainers","sports academies","equipment retailers","physiotherapists (sports)","stadium management"],
      "Beauty, Fashion & Apparel": ["designers","tailors","boutiques","textile suppliers","garment manufacturers","footwear","accessories","fashion stylists","modeling agencies"],
      "Jewelry & Watches": ["jewelers","watchmakers","repair shops","gemstone dealers","custom jewel design"],
      "Printing, Signage & Packaging": ["offset printers","digital printers","packaging designers","label printers","signage & hoardings","3D printing services"],
      "Home Services & Repairs": ["plumbers","electricians","carpenters","handymen","HVAC technicians","pest control","locksmiths","appliance repair"]
    };

    const catSelect = document.getElementById('categorySelect');
    const catSearch = document.getElementById('categorySearch');
    const subSelect = document.getElementById('subcategorySelect');

    if (!catSelect || !catSearch || !subSelect) return;

    // create datalist for suggestions
    let datalist = document.getElementById('categoryDatalist');
    if (!datalist) {
      datalist = document.createElement('datalist');
      datalist.id = 'categoryDatalist';
      document.body.appendChild(datalist);
      catSearch.setAttribute('list', 'categoryDatalist');
    }

    function populateCategories(filter){
      const keys = Object.keys(CATEGORY_DATA).filter(k => !filter || k.toLowerCase().includes(filter.toLowerCase()));
      catSelect.innerHTML = '<option value="">-- choose category --</option>' + keys.map(k => `<option value="${k}">${k}</option>`).join('');
      // update datalist
      datalist.innerHTML = keys.map(k => `<option value="${k}"></option>`).join('');
    }

    function populateSubcategories(category){
      const items = CATEGORY_DATA[category] || [];
      subSelect.innerHTML = '<option value="">-- choose subcategory --</option>' + items.map(s => `<option value="${s}">${s}</option>`).join('');
    }

    catSearch.addEventListener('input', (e)=>{ populateCategories(e.target.value); });
    catSearch.addEventListener('change', (e)=>{
      const val = e.target.value;
      if (CATEGORY_DATA[val]) {
        catSelect.value = val;
        populateSubcategories(val);
      }
    });
    catSelect.addEventListener('change', (e)=>{ populateSubcategories(e.target.value); catSearch.value = e.target.value; });

    // initial population
    populateCategories();
  });
</script>
<% layout('layouts/dashboard-boilerplate') -%>
<% block('styles').append('<link rel="stylesheet" href="/css/profiles/new.css">') %>
<div class="profile-form-container">
<form class="profile-form"
      method="POST"
  <% const currentUserSlugSegment = (currentUser && currentUser.slug) ? '/' + encodeURIComponent(currentUser.slug) : ''; %>
  action="/dashboard<%= currentUserSlugSegment %>/profiles/new"
      enctype="multipart/form-data"
      onsubmit="reindexSocialLinks()">
    <!-- CSRF token for POST protection; populated by csurf-safe GET middleware -->
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2 class="form-title">Create New Profile</h2>
    <div class="form-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required placeholder="Full Name" class="form-control" />
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required placeholder="Email Address" class="form-control" />
    </div>
    <div class="form-group">
      <label for="mobile">Mobile</label>
      <input type="text" id="mobile" name="mobile" required placeholder="Mobile Number" class="form-control" />
    </div>
    <div class="form-group">
      <label for="image">Profile Image</label>
      <input type="file" id="image" name="image" accept="image/*" class="form-control" />
    </div>
    <div class="form-group">
      <label for="addressLine">Address</label>
      <input type="text" id="addressLine" name="addressLine" placeholder="Street Address" class="form-control" />
    </div>
    <div class="form-group">
      <label for="city">City</label>
      <input type="text" id="city" name="city" placeholder="City" class="form-control" />
    </div>
    <div class="form-group">
      <label for="state">State</label>
      <input type="text" id="state" name="state" placeholder="State" class="form-control" />
    </div>
    <div class="form-group">
      <label for="country">Country</label>
      <input type="text" id="country" name="country" placeholder="Country" class="form-control" />
    </div>
      <div class="form-group">
        <label for="postcode">Postcode</label>
        <input type="text" id="postcode" name="postcode" placeholder="Postcode" class="form-control" />
      </div>
      <div id="social-links-section" class="form-group">
        <label>Social Links</label>
      <div id="social-links-list">
        <div class="form-row">
          <div class="form-group">
            <input type="text" name="socialLinks[0][platform]" class="form-control" placeholder="Platform (e.g. Facebook)" required />
          </div>
          <div class="form-group" style="margin-left:1rem;">
            <input type="text" name="socialLinks[0][url]" class="form-control" placeholder="https://…" required />
          </div>
          <button type="button" class="remove-social-link-btn btn btn-link text-danger">×</button>
        </div>
      </div>
      <button id="add-social-link-btn" type="button" class="btn btn-secondary">+ Add Social Link</button>
    </div>  
    <button type="submit" class="btn btn-primary">Create Profile</button>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form   = document.querySelector('.profile-form');
    const list   = document.getElementById('social-links-list');
    const addBtn = document.getElementById('add-social-link-btn');
    
    function reindexSocialLinks() {
      document.querySelectorAll('#social-links-list .form-row').forEach((row, i) => {
        const inputs = row.querySelectorAll('input');
        inputs[0].name = `socialLinks[${i}][platform]`;
        inputs[1].name = `socialLinks[${i}][url]`;
      });
    }
    // 1) On submit, reindex all rows so names are correct
    form.addEventListener('submit', () => {
      reindexSocialLinks();
      // (no preventDefault—let it actually submit)
    });

    // 2) Add a new row when clicked
    addBtn.addEventListener('click', addSocialLinkField);
    
    // 3) Delegate removal clicks
    list.addEventListener('click', (e) => {
      if (e.target.matches('.remove-social-link-btn')) {
        e.target.closest('.form-row').remove();
        reindexSocialLinks();
      }
    });
  });

  function addSocialLinkField() {
    const list = document.getElementById('social-links-list');
    const row  = document.createElement('div');
    row.className = 'form-row';
    row.innerHTML = `
      <div class="form-group">
        <input type="text" class="form-control" placeholder="Platform (e.g. Facebook)" required>
      </div>
      <div class="form-group" style="margin-left:1rem;">
        <input type="text" class="form-control" placeholder="https://…" required>
      </div>
      <button type="button" class="remove-social-link-btn btn btn-link text-danger">×</button>
    `;
    list.appendChild(row);
    reindexSocialLinks();
  }

</script>

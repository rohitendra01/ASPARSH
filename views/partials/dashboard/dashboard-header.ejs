<header class="dashboard-header">
  <div style="display: flex; align-items: center; gap: 1.5rem;">
    <button class="mobile-toggle" id="mobileToggle">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <% const currentUserSlugSegment=(currentUser && currentUser.slug) ? '/' + encodeURIComponent(currentUser.slug) : ''
      ; %>
      <a href="/dashboard<%= currentUserSlugSegment %>" class="header-title-link">Asparsh</a>
  </div>

  <div style="flex: 1;"></div>

  <div class="header-actions">
    <div class="user-dropdown-container">
      <div class="user-profile-trigger" id="userProfileTrigger">
        <img src="<%= currentUser && currentUser.image ? currentUser.image : '/assets/user-login.png' %>" alt="User">
        <span class="user-name-text">
          <%= currentUser && currentUser.username ? currentUser.username : 'User' %>
        </span>
      </div>

      <div class="logout-menu" id="logoutMenu">
        <form id="logoutForm" action="/logout" method="POST">
          <%- include('../csrf-input') %>
            <button type="submit" class="logout-btn">Log out</button>
        </form>
      </div>
    </div>
  </div>
</header>
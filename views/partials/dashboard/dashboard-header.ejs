<header>
    <div class="header-logo">
        <a href="/">Asparsh</a>
    </div>
    <div class="header-links">
        <a href="https://caendar.google.com" class="calender"><img src="/assets/calendar-svg.svg" alt=""></a>
        <a href="" class="messages"><img src="/assets/messages-svg.svg" alt=""></a>
        <a href="" class="notifications"><img src="/assets/notifications-svg.svg" alt=""></a>
        <div class="user-logo" style="position: relative;">
            <img src="<%= currentUser && currentUser.image ? currentUser.image : '/assets/user-login.png' %>" alt="<%= currentUser && currentUser.username ? currentUser.username : 'User' %>" />
            <p><%= currentUser && currentUser.username ? currentUser.username : 'User' %></p>
            <form id="logoutForm" action="/logout" method="POST" class="logout-form">
              <%- include('../csrf-input') %>
              <button type="submit" class="logout-btn">Logout</button>
            </form>
        </div>
        </div>
        </header>
        <script>
          const userLogo = document.querySelector('.user-logo');
          const logoutForm = document.getElementById('logoutForm');
          userLogo.addEventListener('mouseenter', () => {
            logoutForm.style.display = 'block';
          });
          userLogo.addEventListener('mouseleave', () => {
            logoutForm.style.display = 'none';
          });
        </script>
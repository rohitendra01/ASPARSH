<header class="site-header header-scroll-effect">
        <div class="header-container">
            <div class="logo">
                <a href="/" aria-label="Asparsh - Go to homepage">
                    <h1>ASPARSH</h1>
                </a>
            </div>

            <!-- Mobile hamburger toggle -->
            <button 
                type="button" 
                class="hamburger" 
                id="hamburgerBtn" 
                aria-label="Toggle navigation menu" 
                aria-expanded="false" 
                aria-controls="mobileMenu"
            >
                <span></span>
                <span></span>
                <span></span>
            </button>

            <nav class="nav" role="navigation" aria-label="Main navigation">
                <ul class="nav-links">
                    <li><a href="/home" aria-current="<%= locals.currentPage === 'home' ? 'page' : false %>">Home</a></li>
                    <li><a href="/pricing" aria-current="<%= locals.currentPage === 'pricing' ? 'page' : false %>">Pricing</a></li>
                    <li><a href="/about" aria-current="<%= locals.currentPage === 'about' ? 'page' : false %>">About</a></li>
                    <li><a href="/contact" aria-current="<%= locals.currentPage === 'contact' ? 'page' : false %>">Contact</a></li>
                </ul>
            </nav>

            <div class="user-profile">
                <% if (!currentUser) { %>
                    <a href="/dashboard" class="dashboard-btn">
                        <span>Dashboard</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </a>
                <% } else { %>
                    <div class="user-dropdown" id="userDropdown">
                        <button 
                            type="button"
                            class="user-profile-trigger" 
                            id="dropdownTrigger" 
                            aria-label="User menu"
                            aria-expanded="false"
                            aria-haspopup="true"
                        >
                            <img 
                                alt="<%= currentUser.username %>'s profile picture" 
                                class="header-user-image"
                                src="<%= currentUser && currentUser.image ? currentUser.image : '/assets/user-login.png' %>"
                                loading="lazy"
                            >
                            <span class="sr-only"><%= currentUser.username %></span>
                        </button>
                        <div class="user-dropdown-content" id="dropdownContent" role="menu">
                            <div class="form">
                                <p class="p" role="menuitem">
                                    Welcome, <strong><%= currentUser.username %></strong>
                                </p>
                                <form action="/logout" method="POST">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="button-submit" role="menuitem">
                                        Sign Out
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Mobile menu -->
            <div class="mobile-menu" id="mobileMenu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Mobile navigation menu">
                <nav role="navigation" aria-label="Mobile navigation">
                    <ul class="mobile-nav-links">
                        <li><a href="/home" tabindex="-1">Home</a></li>
                        <li><a href="/pricing" tabindex="-1">Pricing</a></li>
                        <li><a href="/about" tabindex="-1">About</a></li>
                        <li><a href="/contact" tabindex="-1">Contact</a></li>
                    </ul>
                </nav>
                <div class="mobile-user-area">
                    <% if (!currentUser) { %>
                        <a href="/dashboard" class="dashboard-btn" tabindex="-1">Dashboard</a>
                    <% } else { %>
                        <div class="mobile-user">
                            <a href="/dashboard" class="mobile-user-link" tabindex="-1">
                                <img 
                                    alt="<%= currentUser.username %>'s profile picture" 
                                    class="header-user-image" 
                                    src="<%= currentUser && currentUser.image ? currentUser.image : '/assets/user-login.png' %>"
                                    loading="lazy"
                                >
                                <span><%= currentUser.username %></span>
                            </a>
                            <form action="/logout" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="button-submit" tabindex="-1">Sign Out</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </header>
<header>
        <div class="logo">
            <a href="/">
                <h3>ASPARSH</h3>
            </a>
        </div>

        <!-- Mobile hamburger toggle (visible on small screens) -->
        <button type="button" class="hamburger" id="hamburgerBtn" aria-label="Toggle navigation" aria-expanded="false" aria-controls="mobileMenu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class="nav">
            <ul class="nav-links">
                <li><a href="/home">Home</a></li>
                <li><a href="/pricing">Pricing</a></li>
                <li><a href="About">About</a></li>
                <li><a href="/contact">Contact Us</a></li>
            </ul>
        </div>

        <div class="user-profile">
                        <% if (!currentUser) { %>
                                <div style="overflow: visible; position: relative;">
                                    <a href="/dashboard" class="dashboard-btn">. Dashboard</a>
                                </div>
                        <% } else { %>
                <div class="user-dropdown" id="userDropdown">
                    <a href="/dashboard" class="user-profile-trigger" id="dropdownTrigger" title="Go to Dashboard">
                        <img alt="User Profile" class="header-user-image"
                            src="<%= currentUser && currentUser.image ? currentUser.image : '/assets/user-login.png'%>" >
                    </a>
                    <div class="user-dropdown-content" id="dropdownContent">
                        <div class="form">
                            <p class="p" style="font-weight: 600; text-align: center;">
                                Welcome, <%= currentUser.username %>
                            </p>
                            <form action="/logout" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="button-submit" style="width: 100%;">Logout</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Mobile menu: contains nav links and user actions for small screens -->
        <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
            <ul class="mobile-nav-links">
                <li><a href="/home">Home</a></li>
                <li><a href="/pricing">Pricing</a></li>
                <li><a href="About">About</a></li>
                <li><a href="/contact">Contact Us</a></li>
            </ul>
            <div class="mobile-user-area">
                <% if (!currentUser) { %>
                    <a href="/dashboard" class="dashboard-btn">Dashboard</a>
                <% } else { %>
                    <div class="mobile-user">
                        <a href="/dashboard" class="mobile-user-link">
                            <img alt="User Profile" class="header-user-image" src="<%= currentUser && currentUser.image ? currentUser.image : '/assets/user-login.png'%>">
                            <span style="margin-left:10px"><%= currentUser.username %></span>
                        </a>
                        <form action="/logout" method="POST" style="margin-top:10px;">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="button-submit">Logout</button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>
    </header>
    <script>
(function () {
  const btn = document.getElementById('hamburgerBtn');
  const panel = document.getElementById('mobileMenu');
  if (!btn || !panel) return;

  function openMenu() {
    btn.setAttribute('aria-expanded', 'true');
    panel.classList.add('open');
    panel.setAttribute('aria-hidden', 'false');
    // prevent background scroll while open
    document.documentElement.style.overflow = 'hidden';
  }
  function closeMenu() {
    btn.setAttribute('aria-expanded', 'false');
    panel.classList.remove('open');
    panel.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
  }

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    if (expanded) closeMenu(); else openMenu();
  });

  // Close when clicking outside: click anywhere not inside panel or button
  document.addEventListener('click', (e) => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    if (!expanded) return;
    if (!panel.contains(e.target) && !btn.contains(e.target)) closeMenu();
  });

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') closeMenu();
  });

  // Close on link click inside mobile panel (keeps UX simple)
  panel.addEventListener('click', (e) => {
    const a = e.target.closest('a');
    if (a) closeMenu();
  });
})();
</script>

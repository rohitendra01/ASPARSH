<style>

  /* Login Page Styles */

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    background-color: #f0f2f5; /* Light grey background for the page */
}

.login-container {
    background-color: #ffffff; /* White background for the form container */
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1); /* Soft shadow */
    width: 100%;
    max-width: 400px;
    box-sizing: border-box;
    text-align: center;
}

.login-title {
    font-size: 2em;
    color: #333333;
    margin-bottom: 30px;
    font-weight: 600;
}

.login-group {
    margin-bottom: 20px;
    text-align: left;
}

.login-group label {
    display: block;
    margin-bottom: 8px;
    color: #555555;
    font-weight: 500;
}

.login-group input[type="email"],
.login-group input[type="password"] {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    box-sizing: border-box;
    font-size: 1em;
    color: #333333;
    transition: border-color 0.3s ease;
}

.login-group input[type="email"]::placeholder,
.login-group input[type="password"]::placeholder {
    color: #aaaaaa;
}

.login-group input[type="email"]:focus,
.login-group input[type="password"]:focus {
    border-color: #007bff; /* Highlight on focus */
    outline: none;
}

.login-btn {
    background-color: #007bff;
    color: #ffffff;
    padding: 15px 25px;
    border: none;
    border-radius: 8px;
    font-size: 1.1em;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    width: 100%;
    margin-top: 20px;
    font-weight: 600;
}

.login-btn:hover {
    background-color: #0056b3;
    transform: translateY(-2px);
}

.login-register-link {
    margin-top: 25px;
    color: #666666;
    font-size: 0.95em;
}

.login-register-link a {
    color: #007bff;
    text-decoration: none;
    font-weight: 500;
}

.login-register-link a:hover {
    text-decoration: underline;
}

/* Styles for alert messages (from your HTML) */
.alert {
    padding: 10px 15px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 0.9em;
    text-align: left;
}

.alert-danger {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}
</style>

<div class="login-container">
  <form class="login-form" method="POST" action="/login">
    <h2 class="login-title">Sign In</h2>
    <!-- <% if (error_msg) { %>
      <div class="alert alert-danger"><%= error_msg %></div>
    <% } %> -->
    <div class="login-group">
      <label for="email">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        value="<%= typeof email !== 'undefined' ? email : '' %>"
        required
        placeholder="Enter your email"
        class="<%= error_msg ? 'input-error' : '' %>"
      >
    </div>
    <div class="login-group">
      <label for="password">Password</label>
      <input
        type="password"
        id="password"
        name="password"
        required
        placeholder="Enter your password"
        class="<%= error_msg ? 'input-error' : '' %>"
      >
    </div>
    <button type="submit" class="login-btn">Login</button>
    <p style="margin-top: 10px; text-align: right;">
      <a href="#" id="forgot-password-link" style="color: #007bff; font-size: 0.95em; text-decoration: none;">Forgot Password?</a>
    </p>
    <p class="login-register-link">Don't have an account? <a href="/register">Register</a></p>
</form>

<!-- Modern Password Reset Modal -->
<div id="reset-modal" style="display:none; position:fixed; top:0; left:0; width:100vw; height:100vh; background:rgba(0,0,0,0.35); z-index:1000; align-items:center; justify-content:center;">
  <div style="background:#fff; padding:2.5rem 2rem; border-radius:16px; box-shadow:0 12px 32px rgba(0,0,0,0.18); max-width:370px; width:92%; margin:auto; display:flex; flex-direction:column; align-items:center;">
    <div style="width:100%; text-align:center;">
      <img src="/public/assets/user-login.png" alt="Reset" style="width:56px; height:56px; margin-bottom:12px; border-radius:50%; box-shadow:0 2px 8px #007bff22;">
      <h2 style="margin-bottom:10px; color:#007bff; font-size:1.5rem; font-weight:700;">Forgot Password?</h2>
      <p style="color:#555; font-size:1rem; margin-bottom:18px;">Enter your registered email to receive a password reset link.</p>
    </div>
    <form id="reset-form" method="POST" action="/request-otp" autocomplete="on" style="width:100%;">
      <label for="reset-email" style="display:block; margin-bottom:8px; color:#333; font-weight:600; text-align:left;">Email Address</label>
      <input type="email" id="reset-email" name="email" required placeholder="your@email.com" style="width:100%; padding:12px; border-radius:8px; border:1.5px solid #b3e5fc; margin-bottom:18px; font-size:1.08rem; background:#f8fafc; color:#083235;">
      <button type="submit" style="background:#007bff; color:#fff; border:none; border-radius:8px; padding:12px 0; width:100%; font-weight:700; font-size:1.08rem; box-shadow:0 2px 8px #b3e5fc44; transition:background 0.2s;">Send Reset Link</button>
    </form>
    <button id="close-modal" style="margin-top:14px; background:none; border:none; color:#007bff; font-size:1rem; cursor:pointer; font-weight:600;">Cancel</button>
  </div>
</div>

<script>
  document.getElementById('forgot-password-link').onclick = function(e) {
    e.preventDefault();
    var modal = document.getElementById('reset-modal');
    modal.style.display = 'flex';
    modal.style.alignItems = 'center';
    modal.style.justifyContent = 'center';
  };
  document.getElementById('close-modal').onclick = function() {
    document.getElementById('reset-modal').style.display = 'none';
  };
  document.getElementById('reset-form').onsubmit = function() {
    var email = document.getElementById('reset-email').value;
    if (!email) {
      document.getElementById('reset-email').focus();
      return false;
    }
    return true;
  };
</script>
  </form>
</div>
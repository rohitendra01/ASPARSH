<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
  <title>Authentication</title>
  <link rel="stylesheet" href="/public/css/users/auth.css">
  <%- include('../partials/csrf-meta') %>
</head>

<body>
  <link rel="stylesheet" href="/css/users/auth.css">

  <div class="auth-wrapper">
    <div class="auth-container">
      <form class="login-form" method="POST" action="/login">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <h2 class="auth-title">Sign In</h2>
        <% if (error_msg) { %>
          <div class="alert alert-danger">
            <%= error_msg %>
          </div>
          <% } %>
            <div class="auth-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>"
                required placeholder="Enter your email" class="auth-input <%= error_msg ? 'input-error' : '' %>">
            </div>
            <div class="auth-group">
              <label for="password">Password</label>
              <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="Enter your password"
                class="auth-input <%= error_msg ? 'input-error' : '' %>">
            </div>
            <input type="hidden" name="returnTo" id="returnToInput"
              value="<%= typeof returnTo !== 'undefined' ? returnTo : (typeof req !== 'undefined' && req.headers.referer ? req.headers.referer : '/') %>">

            <p style="text-align: right; margin-top: -10px; margin-bottom: 20px;">
              <a href="#" id="forgot-password-link" class="auth-link" style="font-size: 0.9em;">Forgot Password?</a>
            </p>

            <button type="submit" class="auth-btn">Login to Dashboard</button>

            <p class="auth-link-text">Don't have an account? <a href="/register" class="auth-link">Register</a></p>
      </form>
    </div>
  </div>

  <div id="reset-modal" class="modal-overlay">
    <div class="modal-content">
      <img src="/assets/user-login.png" alt="Reset" class="modal-icon">
      <h2 class="modal-title">Forgot Password?</h2>
      <p class="modal-desc">Enter your registered email to receive a password reset link.</p>

      <form id="reset-form" method="POST" action="/request-otp" autocomplete="on" style="width:100%;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="auth-group">
          <label for="reset-email" class="auth-label">Email Address</label>
          <input type="email" id="reset-email" name="email" value="<%= typeof resetEmail !== 'undefined' ? resetEmail : '' %>" required placeholder="your@email.com" class="auth-input">
        </div>
        <button type="submit" class="auth-btn">Send Reset Link</button>
      </form>
      <button id="close-modal" class="modal-cancel-btn">Cancel</button>
    </div>
  </div>

  <script>
    window.addEventListener('DOMContentLoaded', function () {
      var returnToInput = document.getElementById('returnToInput');
      var referrer = document.referrer;
      if (!referrer) return;

      try {
        var referrerUrl = new URL(referrer);
        if (referrerUrl.origin === window.location.origin && referrerUrl.pathname.indexOf('/login') !== 0) {
          returnToInput.value = referrerUrl.pathname + referrerUrl.search + referrerUrl.hash;
        }
      } catch (error) {
        returnToInput.value = '/';
      }
    });

    document.getElementById('forgot-password-link').onclick = function (e) {
      e.preventDefault();
      var modal = document.getElementById('reset-modal');
      modal.style.display = 'flex';
    };

    document.getElementById('close-modal').onclick = function () {
      document.getElementById('reset-modal').style.display = 'none';
    };

    document.getElementById('reset-form').onsubmit = function () {
      var email = document.getElementById('reset-email').value;
      if (!email) {
        document.getElementById('reset-email').focus();
        return false;
      }
      return true;
    };
  </script>
  <%- include('../partials/session-heartbeat') %>
</body>

</html>

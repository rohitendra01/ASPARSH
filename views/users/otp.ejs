<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
  <title>Authentication</title>
  <link rel="stylesheet" href="/public/css/users/auth.css">
  <%- include('../partials/csrf-meta') %>
</head>

<body>
  <link rel="stylesheet" href="/css/users/auth.css">

  <div class="auth-wrapper">
    <div class="otp-modal">
      <h2 class="modal-title" style="margin-bottom: 8px;">OTP Verification</h2>
      <p class="modal-desc" style="margin-bottom: 24px;">Enter the 6-digit OTP sent to your email.</p>

      <form method="POST" action="/verify-otp" style="width: 100%;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="email" value="<%= email %>">
        <div class="auth-group">
          <input type="text" name="otp" class="auth-input otp-input" maxlength="6" pattern="\d{6}" required
            placeholder="••••••">
        </div>
        <button type="submit" class="auth-btn" style="margin-bottom: 12px;">Verify OTP</button>
      </form>

      <form method="POST" action="/resend-otp" style="width:100%;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="email" value="<%= email %>">
        <button type="submit" class="auth-btn btn-secondary">Resend OTP</button>
      </form>
    </div>
  </div>
  <%- include('../partials/session-heartbeat') %>
</body>

</html>

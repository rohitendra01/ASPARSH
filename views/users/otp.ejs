<style>
  .otp-modal {
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 16px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
    max-width: 370px;
    width: 92%;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .otp-modal h2 {
    color: #007bff;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .otp-modal p {
    color: #555;
    font-size: 1rem;
    margin-bottom: 18px;
  }
  .otp-modal input[type="text"] {
    width: 100%;
    padding: 12px;
    border-radius: 8px;
    border: 1.5px solid #b3e5fc;
    margin-bottom: 18px;
    font-size: 1.08rem;
    background: #f8fafc;
    color: #083235;
    text-align: center;
    letter-spacing: 0.3em;
  }
  .otp-modal button {
    background: #007bff;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 12px 0;
    width: 100%;
    font-weight: 700;
    font-size: 1.08rem;
    box-shadow: 0 2px 8px #b3e5fc44;
    transition: background 0.2s;
    margin-bottom: 8px;
  }
</style>
<div class="otp-modal">
  <h2>OTP Verification</h2>
  <p>Enter the 6-digit OTP sent to your email.</p>
  <form method="POST" action="/verify-otp">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="email" value="<%= email %>">
    <input type="text" name="otp" maxlength="6" pattern="\d{6}" required placeholder="Enter OTP">
    <button type="submit">Verify OTP</button>
  </form>
  <form method="POST" action="/resend-otp" style="width:100%;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="email" value="<%= email %>">
    <button type="submit" style="background:#f8fafc; color:#007bff; border:1.5px solid #b3e5fc;">Resend OTP</button>
  </form>
</div>

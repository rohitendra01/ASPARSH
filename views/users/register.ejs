<style>


body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    background-color: #f0f2f5; 
}

.register-container {
    background-color: #ffffff; /* White background for the form container */
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1); /* Soft shadow */
    width: 100%;
    max-width: 400px;
    box-sizing: border-box;
    text-align: center;
}

.register-title {
    font-size: 2em;
    color: #333333;
    margin-bottom: 30px;
    font-weight: 600;
}

.register-group {
    margin-bottom: 20px;
    text-align: left;
}

.register-group label {
    display: block;
    margin-bottom: 8px;
    color: #555555;
    font-weight: 500;
}

.register-group input[type="text"],
.register-group input[type="email"],
.register-group input[type="password"] {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    box-sizing: border-box;
    font-size: 1em;
    color: #333333;
    transition: border-color 0.3s ease;
}

.register-group input[type="text"]::placeholder,
.register-group input[type="email"]::placeholder,
.register-group input[type="password"]::placeholder {
    color: #aaaaaa;
}

.register-group input[type="text"]:focus,
.register-group input[type="email"]:focus,
.register-group input[type="password"]:focus {
    border-color: #007bff; /* Highlight on focus */
    outline: none;
}

.register-btn {
    background-color: #007bff;
    color: #ffffff;
    padding: 15px 25px;
    border: none;
    border-radius: 8px;
    font-size: 1.1em;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    width: 100%;
    margin-top: 20px;
    font-weight: 600;
}

.register-btn:hover {
    background-color: #0056b3;
    transform: translateY(-2px);
}

.register-login-link {
    margin-top: 25px;
    color: #666666;
    font-size: 0.95em;
}

.register-login-link a {
    color: #007bff;
    text-decoration: none;
    font-weight: 500;
}

.register-login-link a:hover {
    text-decoration: underline;
}
</style>
<div class="register-container">
  <form class="register-form" method="POST" action="/register">
    <h2 class="register-title">Create Account</h2>
    <div class="register-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required placeholder="Enter your name">
    </div>
    <div class="register-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required placeholder="Enter your email">
    </div>
    <div class="register-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required placeholder="Create a password">
    </div>
    <div class="register-group">
      <label for="confirm">Confirm Password</label>
      <input type="password" id="confirm" name="confirm" required placeholder="Confirm your password">
    </div>
    <button type="submit" class="register-btn">Register</button>
    <p class="register-login-link">Already have an account? <a href="/login">Sign In</a></p>
  </form>
</div>
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
  <title>Authentication</title>
  <link rel="stylesheet" href="/public/css/users/auth.css">
</head>

<body>
  <link rel="stylesheet" href="/css/users/auth.css">

  <div class="auth-wrapper">
    <div class="auth-container">
      <form class="register-form" method="POST" action="/register">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <h2 class="auth-title">Create Account</h2>

        <% if (error_msg && error_msg.length> 0) { %>
          <div class="alert alert-danger"
            style="margin-bottom: 15px; padding: 10px; background-color: #fee2e2; color: #991b1b; border-radius: 6px;">
            <%= error_msg %>
          </div>
          <% } %>

            <div class="auth-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" value="<%= typeof name !== 'undefined' ? name : '' %>" required
                placeholder="Enter your name"
                class="auth-input <%= fieldErrors.name ? 'input-error' : fieldWarnings?.name ? 'input-warning' : '' %>">
              <small style="color:#888; display:block; margin-top:4px; font-size:0.8rem; text-align:left;">If left
                blank,
                username auto-creates from email.</small>
              <% if (fieldErrors.name) { %>
                <div class="alert alert-danger" style="margin-top:8px;">
                  <%= fieldErrors.name %>
                </div>
                <% } else if (fieldWarnings?.name) { %>
                  <div class="alert alert-warning" style="margin-top:8px;">
                    <%= fieldWarnings.name %>
                  </div>
                  <% } %>
            </div>

            <div class="auth-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>"
                required placeholder="Enter your email"
                class="auth-input <%= fieldErrors.email ? 'input-error' : fieldWarnings?.email ? 'input-warning' : '' %>">
              <% if (fieldErrors.email) { %>
                <div class="alert alert-danger" style="margin-top:8px;">
                  <%= fieldErrors.email %>
                </div>
                <% } else if (fieldWarnings?.email) { %>
                  <div class="alert alert-warning" style="margin-top:8px;">
                    <%= fieldWarnings.email %>
                  </div>
                  <% } %>
            </div>

            <div class="auth-group">
              <label for="password">Password</label>
              <input type="password" id="password" name="password" required placeholder="Create a password"
                class="auth-input <%= fieldErrors.password ? 'input-error' : fieldWarnings?.password ? 'input-warning' : '' %>">
              <% if (fieldErrors.password) { %>
                <div class="alert alert-danger" style="margin-top:8px;">
                  <%= fieldErrors.password %>
                </div>
                <% } else if (fieldWarnings?.password) { %>
                  <div class="alert alert-warning" style="margin-top:8px;">
                    <%= fieldWarnings.password %>
                  </div>
                  <% } %>
            </div>

            <div class="auth-group">
              <label for="confirmPassword">Confirm Password</label>
              <input type="password" id="confirmPassword" name="confirmPassword" required
                placeholder="Confirm your password"
                class="auth-input <%= fieldErrors.confirmPassword ? 'input-error' : fieldWarnings?.confirmPassword ? 'input-warning' : '' %>">
              <% if (fieldErrors.confirmPassword) { %>
                <div class="alert alert-danger" style="margin-top:8px;">
                  <%= fieldErrors.confirmPassword %>
                </div>
                <% } else if (fieldWarnings?.confirmPassword) { %>
                  <div class="alert alert-warning" style="margin-top:8px;">
                    <%= fieldWarnings.confirmPassword %>
                  </div>
                  <% } %>
            </div>

            <button type="submit" class="auth-btn">Register Account</button>
            <p class="auth-link-text">
              Already have an account? <a href="/login" class="auth-link">Sign In</a>
            </p>
      </form>
    </div>
  </div>
</body>

</html>
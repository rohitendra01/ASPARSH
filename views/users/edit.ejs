<% layout('layouts/dashboard-boilerplate') %>
  <link rel="stylesheet" href="/css/users/edit.css">

  <div class="admin-profile-container">
    <% const userSlugSegment=(user && user.slug) ? '/' + encodeURIComponent(user.slug) : '' ; %>
      <form action="/dashboard<%= userSlugSegment %>/user/edit/<%= encodeURIComponent(user.slug) %>" method="POST"
        enctype="multipart/form-data" class="admin-profile-card">
        <%- include('../partials/csrf-input') %>
          <div class="admin-profile-header">
            <div class="avatar-wrapper">
              <img src="<%= user.image ? user.image : '/assets/user-login.png' %>" alt="Admin Avatar"
                class="admin-avatar">
              <label class="upload-label">
                <input type="file" id="avatarInput" name="image" accept="image/*" class="form-control" style="display:none;">
                <span class="upload-btn">Change Avatar</span>
              </label>
            </div>
          </div>
          <div class="form-group">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" value="<%= user.username %>" class="form-control" required>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" value="<%= user.email %>" class="form-control" required>
          </div>
          <div class="form-group">
            <label for="password">New Password</label>
            <input type="password" id="password" name="password" class="form-control"
              minlength="12" autocomplete="new-password" placeholder="Leave blank to keep current">
            <% if (passwordPolicy) { %>
              <small style="display:block; margin-top:6px; color:#666;"><%= passwordPolicy %></small>
            <% } %>
          </div>
          <div class="form-group">
            <label for="passwordConfirm">Confirm New Password</label>
            <input type="password" id="passwordConfirm" name="passwordConfirm" class="form-control"
              minlength="12" autocomplete="new-password" placeholder="Confirm new password">
          </div>
          <button type="submit" class="save-btn">Save Changes</button>
      </form>
  </div>

  <script>
    // --- Client-Side Image Compression ---
    document.addEventListener('DOMContentLoaded', () => {
        const imageInput = document.getElementById('avatarInput');

        if (imageInput) {
            imageInput.addEventListener('change', async function (e) {
                const file = e.target.files[0];
                if (!file) return;

                const maxSizeInBytes = 3 * 1024 * 1024; // 3MB

                if (file.size > maxSizeInBytes) {
                    const btn = document.querySelector('.upload-btn');
                    const originalText = btn ? btn.innerText : '';
                    if (btn) btn.innerText = 'Compressing... ⏳';

                    try {
                        const compressedFile = await compressImage(file);

                        const dataTransfer = new DataTransfer();
                        dataTransfer.items.add(compressedFile);
                        e.target.files = dataTransfer.files;

                        if (btn) btn.innerText = 'Compressed! ✅';
                        setTimeout(() => {
                            if (btn) btn.innerText = originalText || 'Change Avatar';
                        }, 3000);

                    } catch (err) {
                        console.error('Client-side compression failed:', err);
                        alert('Image too large and compression failed.');
                        e.target.value = '';
                        if (btn) btn.innerText = originalText || 'Change Avatar';
                    }
                }
            });
        }

        function compressImage(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = event => {
                    const img = new Image();
                    img.src = event.target.result;
                    img.onload = () => {
                        const canvas = document.createElement('canvas');
                        const ctx = canvas.getContext('2d');
                        const MAX_WIDTH = 1200; // Avatars don't need to be huge
                        const MAX_HEIGHT = 1200;
                        let width = img.width;
                        let height = img.height;

                        if (width > height) {
                            if (width > MAX_WIDTH) {
                                height *= MAX_WIDTH / width;
                                width = MAX_WIDTH;
                            }
                        } else {
                            if (height > MAX_HEIGHT) {
                                width *= MAX_HEIGHT / height;
                                height = MAX_HEIGHT;
                            }
                        }

                        canvas.width = width;
                        canvas.height = height;
                        ctx.drawImage(img, 0, 0, width, height);

                        canvas.toBlob((blob) => {
                            if (!blob) return reject(new Error('Canvas empty'));
                            const newFile = new File([blob], file.name.replace(/\.[^/.]+$/, "") + "_compressed.jpg", {
                                type: 'image/jpeg',
                                lastModified: Date.now()
                            });
                            resolve(newFile);
                        }, 'image/jpeg', 0.80);
                    };
                    img.onerror = error => reject(error);
                };
                reader.onerror = error => reject(error);
            });
        }
    });
  </script>

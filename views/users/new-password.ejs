<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
  <title>Authentication</title>
  <link rel="stylesheet" href="/public/css/users/auth.css">
  <%- include('../partials/csrf-meta') %>
</head>

<body>
  <link rel="stylesheet" href="/css/users/auth.css">

  <div class="auth-wrapper">
    <div class="reset-modal">
      <h2 class="auth-title">Set New Password</h2>
      <% if (error_msg) { %>
        <div class="alert alert-danger">
          <%= error_msg %>
        </div>
      <% } %>
      <form method="POST" action="/reset-password-otp" style="width: 100%;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="email" value="<%= email %>">
        <div class="auth-group">
          <label for="password">New Password</label>
          <input type="password" name="password" id="password" class="auth-input" required minlength="12" autocomplete="new-password"
            placeholder="Enter new password">
          <% if (passwordPolicy) { %>
            <small style="color:#888; display:block; margin-top:4px; font-size:0.8rem; text-align:left;"><%= passwordPolicy %></small>
          <% } %>
        </div>
        <div class="auth-group">
          <label for="confirmPassword">Confirm New Password</label>
          <input type="password" name="confirmPassword" id="confirmPassword" class="auth-input" required minlength="12" autocomplete="new-password"
            placeholder="Confirm new password">
        </div>
        <button type="submit" class="auth-btn">Reset Password</button>
      </form>
    </div>
  </div>
  <%- include('../partials/session-heartbeat') %>
</body>

</html>

<style>
  .reset-modal {
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 16px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
    max-width: 370px;
    width: 92%;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .reset-modal h2 {
    color: #007bff;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .reset-modal input[type="password"] {
    width: 100%;
    padding: 12px;
    border-radius: 8px;
    border: 1.5px solid #b3e5fc;
    margin-bottom: 18px;
    font-size: 1.08rem;
    background: #f8fafc;
    color: #083235;
  }
  .reset-modal button {
    background: #007bff;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 12px 0;
    width: 100%;
    font-weight: 700;
    font-size: 1.08rem;
    box-shadow: 0 2px 8px #b3e5fc44;
    transition: background 0.2s;
    margin-bottom: 8px;
  }
</style>
<div class="reset-modal">
  <h2>Set New Password</h2>
  <form method="POST" action="/reset-password-otp">
    <input type="hidden" name="email" value="<%= email %>">
    <input type="password" name="password" required placeholder="Enter new password">
    <button type="submit">Reset Password</button>
  </form>
</div>

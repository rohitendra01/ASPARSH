<% layout('layouts/dashboard-boilerplate') %>

<div class="admin-profile-container">
  <div class="admin-profile-card">
    <div class="admin-profile-header">
      <img src="<%= user.image ? user.image : '/assets/user-login.png' %>" alt="Admin Avatar" class="admin-avatar">
      <h2 class="admin-username"><%= user.username %></h2>
      <p class="admin-email"><%= user.email %></p>
    </div>
    <div class="admin-profile-actions">
      <a href="/dashboard/<%= user.slug %>/user/edit/<%= user.slug %>" class="btn btn-primary admin-edit-btn">Edit Profile</a>
    </div>
    </div>
  </div>
</div>

<style>
.admin-profile-container {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  min-height: 80vh;
  padding: 2rem 1rem;
}
.admin-profile-card {
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 6px 24px rgba(0,0,0,0.10);
  padding: 2.5rem 2rem 2rem 2rem;
  max-width: 420px;
  width: 100%;
  text-align: center;
}
.admin-profile-header {
  margin-bottom: 1.5rem;
}
.admin-avatar {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  object-fit: cover;
  margin-bottom: 1rem;
  box-shadow: 0 2px 8px #007bff22;
}
.admin-username {
  font-size: 1.5rem;
  font-weight: 700;
  color: #222;
  margin-bottom: 0.3rem;
}
.admin-email {
  color: #007bff;
  font-size: 1.08rem;
  margin-bottom: 0.5rem;
}

.admin-profile-actions {
  margin-top: 1.5rem;
  display: flex;
  justify-content: center;
  align-items: center;
}

.admin-edit-btn {
  background-color: #007bff;
  color: #fff;
  border: none;
  padding: 0.7rem 2rem;
  border-radius: 6px;
  font-size: 1rem;
  font-weight: 600;
  transition: background 0.2s, box-shadow 0.2s;
  box-shadow: 0 2px 8px #007bff22;
  cursor: pointer;
  text-decoration: none;
  outline: none;
}

.admin-edit-btn:hover,
.admin-edit-btn:focus {
  background-color: #0056b3;
  box-shadow: 0 4px 16px #007bff33;
  color: #fff;
  text-decoration: none;
}
<% layout('layouts/dashboard-boilerplate') %>
  <link rel="stylesheet" href="/css/users/view.css">

  <div class="user-ecosystem-layout">

    <aside class="admin-profile-sidebar">
      <div class="admin-profile-card">
        <div class="admin-profile-header">
          <div class="avatar-wrapper" style="position: relative; display: inline-block;">
            <img src="<%= user.image ? user.image : '/assets/user-login.png' %>" alt="Admin Avatar" class="admin-avatar"
              id="avatarImg">

            <div id="avatarPreview" class="avatar-preview-box">
              <img src="<%= user.image ? user.image : '/assets/user-login.png' %>" alt="Admin Avatar Preview"
                class="avatar-preview-img">
            </div>
          </div>

          <div class="profile-info-wrapper">
            <h2 class="admin-username">
              <%= user.username %>
            </h2>
            <p class="admin-email" title="<%= user.email %>">
              <%= user.email %>
            </p>
          </div>
        </div>

        <div class="admin-profile-actions">
          <% const userSlugSegment=(user && user.slug) ? '/' + encodeURIComponent(user.slug) : '' ; %>
            <button type="button" class="admin-edit-btn"
              onclick="window.location.href='/dashboard<%= userSlugSegment %>/user/edit/<%= encodeURIComponent(user.slug) %>'">
              Edit Profile
            </button>

            <form action="/logout" method="POST" class="admin-logout-form" style="width: 100%;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="admin-logout-btn">Logout</button>
            </form>
        </div>
      </div>
    </aside>

    <main class="admin-stats-main">
      <div class="stats-header">
        <h2>Ecosystem Breakdown</h2>
        <p>Performance and asset distribution across all managed profiles.</p>
      </div>

      <div class="eco-kpi-grid">

        <div class="eco-kpi-card">
          <div class="kpi-icon-wrapper blue">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
              </path>
            </svg>
          </div>
          <div class="kpi-content">
            <h3 title="Managed Profiles">Managed Profiles</h3>
            <p class="kpi-number" title="<%= totalProfiles || 0 %>">
              <%= Number(totalProfiles || 0).toLocaleString() %>
            </p>
          </div>
        </div>

        <div class="eco-kpi-card">
          <div class="kpi-icon-wrapper purple">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
              </path>
            </svg>
          </div>
          <div class="kpi-content">
            <h3 title="Total Digital Assets">Total Digital Assets</h3>
            <p class="kpi-number" title="<%= totalManagedAssets || 0 %>">
              <%= Number(totalManagedAssets || 0).toLocaleString() %>
            </p>
          </div>
        </div>

      </div>

      <div class="eco-table-container">
        <% if (ecosystemStats && ecosystemStats.length> 0) { %>
          <% const slugSegment = (currentUser && currentUser.slug) ? '/' + encodeURIComponent(currentUser.slug) : '' ; %>

            <table class="eco-table">
              <thead>
                <tr>
                  <th>Profile Name</th>
                  <th>Category</th>
                  <th class="center-col">Portfolios</th>
                  <th class="center-col">Hotels</th>
                  <th class="center-col">V-Cards</th>
                  <th class="center-col">Reviews</th>
                </tr>
              </thead>
              <tbody>
                <% ecosystemStats.forEach(stat=> { %>
                  <a href="/dashboard<%= slugSegment %>/profiles/<%= encodeURIComponent(stat.slug) %>"
                    class="action-icon-btn" title="View Profile" onclick="event.stopPropagation();"
                    style="color: #6366f1; transition: color 0.2s;">
                    <tr style="cursor: pointer;"
                      onclick="window.location.href='/dashboard<%= slugSegment %>/profiles/<%= encodeURIComponent(stat.slug) %>'">

                      <td class="primary-cell">
                        <a href="/dashboard<%= slugSegment %>/profiles/<%= encodeURIComponent(stat.slug) %>"
                          style="text-decoration: none; color: inherit; display: block;">
                          <strong title="<%= stat.name %>">
                            <%= stat.name %>
                          </strong>
                          <span class="cell-subtext">/<%= stat.slug %></span>
                        </a>
                      </td>

                      <td>
                        <span class="category-badge">
                          <%= stat.category %>
                        </span>
                      </td>
                      <td class="center-col">
                        <%= stat.portfolioCount %>
                      </td>
                      <td class="center-col">
                        <%= stat.hotelCount %>
                      </td>
                      <td class="center-col">
                        <%= stat.vcardCount %>
                      </td>
                      <td class="center-col">
                        <%= stat.reviewCount %>
                      </td>



                    </tr>
                  </a>
                  <% }) %>
              </tbody>
            </table>
            <% } else { %>
              <div class="empty-state">
                <svg style="width: 54px; height: 54px; color: #cbd5e1; margin-bottom: 1rem;" fill="none"
                  stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4">
                  </path>
                </svg>
                <p style="font-size: 0.95rem; font-weight: 500;">No profiles found. Create a profile to start tracking
                  your ecosystem.</p>
              </div>
              <% } %>
      </div>
    </main>
  </div>
  <script>
    const avatarImg = document.getElementById('avatarImg');
    const avatarPreview = document.getElementById('avatarPreview');

    if (avatarImg && avatarPreview) {
      avatarImg.addEventListener('mouseenter', function () {
        if (window.innerWidth > 992) avatarPreview.style.display = 'block';
      });
      avatarImg.addEventListener('mouseleave', function () {
        setTimeout(function () {
          if (!avatarPreview.matches(':hover')) {
            avatarPreview.style.display = 'none';
          }
        }, 100);
      });
      avatarPreview.addEventListener('mouseleave', function () {
        avatarPreview.style.display = 'none';
      });
    }
  </script>
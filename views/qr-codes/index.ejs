<% layout('layouts/dashboard-boilerplate') -%>
  <% block('styles').append('<link rel="stylesheet" href="/css/qr-codes/index.css" />') %>

<%
  // 1. Safely extract existing QR Codes
  var list = [];
  if (typeof qrCodes !== 'undefined' && qrCodes) {
    list = qrCodes;
  }
  
  // 2. Safely extract User Slug for API Routes
  var safeUserSlug = '';
  if (typeof user !== 'undefined' && user && user.slug) {
    safeUserSlug = user.slug;
  }
  
  // 3. Safely extract CSRF Token (Crucial for fixing the "Server Error" on bulk actions)
  var safeCsrf = '';
  if (typeof csrfToken !== 'undefined' && csrfToken) {
    safeCsrf = csrfToken;
  } else if (typeof req !== 'undefined' && typeof req.csrfToken === 'function') {
    safeCsrf = req.csrfToken();
  }
%>

    <div class="page-container">

      <div class="page-header-row">
        <div class="page-header-text">
          <h1 class="page-title">Dynamic QR Codes</h1>
          <p class="page-subtitle">Generate, track, and manage redirectable QR codes in bulk.</p>
        </div>

        <div class="page-header-actions">
          <div class="search-wrapper">
            <input type="text" id="liveSearchInput" placeholder="Search batch name or ID..." onkeyup="filterQRCodes()">
          </div>

          <select id="statusFilter" class="status-dropdown" onchange="filterQRCodes()">
            <option value="ALL">All Statuses</option>
            <option value="LIVE">🟢 Live</option>
            <option value="INACTIVE">🔴 Inactive</option>
            <option value="EMPTY">⚪ Empty</option>
          </select>

          <button class="btn-primary" onclick="openBulkGenerateModal()">+ Generate QRs</button>
        </div>
      </div>

      <div class="quick-stats-row">
        <% if (list.length> 0) { %>
          <div class="stat-card">
            <span class="stat-value" id="totalCountDisplay">
              <%= list.length %>
            </span>
            <span class="stat-label">Total QR Codes</span>
          </div>

          <div class="bulk-actions-card" id="bulkActionsContainer" style="display: none;">
            <div class="bulk-info">
              <span id="selectedCount">0</span> selected
            </div>
            <div class="bulk-buttons">
              <button class="btn-secondary" onclick="bulkDownloadQRs()">⬇ Download Selected</button>
              <button class="btn-danger" onclick="bulkDeleteQRs()">🗑 Delete Selected</button>
              <button class="btn-text" onclick="deselectAll()">Cancel</button>
            </div>
          </div>
          <% } %>
      </div>

      <% if (list.length> 0) { %>
        <div class="select-all-row">
          <label class="custom-checkbox">
            <input type="checkbox" id="selectAllCheckbox" onchange="toggleSelectAll(this)">
            <span class="checkmark"></span>
            <span class="checkbox-label">Select All Visible</span>
          </label>
        </div>
        <% } %>

          <div class="entity-list-container">
            <% if (list.length> 0) { %>
              <div class="compact-grid" id="entityGrid">

                <% list.forEach(function(qr) { var cTitle=qr.batchName || qr.shortId; var cSearchTerm=(cTitle + ' ' +
                  qr.shortId).toLowerCase(); %>

                  <div class="compact-card entity-card qr-card" data-search-term="<%= cSearchTerm %>"
                    data-status="<%= qr.status %>" data-id="<%= qr._id %>">

                    <label class="custom-checkbox card-checkbox" onclick="event.stopPropagation()">
                      <input type="checkbox" class="qr-select-checkbox" value="<%= qr._id %>"
                        data-shortid="<%= qr.shortId %>" onchange="updateBulkActionState()">
                      <span class="checkmark"></span>
                    </label>

                    <div class="card-thumbnail qr-thumbnail" onclick="openQrPanel('<%= qr._id %>')">
                      <img class="qr-thumb-img"
                        src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='64' height='64' fill='%23e2e8f0'><rect width='64' height='64'/></svg>"
                        data-id="<%= qr._id %>" alt="QR Code" loading="lazy">
                    </div>

                    <div class="card-info" onclick="openQrPanel('<%= qr._id %>')">
                      <div class="info-header">
                        <h3 class="card-title text-truncate" title="<%= cTitle %>">
                          <%= cTitle %>
                        </h3>
                        <span class="badge status-badge-<%= qr.status %>">
                          <%= qr.status %>
                        </span>
                      </div>

                      <div class="info-meta-grid">
                        <span class="meta-item text-truncate">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                          </svg>
                          /q/<%= qr.shortId %>
                        </span>
                        <span class="meta-item">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                          </svg>
                          <%= qr.scanCount || 0 %> scans
                        </span>
                      </div>
                    </div>

                    <div class="card-actions">
                      <button type="button" class="action-icon-btn edit-btn" onclick="openQrPanel('<%= qr._id %>')"
                        title="Manage QR">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 20h9"></path>
                          <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                        </svg>
                      </button>
                    </div>

                  </div>
                  <% }); %>

              </div>

              <% } else { %>

                <div class="empty-state">
                  <div class="empty-icon">🔲</div>
                  <h2>No QR codes found</h2>
                  <p>Generate your first batch of dynamic QR codes to start linking physical objects to digital
                    experiences.</p>
                  <button class="btn-primary" onclick="openBulkGenerateModal()">+ Generate QR Codes</button>
                </div>

                <% } %>
          </div>
    </div>

    <div class="modal-overlay" id="bulkGenerateModal">
      <div class="modal-card">
        <div class="modal-header">
          <h3>⚡ Generate QR Codes</h3>
          <button class="close-modal-btn" onclick="closeBulkGenerateModal()">✕</button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label for="genCount">Number of QR Codes</label>
            <input type="number" id="genCount" class="form-control" min="1" max="100" placeholder="e.g. 25" value="1">
          </div>
          <div class="form-group">
            <label for="genBatchName">Batch Name <span class="text-muted">(Optional)</span></label>
            <input type="text" id="genBatchName" class="form-control" placeholder="e.g. Table Tents Q3">
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn-text" onclick="closeBulkGenerateModal()">Cancel</button>
          <button class="btn-primary" onclick="submitBulkGenerate()">Generate 🚀</button>
        </div>
      </div>
    </div>

    <div class="side-panel-overlay" id="qrSidePanelOverlay" onclick="closeQrPanel()"></div>
    <div class="side-panel" id="qrSidePanel">
      <div class="panel-header">
        <div class="panel-header-title">
          <span class="text-muted">MANAGE QR</span>
          <div class="panel-shortid" id="panelShortId">/q/---</div>
        </div>
        <button class="panel-close-btn" onclick="closeQrPanel()">✕</button>
      </div>

      <div class="panel-tabs">
        <button class="panel-tab active" onclick="switchPanelTab('manage', this)">Settings</button>
        <button class="panel-tab" onclick="switchPanelTab('analytics', this)">Analytics</button>
      </div>

      <div class="panel-body" id="panelBodyContent">
        <div class="panel-loader" id="panelLoader">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            class="spin">
            <line x1="12" y1="2" x2="12" y2="6"></line>
            <line x1="12" y1="18" x2="12" y2="22"></line>
            <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line>
            <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line>
            <line x1="2" y1="12" x2="6" y2="12"></line>
            <line x1="18" y1="12" x2="22" y2="12"></line>
            <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line>
            <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line>
          </svg>
          Loading data...
        </div>

        <div class="panel-section active" id="tabManage">
          <div class="panel-qr-preview">
            <img id="panelQrImg" src="" alt="QR Code">
            <a id="panelDownloadBtn" class="btn-secondary btn-sm" href="#" download="qr-code.png">⬇ Download Image</a>
          </div>

          <input type="hidden" id="panelQrId">
          <input type="hidden" id="globalCsrf" value="<%= safeCsrf %>">

          <div class="form-group">
            <label>Status</label>
            <select id="panelStatus" class="form-control">
              <option value="EMPTY">⚪ Empty (Inactive)</option>
              <option value="LIVE">🟢 Live (Active)</option>
              <option value="INACTIVE">🔴 Inactive (Paused)</option>
            </select>
          </div>

          <div class="form-group">
            <label>Destination URL</label>
            <input type="url" id="panelDestUrl" class="form-control" placeholder="https://example.com/menu">
          </div>

          <div class="form-group">
            <label>Batch Name / Title</label>
            <input type="text" id="panelBatchName" class="form-control" placeholder="Internal reference name">
          </div>

          <div class="form-group">
            <label>Auto-Expire Date <span class="text-muted">(Optional)</span></label>
            <input type="datetime-local" id="panelExpiry" class="form-control">
          </div>

          <div class="panel-actions-row">
            <button class="btn-primary w-100" onclick="saveQrSettings()" id="saveQrBtn">Save Changes</button>
            <button class="btn-danger w-100 mt-2" onclick="deleteSingleQr()">🗑 Delete Forever</button>
          </div>
        </div>

        <div class="panel-section" id="tabAnalytics">
          <div class="quick-stats-row">
            <div class="stat-card p-3">
              <span class="stat-value" id="statScans">0</span>
              <span class="stat-label">Total Scans</span>
            </div>
            <div class="stat-card p-3">
              <span class="stat-value" id="statLastScan" style="font-size: 1.2rem; line-height: 1.5;">—</span>
              <span class="stat-label">Last Scanned</span>
            </div>
          </div>

          <h4 style="margin-top: 1.5rem; margin-bottom: 0.5rem; font-family: var(--font-head); font-size: 1rem;">Recent
            Scan Log</h4>
          <div class="history-list" id="historyList">
          </div>
        </div>
      </div>
    </div>

    <script>
      const DASHBOARD_SLUG = '<%= safeUserSlug %>';
      // Retrieve the securely extracted CSRF token
      const CSRF_TOKEN = document.getElementById('globalCsrf').value;

      // ==========================================
      // LAZY LOADING QR IMAGES
      // ==========================================
      document.addEventListener('DOMContentLoaded', () => {
        const thumbs = document.querySelectorAll('.qr-thumb-img');
        if (!thumbs.length) return;

        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const img = entry.target;
              const id = img.dataset.id;
              obs.unobserve(img);

              fetch(`/dashboard/${DASHBOARD_SLUG}/qr-codes/${id}`)
                .then(res => res.json())
                .then(data => {
                  if (data.success && data.qrCodeImage) {
                    img.src = data.qrCodeImage;
                    img.closest('.qr-card').setAttribute('data-img-url', data.qrCodeImage);
                  }
                })
                .catch(e => console.error('Error loading QR image', e));
            }
          });
        }, { rootMargin: '100px' });

        thumbs.forEach(thumb => observer.observe(thumb));
      });

      // ==========================================
      // FILTERING & SEARCH
      // ==========================================
      function filterQRCodes() {
        const searchInput = document.getElementById('liveSearchInput').value.trim().toLowerCase();
        const statusFilter = document.getElementById('statusFilter').value;
        const cards = document.querySelectorAll('.entity-card');

        cards.forEach(card => {
          const searchTerm = card.getAttribute('data-search-term') || '';
          const cardStatus = card.getAttribute('data-status') || '';

          const matchesSearch = searchTerm.includes(searchInput);
          const matchesStatus = statusFilter === 'ALL' || cardStatus === statusFilter;

          if (matchesSearch && matchesStatus) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
            const cb = card.querySelector('.qr-select-checkbox');
            if (cb.checked) { cb.checked = false; }
          }
        });
        updateBulkActionState();
      }

      // ==========================================
      // BULK SELECTION LOGIC
      // ==========================================
      function toggleSelectAll(masterCheckbox) {
        const isChecked = masterCheckbox.checked;
        const cards = document.querySelectorAll('.entity-card');

        cards.forEach(card => {
          if (card.style.display !== 'none') {
            card.querySelector('.qr-select-checkbox').checked = isChecked;
          }
        });
        updateBulkActionState();
      }

      function updateBulkActionState() {
        const checkboxes = document.querySelectorAll('.qr-select-checkbox:checked');
        const bulkContainer = document.getElementById('bulkActionsContainer');
        const countDisplay = document.getElementById('selectedCount');
        const masterCheckbox = document.getElementById('selectAllCheckbox');

        if (checkboxes.length > 0) {
          bulkContainer.style.display = 'flex';
          countDisplay.textContent = checkboxes.length;
        } else {
          bulkContainer.style.display = 'none';
          if (masterCheckbox) masterCheckbox.checked = false;
        }
      }

      function deselectAll() {
        document.querySelectorAll('.qr-select-checkbox').forEach(cb => cb.checked = false);
        if (document.getElementById('selectAllCheckbox')) document.getElementById('selectAllCheckbox').checked = false;
        updateBulkActionState();
      }

      // ==========================================
      // BULK DOWNLOAD
      // ==========================================
      async function bulkDownloadQRs() {
        const checkboxes = document.querySelectorAll('.qr-select-checkbox:checked');
        if (checkboxes.length === 0) return;

        if (!confirm(`Are you sure you want to download ${checkboxes.length} QR codes? Your browser may ask for permission to download multiple files.`)) return;

        for (var i = 0; i < checkboxes.length; i++) {
          const cb = checkboxes[i];
          const card = cb.closest('.qr-card');
          const shortId = cb.getAttribute('data-shortid');
          let dataUrl = card.getAttribute('data-img-url');

          if (!dataUrl) {
            try {
              const res = await fetch(`/dashboard/${DASHBOARD_SLUG}/qr-codes/${cb.value}`);
              const data = await res.json();
              if (data.success && data.qrCodeImage) {
                dataUrl = data.qrCodeImage;
                card.setAttribute('data-img-url', dataUrl);
              }
            } catch (e) { console.error(e); }
          }

          if (dataUrl) {
            const a = document.createElement('a');
            a.href = dataUrl;
            a.download = `QR_${shortId}.png`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }
          await new Promise(r => setTimeout(r, 300));
        }
        deselectAll();
      }

      // ==========================================
      // BULK DELETE
      // ==========================================
      async function bulkDeleteQRs() {
        const checkboxes = document.querySelectorAll('.qr-select-checkbox:checked');
        if (checkboxes.length === 0) return;

        if (!confirm(`WARNING: You are about to permanently delete ${checkboxes.length} QR codes. This cannot be undone. Proceed?`)) return;

        const deletePromises = Array.from(checkboxes).map(cb => {
          return fetch(`/dashboard/${DASHBOARD_SLUG}/qr-codes/${cb.value}/delete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
            body: JSON.stringify({})
          });
        });

        try {
          await Promise.all(deletePromises);
          window.location.reload();
        } catch (e) {
          alert('An error occurred during bulk deletion. The page will reload.');
          window.location.reload();
        }
      }

      // ==========================================
      // BULK GENERATE MODAL
      // ==========================================
      function openBulkGenerateModal() {
        document.getElementById('bulkGenerateModal').classList.add('active');
      }

      function closeBulkGenerateModal() {
        document.getElementById('bulkGenerateModal').classList.remove('active');
      }

      async function submitBulkGenerate() {
        const count = parseInt(document.getElementById('genCount').value, 10) || 1;
        const batchName = document.getElementById('genBatchName').value.trim();

        try {
          const res = await fetch(`/dashboard/${DASHBOARD_SLUG}/qr-codes/bulk-generate`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
            body: JSON.stringify({ count, batchName })
          });
          const data = await res.json();
          if (data.success) {
            window.location.reload();
          } else {
            alert('Error: ' + (data.message || 'Unknown error'));
          }
        } catch (e) {
          alert('Server error. Please try again.');
        }
      }

      // ==========================================
      // SIDE PANEL (SINGLE QR MANAGE)
      // ==========================================
      function openQrPanel(id) {
        document.getElementById('qrSidePanelOverlay').classList.add('active');
        document.getElementById('qrSidePanel').classList.add('active');

        document.getElementById('panelLoader').style.display = 'flex';
        document.getElementById('tabManage').style.display = 'none';
        document.getElementById('tabAnalytics').style.display = 'none';
        switchPanelTab('manage', document.querySelector('.panel-tab'));

        fetch(`/dashboard/${DASHBOARD_SLUG}/qr-codes/${id}`)
          .then(res => res.json())
          .then(data => {
            if (!data.success) { alert('Failed to load QR'); return; }
            populateSidePanel(data);
          })
          .catch(e => {
            console.error(e);
            alert('Error loading QR data');
            closeQrPanel();
          });
      }

      function closeQrPanel() {
        document.getElementById('qrSidePanelOverlay').classList.remove('active');
        document.getElementById('qrSidePanel').classList.remove('active');
      }

      function switchPanelTab(tabId, btnElement) {
        document.querySelectorAll('.panel-tab').forEach(t => t.classList.remove('active'));
        btnElement.classList.add('active');

        document.getElementById('tabManage').style.display = tabId === 'manage' ? 'block' : 'none';
        document.getElementById('tabAnalytics').style.display = tabId === 'analytics' ? 'block' : 'none';
      }

      function populateSidePanel(data) {
        const { qr, qrCodeImage, history } = data;

        document.getElementById('panelLoader').style.display = 'none';
        document.getElementById('tabManage').style.display = 'block';

        document.getElementById('panelShortId').textContent = '/q/' + qr.shortId;
        document.getElementById('panelQrId').value = qr._id;
        document.getElementById('panelQrImg').src = qrCodeImage;
        document.getElementById('panelDownloadBtn').href = qrCodeImage;
        document.getElementById('panelDownloadBtn').download = `QR_${qr.shortId}.png`;

        document.getElementById('panelDestUrl').value = qr.destinationUrl || '';
        document.getElementById('panelBatchName').value = qr.batchName || '';
        document.getElementById('panelStatus').value = qr.status;

        if (qr.expiresAt) {
          const d = new Date(qr.expiresAt);
          const pad = n => String(n).padStart(2, '0');
          document.getElementById('panelExpiry').value = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
        } else {
          document.getElementById('panelExpiry').value = '';
        }

        document.getElementById('statScans').textContent = qr.scanCount || 0;
        document.getElementById('statLastScan').textContent = qr.lastScannedAt ? new Date(qr.lastScannedAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' }) : '—';

        const list = document.getElementById('historyList');
        if (history && history.length > 0) {
          list.innerHTML = history.map(h => `
        <div class="history-item">
          <span class="text-muted">${new Date(h.scannedAt).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' })}</span>
          <span style="font-family: monospace;">${h.ip || 'Unknown IP'}</span>
        </div>
      `).join('');
        } else {
          list.innerHTML = '<div class="text-muted text-center py-4">No scans recorded yet</div>';
        }
      }

      async function saveQrSettings() {
        const btn = document.getElementById('saveQrBtn');
        const originalText = btn.textContent;
        btn.textContent = 'Saving...';
        btn.disabled = true;

        const id = document.getElementById('panelQrId').value;
        const body = {
          destinationUrl: document.getElementById('panelDestUrl').value,
          batchName: document.getElementById('panelBatchName').value,
          status: document.getElementById('panelStatus').value,
          expiresAt: document.getElementById('panelExpiry').value
        };

        try {
          const res = await fetch(`/dashboard/${DASHBOARD_SLUG}/qr-codes/${id}/update`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
            body: JSON.stringify(body)
          });
          const data = await res.json();

          if (data.success) {
            btn.textContent = '✓ Saved Successfully';
            btn.style.background = '#10b981';
            setTimeout(() => { window.location.reload(); }, 600);
          } else {
            alert('Error: ' + (data.message || 'Unknown'));
            btn.textContent = originalText;
            btn.disabled = false;
          }
        } catch (e) {
          alert('Server error.');
          btn.textContent = originalText;
          btn.disabled = false;
        }
      }

      async function deleteSingleQr() {
        if (!confirm('Are you sure you want to delete this QR code? This cannot be undone.')) return;

        const id = document.getElementById('panelQrId').value;
        try {
          const res = await fetch(`/dashboard/${DASHBOARD_SLUG}/qr-codes/${id}/delete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
            body: JSON.stringify({})
          });
          const data = await res.json();
          if (data.success) {
            window.location.reload();
          } else {
            alert('Error: ' + data.message);
          }
        } catch (e) {
          alert('Server error.');
        }
      }
    </script>
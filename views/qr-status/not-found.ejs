<%- layout('layouts/boilerplate') %>
<style>
  .qr-status-page { min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 2rem; }
  .qr-status-icon { font-size: 5rem; margin-bottom: 1.5rem; }
  .qr-status-heading { font-size: 2rem; font-weight: 700; color: #1a1a2e; margin-bottom: 0.75rem; }
  .qr-status-sub { color: #6b7280; font-size: 1.1rem; max-width: 400px; margin: 0 auto 2rem; }
  .qr-status-badge { display: inline-block; padding: 0.4rem 1.2rem; border-radius: 50px; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; background: #f3f4f6; color: #6b7280; }
  .home-link { display: inline-block; margin-top: 1.5rem; padding: 0.75rem 2rem; background: linear-gradient(135deg, #7928CA, #FF0080); color: #fff; border-radius: 50px; text-decoration: none; font-weight: 600; }
</style>

<div class="qr-status-page">
  <div>
    <div class="qr-status-icon">❓</div>
    <h1 class="qr-status-heading">QR Code Not Found</h1>
    <p class="qr-status-sub">This QR code doesn't exist or may have been removed. Double-check the code and try again.</p>
    <span class="qr-status-badge">Error: 404</span>
    <br>
    <a href="/" class="home-link">Go Home</a>
  </div>
</div>

<%- layout('layouts/boilerplate') %>
<style>
  .qr-status-page { min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 2rem; }
  .qr-status-icon { font-size: 5rem; margin-bottom: 1.5rem; }
  .qr-status-heading { font-size: 2rem; font-weight: 700; color: #1a1a2e; margin-bottom: 0.75rem; }
  .qr-status-sub { color: #6b7280; font-size: 1.1rem; max-width: 400px; margin: 0 auto 2rem; }
  .qr-status-badge { display: inline-block; padding: 0.4rem 1.2rem; border-radius: 50px; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; background: #fef2f2; color: #dc2626; }
</style>

<div class="qr-status-page">
  <div>
    <div class="qr-status-icon">🚫</div>
    <h1 class="qr-status-heading">QR No Longer Active</h1>
    <p class="qr-status-sub">This QR code has been deactivated and is no longer available. Please contact the issuer for more information.</p>
    <span class="qr-status-badge">Status: Inactive</span>
  </div>
</div>

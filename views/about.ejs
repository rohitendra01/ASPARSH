<% layout('layouts/boilerplate') %>
<% block('styles').append(`<link rel="stylesheet" href="/css/asparsh/about.css" />`) %>
<main class="about-main">
    <section class="about-hero">
        <h1 class="about-tagline">Rewriting the Rules of Connection and Sharing</h1>
        <p class="about-intro">At Asparsh, we believe in transforming the way people connect and share. Our mission is to empower seamless, secure, and meaningful interactions for everyone.</p>
    </section>
    <section class="about-founders">
        <h2 class="about-founders-title">Message from Our Founders</h2>
        <div class="about-founders-cards">
            <div class="about-founder-card">
                <img src="/assets/founder1.jpg" alt="Founder 1" class="about-founder-image">
                <div class="about-founder-message">
                    <h3>Aryan Singh</h3>
                    <p>"We started Asparsh to make every connection count. Technology should bring people closer, not complicate their lives. Our platform is built to simplify, secure, and inspire new ways to share and grow together."</p>
                </div>
            </div>
            <div class="about-founder-card">
                <img src="/assets/founder2.jpg" alt="Founder 2" class="about-founder-image">
                <div class="about-founder-message">
                    <h3>Rohitendra Singh</h3>
                    <p>"At Asparsh, we are committed to innovation and user-centric design. Our goal is to create a space where everyone feels empowered to connect, share, and thrive. We are excited about the journey ahead and the impact we can make together."</p>
                </div>
            </div>
            <div class="about-founder-card">
                <img src="/assets/founder3.jpg" alt="Founder 3" class="about-founder-image">
                <div class="about-founder-message">
                    <h3>Irfan Shah</h3>
                    <p>"Asparsh is more than just a platform; it's a movement towards a more connected and compassionate world. We are dedicated to building tools that foster genuine relationships and meaningful interactions."</p>
                </div>
            </div>
        </div>
    </section>
</main>

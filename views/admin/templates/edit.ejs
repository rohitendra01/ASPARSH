<% layout('layouts/dashboard-boilerplate') %>
    <% block('styles').append('<link rel="stylesheet" href="/css/visiting-cards/index.css">') %>
        <% block('styles').append('<link rel="stylesheet" href="/css/dashboard/template-form.css">') %>

            <% const slugSegment=(typeof slug !=='undefined' && slug) ? '/' + encodeURIComponent(slug) : '' ; %>
            <%
              const _errMsg = (typeof query !== 'undefined' && query && query.error) ? query.error : (typeof error !== 'undefined' ? error : null);
              const _successMsg = (typeof query !== 'undefined' && query && query.success) ? query.success : null;
            %>
                <div class="page-container" style="max-width: 900px;">

                  <% if (_errMsg) { %>
                    <div style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;border-radius:10px;padding:.85rem 1.1rem;margin-bottom:1.2rem;font-size:.9rem;">⚠️ <%= _errMsg %></div>
                  <% } %>
                  <% if (_successMsg) { %>
                    <div style="background:#f0fdf4;border:1px solid #86efac;color:#15803d;border-radius:10px;padding:.85rem 1.1rem;margin-bottom:1.2rem;font-size:.9rem;">✅ <%= _successMsg %></div>
                  <% } %>

                    <div class="page-header-row">
                        <div class="page-header-text">
                            <h1 class="page-title">Edit Template: <%= template.name %></h1>
                        </div>
                    </div>

                    <form id="templateEditForm"
                        action="/dashboard<%= slugSegment %>/templates/<%= template._id %>?_method=PUT" method="POST"
                        enctype="multipart/form-data" class="wizard-form"
                        style="display: flex; flex-direction: column; gap: 1.5rem;">
                        <% if (typeof csrfToken !=='undefined' && csrfToken) { %>
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <% } %>
                                <input type="hidden" name="customFields" id="customFieldsJson">

                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                                    <label>
                                        <span style="display:block; margin-bottom: 0.5rem; font-weight: 600;">Template
                                            Display
                                            Name</span>
                                        <input type="text" name="name" value="<%= template.name %>" required
                                            style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px;">
                                    </label>
                                    <label>
                                        <span style="display:block; margin-bottom: 0.5rem; font-weight: 600;">Profession
                                            Category</span>
                                        <input type="text" name="category" value="<%= template.category %>"
                                            style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px;">
                                    </label>
                                </div>

                                <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">
                                    <label>
                                        <span style="display:block; margin-bottom: 0.5rem; font-weight: 600;">Thumbnail
                                            Image (Optional)</span>
                                        <input type="file" id="thumbnailInput" name="thumbnail" accept="image/*"
                                            style="width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px;">
                                        <% if (template.thumbnailUrl) { %>
                                            <div style="margin-top: 10px;">
                                                <p style="font-size: 0.85rem; margin-bottom: 5px;">Current Thumbnail:
                                                </p>
                                                <img src="<%= template.thumbnailUrl %>" alt="Current Thumbnail"
                                                    style="max-width: 150px; border-radius: 4px; border: 1px solid #e2e8f0;">
                                            </div>
                                            <% } %>
                                    </label>
                                </div>

                                <div
                                    style="margin-top: 1rem; padding: 1.5rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                                    <div
                                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                        <h3 style="font-family: var(--font-head); font-size: 1.1rem;">Custom Fields</h3>
                                        <button type="button" onclick="addField()" class="btn-secondary"
                                            style="background: #fff; border: 1px solid #cbd5e1; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer;">+
                                            Add Field</button>
                                    </div>
                                    <div id="fields-container"
                                        style="display: flex; flex-direction: column; gap: 1rem;">
                                    </div>
                                </div>

                                <div class="form-actions" style="display: flex; gap: 1rem; justify-content: space-between; align-items: center;">
                                    <!-- Left: danger action -->
                                    <button type="button" id="deleteDesignBtn" onclick="confirmDeleteTemplate()"
                                        style="padding:0.75rem 1.5rem; background:#fef2f2; color:#dc2626; border:1px solid #fecaca; border-radius:10px; font-size:0.9rem; font-weight:600; cursor:pointer; transition:background .2s;"
                                        onmouseover="this.style.background='#fee2e2'" onmouseout="this.style.background='#fef2f2'">
                                        🗑️ Delete Design
                                    </button>
                                    <!-- Right: save action -->
                                    <button type="submit" class="btn-primary" style="padding: 0.75rem 2rem;">💾 Update Design Schema</button>
                                </div>
                    </form>

                    <!-- Hidden DELETE form -->
                    <form id="deleteTemplateForm"
                          action="/dashboard<%= slugSegment %>/templates/<%= template._id %>/delete"
                          method="POST"
                          style="display:none;">
                        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <% } %>
                    </form>
                </div>

                <script>
                    function confirmDeleteTemplate() {
                        if (confirm('⚠️ Delete "<%= template.name %>"?\n\nThis action is permanent and cannot be undone.\nDesigns that still have vCards linked to them cannot be deleted.')) {
                            document.getElementById('deleteTemplateForm').submit();
                        }
                    }
                </script>

                <script>
                    const existingFields = <% - JSON.stringify(template.customFields || []) %>;
                    const container = document.getElementById('fields-container');
                    const form = document.getElementById('templateEditForm');
                    const jsonInput = document.getElementById('customFieldsJson');

                    function createFieldRow(data = {}) {
                        const row = document.createElement('div');
                        row.className = 'field-row';
                        row.style.cssText = "display: grid; grid-template-columns: 2fr 2fr 1.5fr auto auto; gap: 1rem; align-items: center; background: #fff; padding: 1rem; border: 1px solid #e2e8f0; border-radius: 8px;";

                        row.innerHTML = `
      <input type="text" class="f-name" value="${data.name || ''}" placeholder="Variable Name" style="padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 6px;">
      <input type="text" class="f-label" value="${data.label || ''}" placeholder="Display Label" style="padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 6px;">
      <select class="f-type" style="padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 6px;">
        <option value="text" ${data.type === 'text' ? 'selected' : ''}>Text (Short)</option>
        <option value="textarea" ${data.type === 'textarea' ? 'selected' : ''}>Text (Long)</option>
        <option value="color" ${data.type === 'color' ? 'selected' : ''}>Color Picker</option>
        <option value="url" ${data.type === 'url' ? 'selected' : ''}>URL Link</option>
        <option value="image" ${data.type === 'image' ? 'selected' : ''}>Image Upload</option>
      </select>
      <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem;">
        <input type="checkbox" class="f-required" ${data.required ? 'checked' : ''}> Required
      </label>
      <button type="button" onclick="this.parentElement.remove()" style="background: #fee2e2; color: #ef4444; border: none; padding: 0.5rem; border-radius: 6px; cursor: pointer;">🗑️</button>
    `;
                        return row;
                    }

                    function addField() { container.appendChild(createFieldRow()); }
                    existingFields.forEach(field => container.appendChild(createFieldRow(field)));

                    form.addEventListener('submit', function (e) {
                        const rows = document.querySelectorAll('.field-row');
                        const fieldsData = Array.from(rows).map(row => ({
                            name: row.querySelector('.f-name').value.trim(),
                            label: row.querySelector('.f-label').value.trim(),
                            type: row.querySelector('.f-type').value,
                            required: row.querySelector('.f-required').checked
                        }));
                        jsonInput.value = JSON.stringify(fieldsData);
                    });
                </script>

                <script>
                    // --- Client-Side Image Compression ---
                    document.addEventListener('DOMContentLoaded', () => {
                        const imageInput = document.getElementById('thumbnailInput');

                        if (imageInput) {
                            imageInput.addEventListener('change', async function (e) {
                                const file = e.target.files[0];
                                if (!file) return;

                                // Compress if larger than 3MB to safely stay under 7MB limit
                                const maxSizeInBytes = 7 * 1024 * 1024;

                                if (file.size > maxSizeInBytes) {
                                    const label = this.closest('label').querySelector('span');
                                    const originalLabel = label ? label.innerText : '';
                                    if (label) label.innerText = 'Compressing image, please wait... ⏳';

                                    try {
                                        const compressedFile = await compressImage(file);

                                        const dataTransfer = new DataTransfer();
                                        dataTransfer.items.add(compressedFile);
                                        e.target.files = dataTransfer.files;

                                        if (label) label.innerText = 'Image successfully compressed! ✅';
                                        setTimeout(() => {
                                            if (label) label.innerText = originalLabel || 'Thumbnail Image';
                                        }, 3000);

                                    } catch (err) {
                                        console.error('Client-side compression failed:', err);
                                        alert('The image is too large and failed to compress. Please choose a smaller file.');
                                        e.target.value = ''; // Clear the input
                                        if (label) label.innerText = originalLabel || 'Thumbnail Image';
                                    }
                                }
                            });
                        }

                        // Canvas-based compression function
                        function compressImage(file) {
                            return new Promise((resolve, reject) => {
                                const reader = new FileReader();
                                reader.readAsDataURL(file);
                                reader.onload = event => {
                                    const img = new Image();
                                    img.src = event.target.result;
                                    img.onload = () => {
                                        const canvas = document.createElement('canvas');
                                        const ctx = canvas.getContext('2d');

                                        // Scale down if dimensions are massive (max 1920px)
                                        const MAX_WIDTH = 1920;
                                        const MAX_HEIGHT = 1920;
                                        let width = img.width;
                                        let height = img.height;

                                        if (width > height) {
                                            if (width > MAX_WIDTH) {
                                                height *= MAX_WIDTH / width;
                                                width = MAX_WIDTH;
                                            }
                                        } else {
                                            if (height > MAX_HEIGHT) {
                                                width *= MAX_HEIGHT / height;
                                                height = MAX_HEIGHT;
                                            }
                                        }

                                        canvas.width = width;
                                        canvas.height = height;
                                        ctx.drawImage(img, 0, 0, width, height);

                                        // Output as JPEG at 80% quality
                                        canvas.toBlob((blob) => {
                                            if (!blob) return reject(new Error('Canvas is empty'));
                                            let newFileName = file.name.replace(/\.[^/.]+$/, "") + "_compressed.jpg";
                                            const newFile = new File([blob], newFileName, {
                                                type: 'image/jpeg',
                                                lastModified: Date.now()
                                            });
                                            resolve(newFile);
                                        }, 'image/jpeg', 0.80);
                                    };
                                    img.onerror = error => reject(error);
                                };
                                reader.onerror = error => reject(error);
                            });
                        }
                    });
                </script>
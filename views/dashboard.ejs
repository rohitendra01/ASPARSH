<% layout('layouts/dashboard-boilerplate') %>
<% block('styles').append(`<link rel="stylesheet" href="/css/dashboard/dashboard.css" />`) %>
<section class="dashboard-intro">
    <h1>Welcome to Your Dashboard</h1>
    <p>
        This dashboard provides a quick overview of your activities, statistics, and recent updates. Use the tools and features below to manage your account and stay informed.
    </p>
    <div class="dashboard-illustrations">
        <img src="/images/overview.svg" alt="Overview Illustration" style="width:80px; margin-right:20px;">
        <img src="/images/updates.svg" alt="Updates Illustration" style="width:80px;">
    </div>
</section>
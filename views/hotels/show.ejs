<% layout('layouts/hotel-boilerplate') %>
<% block('styles').append(`<link rel="stylesheet" href="/css/hotel/show.css" />`) %>
<img src="/assets/hotel-banner.jpg" alt="Hero" class="mobile-hero-image">
<hr>
<div class="category-filter-bar" id="categoryFilterBar">
  <button class="category-btn" data-category="all">All</button>
  <% if (foodCategories && foodCategories.length) { %>
    <% foodCategories.forEach(category => { %>
      <button class="category-btn" data-category="<%= category.categoryName %>"><%= category.categoryName %></button>
    <% }) %>
  <% } %>
</div>

<main>
  <% if (foodCategories && foodCategories.length) { %>
    <% foodCategories.forEach(category => { %>
    <div class="food-container" data-category="<%= category.categoryName %>">
      <div class="food-category">
        <h3><%= category.categoryName %></h3>
        <% if (category.imageUrl) { %>
          <img src="<%= category.imageUrl %>" alt="<%= category.categoryName %>">
        <% } %>
      </div>
      <div class="food-items">
        <ul>
          <% category.foodItems.forEach(item => { %>
            <li>
              <div class="food-item"><%= item.itemName %></div>
              <div class="food-price">₹<%= item.price %></div>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
    <% }) %>
  <% } else { %>
    <p>No food categories found.</p>
  <% } %>
</main>

<script>
document.addEventListener('DOMContentLoaded', function() {
  function isMobile() {
    return window.innerWidth <= 600;
  }
  if (isMobile()) {
    const buttons = document.querySelectorAll('.category-btn');
    const containers = document.querySelectorAll('.food-container');
    if (buttons.length) {
      buttons[0].classList.add('selected');
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', function() {
        buttons.forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        const cat = btn.getAttribute('data-category');
        if (cat === 'all') {
          containers.forEach(c => c.style.display = '');
        } else {
          containers.forEach(c => {
            if (c.getAttribute('data-category') === cat) {
              c.style.display = '';
            } else {
              c.style.display = 'none';
            }
          });
        }
      });
    });
  } else {
    const bar = document.getElementById('categoryFilterBar');
    if (bar) bar.style.display = 'none';
  }
});
</script>
<% layout('layouts/dashboard-boilerplate') %>
<% block('styles').append(`<link rel="stylesheet" href="/css/hotel/new.css" />`) %>


<div class="dashboard-container">
  <h2 class="dashboard-title">Create a New Hotel</h2>
  <div class="dashboard-options">
    <div class="option-card">
      <form action="/dashboard/<%= user.slug %>/hotels/new" method="POST" enctype="multipart/form-data" class="hotel-form">
        <div class="form-row">
          <div class="form-group">
            <label for="profileSearch">Search User Profile</label>
            <input type="text" id="profileSearch" name="profileSearch" placeholder="Enter user slug, email, or mobile" required autocomplete="off">
            <div id="profileSearchResults" class="search-results"></div>
            <input type="hidden" id="selectedProfileId" name="selectedProfileId">
            <input type="hidden" id="selectedProfileSlug" name="selectedProfileSlug">
            <input type="hidden" id="selectedProfileName" name="selectedProfileName">
          </div>
        </div>
        <div id="selectedProfileCard" style="display:none; margin-bottom:1rem;"></div>
        <script>
          document.addEventListener('DOMContentLoaded', function() {
            var profileSearch = document.getElementById('profileSearch');
            var resultsDiv = document.getElementById('profileSearchResults');
            var selectedProfileCard = document.getElementById('selectedProfileCard');
            if (profileSearch) {
              profileSearch.addEventListener('input', function(e) {
                var query = e.target.value.trim();
                if (query.length < 2) {
                  resultsDiv.innerHTML = '';
                  return;
                }
                fetch('/api/profiles/search?q=' + encodeURIComponent(query))
                  .then(function(res) { return res.json(); })
                  .then(function(data) {
                    if (Array.isArray(data) && data.length) {
                      resultsDiv.innerHTML = data.map(function(profile) {
                        return '<div class="search-result-item" data-id="' + profile._id + '" data-slug="' + profile.slug + '" data-name="' + profile.name + '" data-email="' + profile.email + '" data-mobile="' + profile.mobile + '">' +
                          '<strong>' + profile.name + '</strong> <span class="muted">(' + profile.slug + ')</span><br>' +
                          '<small>' + profile.email + ' | ' + profile.mobile + '</small>' +
                        '</div>';
                      }).join('');
                    } else {
                      resultsDiv.innerHTML = '<div class="muted">No user found.</div>';
                    }
                  });
              });
              resultsDiv.addEventListener('click', function(e) {
                var item = e.target.closest('.search-result-item');
                if (!item) return;
                document.getElementById('selectedProfileId').value = item.dataset.id;
                document.getElementById('selectedProfileSlug').value = item.dataset.slug;
                document.getElementById('selectedProfileName').value = item.dataset.name;
                profileSearch.value = item.dataset.name + ' (' + item.dataset.slug + ')';
                resultsDiv.innerHTML = '';
                // Show selected user card
                selectedProfileCard.innerHTML =
                  '<div class="profile-card" style="border:1px solid #ccc; padding:1rem; border-radius:8px; background:#f9f9f9;">' +
                    '<strong>' + item.dataset.name + '</strong> <span class="muted">(' + item.dataset.slug + ')</span><br>' +
                    '<small>' + item.dataset.email + ' | ' + item.dataset.mobile + '</small>' +
                  '</div>';
                selectedProfileCard.style.display = 'block';
              });
            }
          });
        </script>
          <div class="form-row">
            <div class="form-group">
              <label for="hotelName">Hotel Name</label>
              <input type="text" id="hotelName" name="hotelName" value="" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="hotelType">Type</label>
              <input type="text" id="hotelType" name="hotelType" value="" required>
            </div>
            <div class="form-group">
              <label for="hotelLogo">Hotel Logo</label>
              <input type="file" id="hotelLogo" name="hotelLogo" accept="image/*" value="" required>
            </div>
            <div class="form-group">
              <label for="hotelOfferBanner">Offer Banner</label>
              <input type="file" id="hotelOfferBanner" name="hotelOfferBanner" accept="image/*" value="" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="hotelDescription">Description</label>
              <textarea id="hotelDescription" name="hotelDescription" required></textarea>
            </div>
          </div>
          <fieldset>
            <legend>Hotel Address</legend>
            <div class="form-row">
              <div class="form-group">
                <input type="text" name="street" placeholder="Street" value="" required>
              </div>
              <div class="form-group">
                <input type="text" name="city" placeholder="City" value="" required>
              </div>
              <div class="form-group">
                <input type="text" name="state" placeholder="State" value="" required>
              </div>
              <div class="form-group">
                <input type="text" name="country" placeholder="Country" value="" required>
              </div>
              <div class="form-group">
                <input type="text" name="zipCode" placeholder="Zip Code" value="" required>
              </div>
            </div>
          </fieldset>
          <fieldset id="foodCategories">
            <legend>Food Categories & Items</legend>
          </fieldset>
          <div class="form-row">
            <button type="button" onclick="addCategory()">Add Category</button>
            <button type="submit">Create Show Page</button>
          </div>
          <script>
            let categoryCount = 0;
            let itemCounts = [];
            function addCategory() {
              const container = document.getElementById('foodCategories');
              const group = document.createElement('div');
              group.className = 'food-category-group';
              group.setAttribute('data-category', categoryCount);
              itemCounts[categoryCount] = 0;
              group.innerHTML = `
                <hr>
                <label>Category Name:</label>
                <input type="text" name="foodCategories[${categoryCount}][categoryName]">
                <div class="food-items-list" id="foodItemsList${categoryCount}"></div>
                <button type="button" onclick="addItem(${categoryCount})">Add Item</button>
                <button type="button" onclick="removeCategory(this)">Remove Category</button>
              `;
              container.appendChild(group);
              addItem(categoryCount); // Add first item by default
              categoryCount++;
            }
            function addItem(catIdx) {
              const itemsList = document.getElementById(`foodItemsList${catIdx}`);
              if (!itemsList) return;
              const itemIdx = itemCounts[catIdx] || 0;
              const itemDiv = document.createElement('div');
              itemDiv.className = 'food-items-group';
              itemDiv.innerHTML = `
                <label>Item Name:</label>
                <input type="text" name="foodCategories[${catIdx}][foodItems][${itemIdx}][itemName]">
                <label>Price:</label>
                <input type="number" name="foodCategories[${catIdx}][foodItems][${itemIdx}][price]" min="0">
                <button type="button" onclick="removeItem(this)">Remove Item</button>
              `;
              itemsList.appendChild(itemDiv);
              itemCounts[catIdx] = itemIdx + 1;
            }
            function removeCategory(btn) {
              btn.parentElement.remove();
            }
            function removeItem(btn) {
              btn.parentElement.remove();
            }
            window.onload = function() { addCategory(); };

            // ...existing code...
            // Client-side image size validation (max 10,000,000 KB = 10,000,000,000 bytes)
            document.querySelector('.hotel-form').addEventListener('submit', function(e) {
              var logo = document.getElementById('hotelLogo').files[0];
              var banner = document.getElementById('hotelOfferBanner').files[0];
              var maxSize = 1000 * 1024; // 1000 KB in bytes
              if (logo && logo.size > maxSize) {
                alert('Hotel Logo file size must be less than 1000 KB.');
                e.preventDefault();
                return false;
              }
              if (banner && banner.size > maxSize) {
                alert('Offer Banner file size must be less than 1000 KB.');
                e.preventDefault();
                return false;
              }
            });
          </script>
        </form>
      </div>
    </div>
  </div>
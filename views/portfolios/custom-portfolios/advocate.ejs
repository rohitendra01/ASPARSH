(function initTestimonials() {
            // same logic you already have, but use `testimonials` from server
            const dots = document.querySelectorAll('.dot');
            const testimonialText = document.querySelector('.testimonial-text');
            const authorName = document.querySelector('.author-info h4');
            const authorPosition = document.querySelector('.author-info span');

            let current 
= 0;
            function update(i) {
                const t = testimonials[i];
                if (!t) return;
                testimonialText.textContent = t.text;
                authorName.textContent = t.name || '';
          
      authorPosition.textContent = t.position || t.role || '';
                const authorImg = document.querySelector('.author-image');
                if (authorImg && t.avatar) authorImg.style.backgroundImage = 'url(' + t.avatar + ')';
            }

            dots.forEach((dot, idx) => {
                
dot.addEventListener('click', () => {
                    dots.forEach(d => d.classList.remove('active'));
dot.classList.add('active');
                    current = idx;
                    update(idx);
                });
            });

            setInterval(() => {
                dots[current].classList.remove('active');
                current = (current + 1) % dots.length;
                dots[current].classList.add('active');
                update(current);
            }, 6000);
})();

        function saveContact() {

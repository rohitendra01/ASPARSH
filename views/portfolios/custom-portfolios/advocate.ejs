VERSION:3.0
FN:Advocate Rajesh Kumar
TITLE:Senior Legal Counsel
TEL;TYPE=CELL:+919876543210
EMAIL:advocate.kumar@legalfirm.com
ADR;TYPE=WORK:;;Chamber No. 45, District Court Complex;Delhi;;110001;India
NOTE:15+ Years Experience in Civil, Criminal, and Corporate Law
URL:https://advocatekumar.com
END:VCARD`;
const blob = new Blob([vcard], { type: 'text/vcard' });
            const url = window.URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
link.download = 'Advocate_Rajesh_Kumar.vcf';

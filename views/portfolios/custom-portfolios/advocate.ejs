<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title><%= (portfolio && portfolio.name) ?
(portfolio.name + ' - ' + (portfolio.profession || 'Legal Professional')) : 'Advocate - Legal Professional' %></title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
padding: 0;
            box-sizing: border-box;
        }

        body {
             font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
background-color: #0a0a0a;
            color: #ffffff;
            line-height: 1.6;
            position: relative;
        }

        /* Decorative Background Elements */
        body::before {
            content: '';
position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
background-image: 
                repeating-linear-gradient(90deg, rgba(184, 134, 11, 0.03) 0px, transparent 1px, transparent 50px, rgba(184, 134, 11, 0.03) 51px),
                repeating-linear-gradient(0deg, rgba(184, 134, 11, 0.03) 0px, transparent 1px, transparent 50px, rgba(184, 134, 11, 0.03) 51px);
pointer-events: none;
            z-index: 0;
        }

        /* Hero Section - Mobile First */
        .hero {
            min-height: 100vh;
display: flex;
            align-items: center;
            padding: 40px 20px;
            background: 
                linear-gradient(135deg, rgba(10, 10, 10, 0.95), rgba(20, 20, 20, 0.9)),
                url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=1600') center/cover;
position: relative;
            z-index: 1;
        }

        .hero::before {
            content: '';
position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
background: radial-gradient(circle at 20% 50%, rgba(184, 134, 11, 0.1), transparent 50%);
            pointer-events: none;
}

        .hero-container {
            max-width: 500px;
margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        .hero-content {
            text-align: center;
}

        .profile-section {
            margin-bottom: 30px;
}

        .profile-img-container {
            position: relative;
display: inline-block;
            margin-bottom: 20px;
        }

        .profile-img-container::before {
            content: '';
position: absolute;
            top: -15px;
            left: -15px;
            right: -15px;
            bottom: -15px;
            /* border: 2px solid rgba(184, 134, 11, 0.3);
*/
            border-radius: 50%;
            z-index: -1;
}
.profile-img {
  position: relative;
  width: 200px;
  height: 200px;
  border-radius: 50%;
  background: url('https://images.unsplash.com/photo-1556157382-97eda2d62296?w=400') center/cover;
  object-fit: cover;
  overflow: hidden;
/* important for clean edges */
}

/* Circular gradient border */
.profile-img::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
padding: 3px; /* border thickness */
  background: conic-gradient(
    #ca940c,
    #ffd700,
    #ca940c
  );
-webkit-mask: 
    linear-gradient(#fff 0 0) content-box, 
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
pointer-events: none;
}



        .hero-text h1 {
            font-size: 2.2rem;
margin-bottom: 10px;
            line-height: 1.2;
            font-weight: 700;
            color: #b8860b;
        }

       .hero-text .subtitle {
  font-size: 1rem;
color: white;
  font-weight: 350;
  margin-bottom: 15px;

  /* ✨ Glass effect properties */
  background: rgba(255, 255, 255, 0.1);
/* transparent white layer */
  backdrop-filter: blur(8px) saturate(150%);
  -webkit-backdrop-filter: blur(8px) saturate(150%);
  border: 2px solid rgba(255, 255, 255, 0.25);
border-image: linear-gradient(to bottom, #ca940c, transparent) 1;
  /* border-radius: 10px; */
  padding: 6px 12px;
  display: inline-block;
/* so glass fits text size */
}


        .hero-text p {
            font-size: 0.95rem;
margin-bottom: 25px;
            color: #b0b0b0;
            line-height: 1.7;
            font-family: 'Segoe UI', sans-serif;
            padding: 0 10px;
}

        .action-buttons {
            display: flex;
gap: 12px;
            justify-content: center;
            margin-bottom: 25px;
        }

        .action-btn {
            flex: 1;
max-width: 180px;
            background: linear-gradient(135deg, #b8860b, #daa520);
            color: white;
            padding: 13px 20px;
            border: none;
            border-radius: 8px;
            font-size: 0.9rem;
            cursor: pointer;
transition: all 0.3s;
            font-weight: 600;
            letter-spacing: 0.3px;
            box-shadow: 0 4px 15px rgba(184, 134, 11, 0.3);
            display: flex;
            align-items: center;
justify-content: center;
            gap: 8px;
            text-decoration: none;
        }

        .action-btn:hover {
            transform: translateY(-2px);
box-shadow: 0 6px 20px rgba(184, 134, 11, 0.4);
        }

        .action-btn i {
            font-size: 1rem;
}

        .social-links {
            display: flex;
justify-content: center;
            gap: 12px;
        }

        .social-links a {
            color: #fff;
font-size: 1rem;
            width: 42px;
            height: 42px;
            background: rgba(184, 134, 11, 0.2);
            border: 1px solid rgba(184, 134, 11, 0.4);
            border-radius: 8px;
display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

        .social-links a:hover {
            background: linear-gradient(135deg, #b8860b, #daa520);
transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(184, 134, 11, 0.3);
}

        /* Stats Section */
        .stats {
            padding: 50px 20px;
background: #0f0f0f;
            position: relative;
            z-index: 1;
        }

        .stats-container {
            max-width: 500px;
margin: 0 auto;
        }

        .section-title {
            text-align: left;
font-size: 1.6rem;
            margin-bottom: 15px;
            color: whitesmoke;
        }

        .section-subtitle {
            text-align: left;
color: #b0b0b0;
            margin-bottom: 40px;
            font-size: 0.95rem;
            font-family: 'Segoe UI', sans-serif;
}

        .stats-grid {
            display: grid;
grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 10px;
        }

        .stat-card {
            background: linear-gradient(135deg, rgba(20, 20, 20, 0.8), rgba(30, 30, 30, 0.6));
padding: 25px 20px;
            border-radius: 12px;
            text-align: center;
            border: 1px solid rgba(184, 134, 11, 0.2);
            transition: all 0.3s;
}

        .stat-card:hover {
            transform: translateY(-5px);
box-shadow: 0 10px 30px rgba(212, 235, 9, 0.2);
            border-color: #b8860b;
}

        .stat-icon {
            width: 50px;
height: 50px;
            background: linear-gradient(135deg, #b8860b, #daa520);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 1.3rem;
color: white;
            box-shadow: 0 6px 15px rgba(184, 134, 11, 0.3);
}

        .stat-number {
            font-size: 2rem;
font-weight: bold;
            color: #b8860b;
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 0.9rem;
color: #c0c0c0;
            font-family: 'Segoe UI', sans-serif;
        }

      .contact-details-card {
    background: linear-gradient(135deg, rgba(20, 20, 20, 0.9), rgba(30, 30, 30, 0.7));
padding: 20px 20px;
    border-radius: 12px;
    border: 1px solid rgba(184, 134, 11, 0.3);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
}

.contact-details-card h3 {
    text-align: left;
    color: whitesmoke;
    margin-bottom: 25px;
    font-size: 1.4rem;
}

/* Make contact-item links behave like cards */
.contact-item {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 15px;
padding: 15px;
    background: rgba(10, 10, 10, 0.5);
    border-radius: 8px;
    border: 1.5px solid rgba(184, 134, 11, 0.2);
    transition: all 0.3s;
text-decoration: none;   /* Remove underline for links */
    color: inherit;
/* Keep text color */
}

.contact-item:hover {
    background: rgba(184, 134, 11, 0.1);
    border-color: #b8860b;
    cursor: pointer;
/* Show pointer on hover */
}

.contact-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #b8860b, #daa520);
    border-radius: 8px;
display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: white;
    flex-shrink: 0;
}

.contact-info {
    flex: 1;
}

.contact-label {
    font-size: 0.8rem;
    color: #d6d0d0;
    margin-bottom: 3px;
    font-family: 'Segoe UI', sans-serif;
}

.contact-value {
    font-size: 0.95rem;
    color: #e0e0e0;
    font-family: 'Segoe UI', sans-serif;
    word-break: break-word;
}


        /* Services Section */
        .services {
            padding: 30px 7px;
background: #0a0a0a;
            position: relative;
            z-index: 1;
        }

        .services-container {
            max-width: 500px;
margin: 0 auto;
        }

        .services-grid {
            display: grid;
grid-template-columns: 1fr;
            gap: 20px;
        }

        .service-card {
            background: linear-gradient(135deg, rgba(20, 20, 20, 0.8), rgba(30, 30, 30, 0.6));
padding: 30px 25px;
            border-radius: 12px;
            border: 1px solid rgba(184, 134, 11, 0.2);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
}

        .service-card::before {
            content: '';
position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(184, 134, 11, 0.1), transparent);
transition: left 0.5s;
        }

        .service-card:hover::before {
            left: 100%;
}

        .service-card:hover {
            transform: translateY(-5px);
box-shadow: 0 15px 40px rgba(184, 134, 11, 0.2);
            border-color: #b8860b;
}

        .service-header {
            display: flex;
align-items: center;
            gap: 15px;
            margin-bottom: 15px;
        }

        .service-icon {
            width: 55px;
height: 55px;
            background: linear-gradient(135deg, #b8860b, #daa520);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
box-shadow: 0 6px 15px rgba(184, 134, 11, 0.3);
            flex-shrink: 0;
}

        .service-card h3 {
            font-size: 1.2rem;
color: #e0e0e0;
        }

        .service-card p {
            color: #a0a0a0;
line-height: 1.6;
            font-family: 'Segoe UI', sans-serif;
            font-size: 0.95rem;
        }

        /* Cases Section */
        .cases {
            padding: 20px 15px;
background: #0f0f0f;
            position: relative;
            z-index: 1;
        }

        .cases-container {
            max-width: 500px;
margin: 0 auto;
        }

        .case-filters {
            display: flex;
gap: 10px;
            margin-bottom: 30px;
            flex-wrap: wrap;
            justify-content: left;
        }

        .filter-btn {
            background: transparent;
color: #e0e0e0;
            border: 1px solid rgba(184, 134, 11, 0.4);
            padding: 8px 18px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
font-family: 'Georgia', serif;
            font-size: 0.85rem;
        }

        .filter-btn.active,
        .filter-btn:hover {
            background: linear-gradient(135deg, #b8860b, #daa520);
border-color: #b8860b;
            color: white;
        }

        .cases-grid {
            display: grid;
grid-template-columns: 1fr;
            gap: 20px;
        }

        .case-card {
            background: rgba(20, 20, 20, 0.8);
border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s;
            border: 1px solid rgba(184, 134, 11, 0.2);
}

        .case-card:hover {
            transform: translateY(-5px);
box-shadow: 0 15px 40px rgba(184, 134, 11, 0.2);
        }

        .case-image {
            height: 180px;
background: #1a1a1a;
            position: relative;
            overflow: hidden;
        }

        .case-image img {
            width: 100%;
height: 100%;
            object-fit: cover;
            transition: transform 0.4s;
        }

        .case-card:hover .case-image img {
            transform: scale(1.1);
}

        .case-overlay {
            position: absolute;
top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(184, 134, 11, 0.9), rgba(218, 165, 32, 0.9));
            display: flex;
align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .case-card:hover .case-overlay {
            opacity: 1;
}

        .case-info {
            padding: 20px;
}

        .case-info h3 {
            margin-bottom: 8px;
color: #e0e0e0;
            font-size: 1.1rem;
        }

        .case-category {
            color: #b8860b;
font-size: 0.85rem;
            font-weight: 600;
        }

        /* Testimonials Section */
        .testimonials {
            padding: 30px 15px;
background: #0a0a0a;
            position: relative;
            z-index: 1;
        }

        .testimonials-container {
            max-width: 500px;
margin: 0 auto;
        }

        .testimonial {
            background: linear-gradient(135deg, rgba(20, 20, 20, 0.9), rgba(30, 30, 30, 0.7));
padding: 20px 25px;
            border-radius: 12px;
            margin-bottom: 20px;
            border: 1px solid rgba(184, 134, 11, 0.2);
box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .testimonial-text {
            font-size: 0.95rem;
margin-bottom: 20px;
            color: #b0b0b0;
            font-style: italic;
            line-height: 1.7;
            font-family: 'Georgia', serif;
}

        .testimonial-author {
            display: flex;
align-items: center;
            gap: 15px;
        }

        .author-image {
            width: 50px;
height: 50px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #b8860b;
            background: url('https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100') center/cover;
            flex-shrink: 0;
}

        .author-info h4 {
            margin-bottom: 3px;
color: #e0e0e0;
            font-size: 1rem;
        }

        .author-info span {
            color: #b8860b;
font-size: 0.85rem;
        }

        .slider-dots {
            display: flex;
justify-content: center;
            gap: 10px;
            margin-top: 25px;
        }

        .dot {
            width: 10px;
height: 10px;
            border-radius: 50%;
            background: rgba(184, 134, 11, 0.3);
            cursor: pointer;
            transition: all 0.3s;
}

        .dot.active {
            background: #b8860b;
transform: scale(1.2);
        }

        /* Google Action Buttons */
        .google-action-btn {
            flex: 1;
min-width: 140px;
            padding: 12px 20px;
            background: linear-gradient(135deg, #4285f4, #34a853);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-size: 0.9rem;
font-family: 'Segoe UI', sans-serif;
            font-weight: 600;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
box-shadow: 0 4px 15px rgba(66, 133, 244, 0.3);
            border: none;
            cursor: pointer;
}

        .google-action-btn:hover {
            transform: translateY(-3px);
box-shadow: 0 6px 20px rgba(66, 133, 244, 0.4);
        }

        .google-action-btn-secondary {
            background: linear-gradient(135deg, rgba(66, 133, 244, 0.2), rgba(52, 168, 83, 0.2));
border: 1px solid rgba(66, 133, 244, 0.4);
        }

        .google-action-btn-secondary:hover {
            background: linear-gradient(135deg, rgba(66, 133, 244, 0.3), rgba(52, 168, 83, 0.3));
border-color: #4285f4;
        }

        /* Ratings Section */
        .ratings {
            padding: 15px 15px;
background: #0f0f0f;
            position: relative;
            z-index: 1;
        }

        .ratings-container {
            max-width: 500px;
margin: 0 auto;
        }

        .overall-rating {
            text-align: center;
background: linear-gradient(135deg, rgba(20, 20, 20, 0.9), rgba(30, 30, 30, 0.7));
            padding: 20px 30px;
            border-radius: 12px;
            margin-bottom: 30px;
border: 1px solid rgba(184, 134, 11, 0.3);
        }

        .rating-number {
            font-size: 4rem;
font-weight: bold;
            color: #b8860b;
            margin-bottom: 10px;
        }

        .rating-stars {
            font-size: 1.8rem;
color: #b8860b;
            margin-bottom: 8px;
        }

        .rating-text {
            color: #b0b0b0;
font-size: 0.95rem;
            font-family: 'Segoe UI', sans-serif;
        }

        .rating-breakdown {
            display: flex;
flex-direction: column;
            gap: 15px;
        }

        .rating-item {
            display: flex;
align-items: center;
            gap: 15px;
        }

        .rating-label {
            width: 120px;
font-size: 0.9rem;
            color: #e0e0e0;
            font-family: 'Segoe UI', sans-serif;
        }

        .rating-bar-container {
            flex: 1;
height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
}

        .rating-bar-fill {
            height: 100%;
background: linear-gradient(90deg, #b8860b, #daa520);
            border-radius: 4px;
            transition: width 1s ease-in-out;
            box-shadow: 0 0 8px rgba(184, 134, 11, 0.5);
}

        .rating-value {
            width: 35px;
text-align: right;
            font-size: 0.9rem;
            color: #b8860b;
            font-weight: 600;
        }

        /* Footer */
        .footer {
            background: #0a0a0a;
padding: 25px 20px;
            text-align: center;
            border-top: 1px solid rgba(184, 134, 11, 0.2);
}

        .footer p {
            color: white;
font-family: 'Segoe UI', sans-serif;
            font-size: 0.85rem;
        }

        .footer h5 {
             color: #e0e0e0;
font-weight: 500;
        }

        /* Scroll to top button */
        .scroll-top {
            position: fixed;
bottom: 30px;
            right: 20px;
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #b8860b, #daa520);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
cursor: pointer;
            box-shadow: 0 6px 20px rgba(184, 134, 11, 0.4);
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
            z-index: 1000;
}

        .scroll-top.visible {
            opacity: 1;
visibility: visible;
        }

        .scroll-top:hover {
            transform: translateY(-5px);
}

        .scroll-top i {
            color: white;
font-size: 1.2rem;
        }

    </style>
</head>
<body>
    <section class="hero">
        <div class="hero-container">
            <div class="hero-content">
                <div class="profile-section">
                    <div class="profile-img-container">
                      
  <div class="profile-img"
                             style="background-image: url('<%= portfolio && portfolio.heroImage ? portfolio.heroImage : (portfolio && portfolio.aboutImage ? portfolio.aboutImage : '/assets/default-profile.jpg') %>');">
                
        </div>
                    </div>
                    <div class="hero-text">
                        <h1><%= portfolio && portfolio.name ?
portfolio.name : 'Advocate Rajesh Kumar' %></h1>

                        <div class="subtitle"><%= portfolio && portfolio.profession ?
portfolio.profession : 'Senior Legal Counsel' %></div>

                        <p>
                            <%= portfolio && portfolio.briefIntro ?
portfolio.briefIntro : 
                                'With over 15 years of distinguished practice in civil, criminal, and corporate law, providing comprehensive legal solutions with commitment to justice and client success.'
%>
                        </p>
                    </div>
                </div>

                <div class="action-buttons">
                    <button class="action-btn" onclick="saveContact()">
 
                       <i class="fas fa-address-card"></i>
                        Save Contact
                    </button>
                    <button class="action-btn" onclick="takeScreenshot()">
        
                <i class="fas fa-camera"></i>
                        Screenshot
                    </button>
                </div>

                <div class="social-links">
     
               <% if (portfolio && Array.isArray(portfolio.socialLinks) && portfolio.socialLinks.length) { %>
                        <% portfolio.socialLinks.forEach(function(s) { %>
                            <% if (s && s.url) { %>
                
                <a href="<%= s.url %>" target="_blank" rel="noopener noreferrer" aria-label="<%= s.platform || 'social' %>">
                                    <% // try to map platform to icon if platform known %>
                          
          <% if (s.platform && s.platform.toLowerCase().includes('linkedin')) { %>
                                        <i class="fab fa-linkedin-in"></i>
                                    <% } else if (s.platform && 
s.platform.toLowerCase().includes('twitter')) { %>
                                        <i class="fab fa-twitter"></i>
                                    <% } else { %>
                
                        <i class="fas fa-link"></i>
                                    <% } %>
                                </a>
    
                        <% } %>
                        <% }) %>
                    <% } else { %>
                        
<a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fas fa-envelope"></i></a>
           
             <a href="#"><i class="fas fa-phone"></i></a>
                    <% } %>
                </div>
            </div>
        </div>
    </section>

    <div class="contact-details-card">
        <h3>Contact 
</h3>

        <% /* Phone */ %>
        <% if (portfolio && portfolio.contact && portfolio.contact.phone) { %>
        <a href="tel:<%= portfolio.contact.phone %>" class="contact-item">
            <div class="contact-icon"><i class="fas fa-phone"></i></div>
            <div class="contact-info">
                <div class="contact-label">Phone Number</div>
              
  <div class="contact-value"><%= portfolio.contact.phone %></div>
            </div>
        </a>
        <% } else { %>
        <a class="contact-item" href="tel:+919876543210">
            <div class="contact-icon"><i class="fas fa-phone"></i></div>
            <div class="contact-info">
                <div class="contact-label">Phone Number</div>
       

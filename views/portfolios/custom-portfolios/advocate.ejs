}

        // Animate rating bars on scroll
        const ratingBars = document.querySelectorAll('.rating-bar-fill');
const ratingsSection = document.querySelector('.ratings');

        const animateRatings = () => {
            const ratingsRect = ratingsSection.getBoundingClientRect();
if (ratingsRect.top < window.innerHeight && ratingsRect.bottom > 0) {
                ratingBars.forEach(bar => {
                    const width = bar.style.width;
                    bar.style.width = '0%';
                    setTimeout(() => {
       
                 bar.style.width = width;
                    }, 200);
                });
window.removeEventListener('scroll', animateRatings);
            }

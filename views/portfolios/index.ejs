<% layout('layouts/dashboard-boilerplate') -%>
<% block('styles').append('<link rel="stylesheet" href="/css/portfolio/index.css">') %>

<%
  const items = (typeof portfolios !== 'undefined' && portfolios) ? portfolios : ((typeof cards !== 'undefined' && cards) ? cards : []);
  const userSlug = (typeof user !== 'undefined') ? user.slug : (typeof slug !== 'undefined' ? slug : '');
%>

<div class="dashboard-header-row">
  <form class="search-form" onsubmit="return filterPortfolios(event)">
    <input type="text" id="portfolioSlugSearch" name="portfolioSlug" placeholder="Enter Portfolio Slug or Title" required>
    <button type="submit">Search</button>
  </form>
  <% const userSlugSegment = (typeof userSlug !== 'undefined' && userSlug) ? '/' + encodeURIComponent(userSlug) : ''; %>
  <a href="/dashboard<%= userSlugSegment %>/portfolios/new" class="create-hotel-btn create-hotel-btn-fixed">+ Create New Portfolio</a>
</div>

<div class="hotel-list-container portfolio-list-container">
  <% if (items && items.length) { %>
    <div class="visiting-card-cards-grid">
      <% items.forEach(p => { %>
        <div class="visiting-card portfolio-card" data-card-id="<%= p._id %>" data-card-slug="<%= (p.slug || '') %>">
          <img src="<%= (p.coverImage || p.image || '/assets/feature1.jpg') %>" alt="<%= (p.title || p.name || 'Portfolio') %>" class="visiting-card-logo">
          <div class="visiting-card-body">
            <div class="visiting-card-heading">
              <h2 class="visiting-card-title"><%= p.title || p.name || 'Untitled' %></h2>
              <% if (p.tagline || p.subtitle) { %>
                <p class="visiting-card-company"><%= p.tagline || p.subtitle %></p>
              <% } %>
            </div>
            <div class="visiting-card-links">
              <% const viewSlug = p.slug ? encodeURIComponent(p.slug) : (p._id ? p._id : null); %>
              <a href="/portfolio/<%= viewSlug %>" class="visiting-card-link" target="_blank">View Final</a>
              <% const editTarget = p.slug ? `/dashboard/${encodeURIComponent(userSlug)}/portfolios/slug/${encodeURIComponent(p.slug)}/edit` : `/dashboard/${encodeURIComponent(userSlug)}/portfolios/${p._id}/edit`; %>
              <a href="<%= editTarget %>" class="visiting-card-edit">Edit</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p>No portfolios found.</p>
  <% } %>
</div>

<script>
  function filterPortfolios(event) {
    event.preventDefault();
    const input = document.getElementById('portfolioSlugSearch').value.trim().toLowerCase();
    const cards = document.querySelectorAll('.visiting-card');
    if (!input) {
      cards.forEach(card => card.style.display = '');
      return false;
    }
    cards.forEach(card => {
      const slug = (card.getAttribute('data-card-slug') || '') + ' ' + (card.querySelector('.visiting-card-title')?.textContent || '');
      if (slug.toLowerCase().includes(input)) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
    return false;
  }
</script>
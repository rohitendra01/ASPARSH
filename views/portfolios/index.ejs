<% layout('layouts/dashboard-boilerplate') -%>
  <% block('styles').append(`<link rel="stylesheet" href="/css/portfolio/index.css" />`) %>

  <% const items=(typeof portfolios !=='undefined' && portfolios) ? portfolios : ((typeof cards !=='undefined' && cards)
    ? cards : []); const userSlug=(typeof user !=='undefined' ) ? user.slug : (typeof slug !=='undefined' ? slug : '' );
    const userSlugSegment=(typeof userSlug !=='undefined' && userSlug) ? '/' + encodeURIComponent(userSlug) : '' ; %>

    <div class="page-container">

      <div class="page-header-row">
        <div class="page-header-text">
          <h1 class="page-title">Portfolios</h1>
          <p class="page-subtitle">Manage your deployed portfolio websites and templates.</p>
        </div>

        <div class="page-header-actions">
          <div class="search-wrapper">
            <input type="text" id="liveSearchInput" placeholder="Search by name, profession, or template..."
              onkeyup="filterPortfolios()">
          </div>
          <a href="/dashboard<%= userSlugSegment %>/portfolios/new" class="btn-primary">+ Create Portfolio</a>
        </div>
      </div>

      <% if (items && items.length> 0) { %>
        <div class="quick-stats-row">
          <div class="stat-card">
            <span class="stat-value">
              <%= items.length %>
            </span>
            <span class="stat-label">Active Portfolios</span>
          </div>
        </div>
        <% } %>

          <div class="entity-list-container">
            <% if (items && items.length> 0) { %>
              <div class="compact-grid" id="entityGrid">

                <% items.forEach(p=> { %>
                  <% const title=p.title || p.name || 'Untitled' ; const profession=p.profession || p.tagline ||
                    p.subtitle || (p.design ? p.design.category : '' ); const cover=p.heroImage || p.coverImage ||
                    p.image; const viewSlug=p.slug ? encodeURIComponent(p.slug) : (p._id ? p._id : null); const
                    editTarget=p.slug ?
                    `/dashboard${userSlugSegment}/portfolios/slug/${encodeURIComponent(p.slug)}/edit` :
                    `/dashboard${userSlugSegment}/portfolios/${p._id}/edit`; const profileName=p.profileId &&
                    p.profileId.name ? p.profileId.name : 'Unknown Profile' ; const designName=p.design && p.design.name
                    ? p.design.name : 'Custom Template' ; %>

                    <div class="compact-card entity-card"
                      data-search-term="<%= title.toLowerCase() %> <%= profession.toLowerCase() %> <%= profileName.toLowerCase() %> <%= designName.toLowerCase() %>">

                      <div class="card-thumbnail">
                        <% if (cover) { %>
                          <img src="<%= cover %>" alt="<%= title %>" loading="lazy">
                          <% } else { %>
                            <div class="thumbnail-placeholder">
                              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="3" y1="9" x2="21" y2="9"></line>
                                <line x1="9" y1="21" x2="9" y2="9"></line>
                              </svg>
                            </div>
                            <% } %>
                      </div>

                      <div class="card-info">
                        <div class="info-header">
                          <h3 class="card-title text-truncate" title="<%= title %>">
                            <%= title %>
                          </h3>
                          <% if (profession) { %>
                            <span class="badge">
                              <%= profession %>
                            </span>
                            <% } %>
                        </div>

                        <div class="info-meta-grid">
                          <span class="meta-item text-truncate" title="Linked Profile: <%= profileName %>">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                              <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                            <%= profileName %>
                          </span>

                          <span class="meta-item text-truncate" title="Template: <%= designName %>">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                              <polyline points="2 17 12 22 22 17"></polyline>
                              <polyline points="2 12 12 17 22 12"></polyline>
                            </svg>
                            <%= designName %>
                          </span>
                        </div>
                      </div>

                      <div class="card-actions">
                        <a href="/portfolio/<%= viewSlug %>" target="_blank" class="action-icon-btn info-btn"
                          title="View Live Site">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                            <polyline points="15 3 21 3 21 9"></polyline>
                            <line x1="10" y1="14" x2="21" y2="3"></line>
                          </svg>
                        </a>

                        <a href="<%= editTarget %>" class="action-icon-btn edit-btn" title="Edit Portfolio">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                          </svg>
                        </a>
                      </div>

                    </div>
                    <% }) %>

              </div>

              <% } else { %>

                <div class="empty-state">
                  <div class="empty-icon">🖥️</div>
                  <h2>No portfolios found</h2>
                  <p>Showcase your work, skills, and experience by building a beautiful portfolio website in minutes.
                  </p>
                  <a href="/dashboard<%= userSlugSegment %>/portfolios/new" class="btn-primary">+ Create Your First
                    Portfolio</a>
                </div>

                <% } %>
          </div>
    </div>

    <script>
      function filterPortfolios() {
        const input = document.getElementById('liveSearchInput').value.trim().toLowerCase();
        const cards = document.querySelectorAll('.entity-card');

        cards.forEach(card => {
          const searchTerm = card.getAttribute('data-search-term') || '';
          if (searchTerm.includes(input)) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      }
    </script>
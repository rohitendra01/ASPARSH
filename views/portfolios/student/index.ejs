
<% layout('layouts/dashboard-boilerplate') %>
<% block('styles').append(`<link rel="stylesheet" href="/css/dashboard/dashboard.css" />`) %>

<div class="portfolio-container">
  <h1 class="portfolio-title">User Portfolio</h1>
  <% if (typeof error !== 'undefined') { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <div class="portfolio-user-info">
    <p><strong>Name:</strong> <%= user && user.name ? user.name : (user && user.username ? user.username : 'N/A') %></p>
    <p><strong>Email:</strong> <%= user && user.email ? user.email : 'N/A' %></p>
  </div>
  <h2 class="portfolio-hotels-title">Hotels Managed</h2>
  <% if (hotels && hotels.length) { %>
    <div class="portfolio-hotels-list">
      <% hotels.forEach(hotel => { %>
        <div class="portfolio-hotel-card">
          <img src="<%= hotel.hotelLogo %>" alt="<%= hotel.hotelName %> Logo" class="portfolio-hotel-logo">
          <div class="portfolio-hotel-info">
            <h3 class="portfolio-hotel-name"><%= hotel.hotelName %></h3>
            <p class="portfolio-hotel-type"><%= hotel.hotelType %></p>
            <p class="portfolio-hotel-desc"><%= hotel.hotelDescription %></p>
            <a href="/hotel/<%= hotel.hotelId %>" class="portfolio-hotel-link">View Hotel</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="portfolio-no-hotels">No hotels found for this user.</p>
  <% } %>
</div>

<style>
.portfolio-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 6rem 1rem;
}
.portfolio-title {
  font-size: 2.2rem;
  font-weight: 700;
  margin-bottom: 2rem;
  color: #222;
}
.portfolio-user-info {
  background: #f8f9fa;
  border-radius: 8px;
  padding: 1.2rem 1.5rem;
  margin-bottom: 2.5rem;
  font-size: 1.1rem;
}
.portfolio-hotels-title {
  font-size: 1.4rem;
  font-weight: 600;
  margin-bottom: 1.2rem;
  color: #007bff;
}
.portfolio-hotels-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
  gap: 2rem;
}
.portfolio-hotel-card {
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s;
}
.portfolio-hotel-card:hover {
  box-shadow: 0 8px 32px rgba(0,0,0,0.16);
}
.portfolio-hotel-logo {
  width: 100%;
  height: 180px;
  object-fit: cover;
  background: #f5f5f5;
}
.portfolio-hotel-info {
  padding: 1.2rem 1rem 1.5rem 1rem;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.portfolio-hotel-name {
  font-size: 1.15rem;
  font-weight: 700;
  margin: 0 0 0.5rem 0;
  color: #222;
}
.portfolio-hotel-type {
  font-size: 1.05rem;
  color: #007bff;
  margin-bottom: 0.5rem;
}
.portfolio-hotel-desc {
  font-size: 1rem;
  color: #444;
  margin-bottom: 1.2rem;
}
.portfolio-hotel-link {
  display: inline-block;
  background: #007bff;
  color: #fff;
  padding: 0.6rem 1.2rem;
  border-radius: 6px;
  text-decoration: none;
  font-weight: 600;
  transition: background 0.2s;
}
.portfolio-hotel-link:hover {
  background: #0056b3;
}
.portfolio-no-hotels {
  color: #888;
  font-size: 1.1rem;
  margin-top: 1.5rem;
}
</style>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asparsh | Visiting Card</title>
    <link rel="stylesheet" href="/css/portfolio/business/visiting-card.css">
</head>
<body>
    <section class="section-header">
        <div class="header-content">
            <div class="header-image">
                <% if (card.image) { %>
                  <img src="<%= card.image %>" alt="<%= card.name %>" class="profile-img" />
                <% } else { %>
                  <img src="/assets/portfolio-image.jpg" alt="Visiting Card Header Image" class="profile-img" />
                <% } %>
            </div>
            <div class="header-intro">
                <h1><%= card.name %></h1>
                <h2><%= card.title %></h2>
                <div class="social-links">
                    <% if (card.linkedin) { %>
                    <a href="<%= card.linkedin %>" target="_blank" aria-label="LinkedIn">
                        <!-- LinkedIn SVG -->
                        <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path fill="#0A66C2" d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11 19h-3v-9h3v9zm-1.5-10.28c-.97 0-1.75-.79-1.75-1.75s.78-1.75 1.75-1.75 1.75.79 1.75 1.75-.78 1.75-1.75 1.75zm13.5 10.28h-3v-4.5c0-1.08-.02-2.47-1.5-2.47-1.5 0-1.73 1.17-1.73 2.39v4.58h-3v-9h2.88v1.23h.04c.4-.75 1.38-1.54 2.84-1.54 3.04 0 3.6 2 3.6 4.59v4.72z"/></svg>
                    </a>
                    <% } %>
                    <% if (card.twitter) { %>
                    <a href="<%= card.twitter %>" target="_blank" aria-label="Twitter">
                        <!-- Twitter SVG -->
                        <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path fill="#1DA1F2" d="M24 4.56c-.89.39-1.84.65-2.84.77a4.93 4.93 0 0 0 2.16-2.72c-.95.56-2 .97-3.13 1.19a4.92 4.92 0 0 0-8.39 4.48c-4.09-.2-7.71-2.17-10.13-5.15a4.93 4.93 0 0 0-.66 2.48c0 1.71.87 3.22 2.19 4.1-.8-.03-1.56-.25-2.22-.62v.06c0 2.39 1.7 4.38 3.95 4.83-.41.11-.85.17-1.3.17-.32 0-.62-.03-.92-.08.63 1.95 2.44 3.37 4.6 3.41a9.87 9.87 0 0 1-6.1 2.1c-.4 0-.79-.02-1.18-.07a13.94 13.94 0 0 0 7.56 2.21c9.05 0 14-7.5 14-14 0-.21 0-.42-.02-.63a9.93 9.93 0 0 0 2.46-2.54z"/></svg>
                    </a>
                    <% } %>
                    <% if (card.facebook) { %>
                    <a href="<%= card.facebook %>" target="_blank" aria-label="Facebook">
                        <!-- Facebook SVG -->
                        <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path fill="#1877F3" d="M22.675 0h-21.35c-.733 0-1.325.592-1.325 1.325v21.351c0 .732.592 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.797.143v3.24l-1.918.001c-1.504 0-1.797.715-1.797 1.763v2.312h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.322-.592 1.322-1.324v-21.35c0-.733-.592-1.325-1.325-1.325z"/></svg>
                    </a>
                    <% } %>
                    <% if (card.instagram) { %>
                    <a href="<%= card.instagram %>" target="_blank" aria-label="Instagram">
                        <!-- Instagram SVG -->
                        <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><radialGradient id="a" cx="1.464" cy="0.507" r="1.5" gradientTransform="matrix(1 0 0 .6667 0 .176)" gradientUnits="userSpaceOnUse"><stop stop-color="#fd5"/><stop offset=".5" stop-color="#ff543e"/><stop offset="1" stop-color="#c837ab"/></radialGradient><rect width="24" height="24" rx="5" fill="url(#a)"/><path fill="#fff" d="M12 7.2A4.8 4.8 0 1 0 12 16.8 4.8 4.8 0 1 0 12 7.2zm0 7.8A3 3 0 1 1 12 9a3 3 0 0 1 0 6zm6.4-8.2a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0 1 2.4 0z"/></svg>
                    </a>
                    <% } %>
                    <% if (card.email) { %>
                    <a href="mailto:<%= card.email %>" target="_blank" aria-label="Email">
                        <!-- Email SVG -->
                        <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path fill="#EA4335" d="M12 13.065 2.4 6.6A2 2 0 0 1 4 6h16a2 2 0 0 1 1.6.6l-9.6 6.465zm-9.6 7.335V7.2l7.68 5.175-7.68 8.025zm1.2 1.2 7.68-8.025 1.44 1.005a1 1 0 0 0 1.12 0l1.44-1.005 7.68 8.025A2 2 0 0 1 20 22H4a2 2 0 0 1-1.6-.4zM21.6 20.4l-7.68-8.025L21.6 7.2v13.2z"/></svg>
                    </a>
                    <% } %>
                </div>
            </div>
        </div>
    </section>
    <section class="section-main">
        <div class="main-description">
            <p><%= card.description %></p>
        </div>
        <div class="main-contact-links">
            <% if (card.email) { %>
            <a href="mailto:<%= card.email %>" class="info-link" aria-label="Email">
                <!-- Email SVG -->
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24">
                    <path fill="#EA4335" d="M12 13.065 2.4 6.6A2 2 0 0 1 4 6h16a2 2 0 0 1 1.6.6l-9.6 6.465zm-9.6 7.335V7.2l7.68 5.175-7.68 8.025zm1.2 1.2 7.68-8.025 1.44 1.005a1 1 0 0 0 1.12 0l1.44-1.005 7.68 8.025A2 2 0 0 1 20 22H4a2 2 0 0 1-1.6-.4zM21.6 20.4l-7.68-8.025L21.6 7.2v13.2z"/>
                </svg>
                <span>Email : <%= card.email %></span>
            </a>
            <% } %>
            <% if (card.phone) { %>
            <a href="tel:<%= card.phone %>" class="info-link" aria-label="Contact">
                <!-- Phone SVG -->
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24">
                    <path fill="#0A66C2" d="M6.62 10.79a15.053 15.053 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.07 21 3 13.93 3 5a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.2 2.2z"/>
                </svg>
                <span>Contact : <%= card.phone %></span>
            </a>
            <% } %>
            <% if (card.address) { %>
            <a href="#" class="info-link" aria-label="Address">
                <!-- Address SVG -->
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24">
                    <path fill="#1877F3" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z"/>
                </svg>
                <span>Address : <%= card.address %></span>
            </a>
            <% } %>
            <% if (card.website) { %>
            <a href="<%= card.website %>" class="info-link" aria-label="Website" target="_blank">
                <!-- Website SVG -->
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24">
                    <path fill="#34A853" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5.59 7.41L11.17 15l-3.59-3.59L8.59 9l3.59 3.59L16.41 9l1.18 1.41z"/>
                </svg>
                <span>Website : <%= card.website.replace(/^https?:\/\//, '') %></span>
            </a>
            <% } %>
        </div>
    </section>
</body>
</html>
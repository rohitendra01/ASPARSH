<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/portfolio/student/show.css">
    <link rel="stylesheet" href="/css/portfolio/student/contact.css">
    <title>Contact | Student Portfolio</title>
</head>
<body>
    <header>
        <div class="user-logo">
            <p>Asparsh</p>
        </div>
        <nav>
            <ul class="nav-links">
                <li><a href="/portfolio/student/show">Home</a></li>
                <li><a href="/portfolio/student/about">About</a></li>
                <li><a href="/portfolio/student/services">Services</a></li>
                <li><a href="/portfolio/student/portfolio">Portfolio</a></li>
                <li><a href="/portfolio/student/blog">Blog</a></li>
                <li><a href="/portfolio/student/contact" class="contact-link active">Contact Me</a></li>
            </ul>
        </nav>
    </header>
    <main>
        <section class="contact-section">
            <h1>Contact Me</h1>
            <div class="contact-content">
                <div class="contact-info">
                    <h2>Get In Touch</h2>
                    <p>I'd love to hear from you! Whether you have a project in mind or just want to connect, feel free to reach out.</p>
                    <div class="contact-details">
                        <div class="contact-item">
                            <h3>Email</h3>
                            <p>tempmail@example.com</p>
                        </div>
                        <div class="contact-item">
                            <h3>Phone</h3>
                            <p>+1 234 567 890</p>
                        </div>
                        <div class="contact-item">
                            <h3>Location</h3>
                            <p>New York, USA</p>
                        </div>
                    </div>
                </div>
                <div class="contact-form">
                    <form action="/portfolio/student/contact" method="POST">
                        <div class="form-group">
                            <label for="name">Name</label>
                            <input type="text" id="name" name="name" required>
                        </div>
                        <div class="form-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" required>
                        </div>
                        <div class="form-group">
                            <label for="subject">Subject</label>
                            <input type="text" id="subject" name="subject" required>
                        </div>
                        <div class="form-group">
                            <label for="message">Message</label>
                            <textarea id="message" name="message" rows="5" required></textarea>
                        </div>
                        <button type="submit" class="submit-btn">Send Message</button>
                    </form>
                </div>
            </div>
        </section>
    </main>
</body>
</html>

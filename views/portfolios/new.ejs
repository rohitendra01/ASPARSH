<% layout('layouts/dashboard-boilerplate') %>
<% block('styles').append('<link rel="stylesheet" href="/css/portfolio/new.css" />') %>

<div class="user-wizard-root">
  <h1>Create New Portfolio</h1>

  <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
    <input type="hidden" id="_csrf" name="_csrf" value="<%= csrfToken %>">
    <script>window.__CSRF = '<%= csrfToken %>';</script>
  <% } %>

  <nav class="wizard-progress" aria-hidden="false">
    <button data-step="0" class="step-btn active">Profile</button>
    <button data-step="1" class="step-btn">Hero Section</button>
    <button data-step="2" class="step-btn">About</button>
    <button data-step="3" class="step-btn">Skills</button>
    <button data-step="4" class="step-btn">Projects</button>
    <button data-step="5" class="step-btn">Experience</button>
    <button data-step="6" class="step-btn">Testimonials</button>
    <button data-step="7" class="step-btn">Gallery</button>
    <button data-step="8" class="step-btn">Services</button>
    <button data-step="9" class="step-btn">SEO/Theme</button>
    <button data-step="10" class="step-btn">Review</button>
  </nav>

  <form id="portfolioWizardForm" class="wizard-form" novalidate enctype="multipart/form-data">
    <!-- Hidden fields used by the wizard script -->
    <input type="hidden" id="selectedProfileSlug" name="selectedProfileSlug">
    <input type="hidden" id="selectedProfileName" name="selectedProfileName">
    <input type="hidden" id="profileId" name="profileId">
    <div id="autosaveStatus" style="margin:0.5rem 0; font-size:0.9rem; color:#333"></div>
    <!-- Step 0: Profile Reference -->
    <fieldset class="wizard-step active" data-step="0">
      <h2>Link User Profile</h2>
      <label for="profileSearch">Find Profile (by slug, email, or mobile)</label>
      <input type="text" id="profileSearch" name="profileSearch" placeholder="Search..." autocomplete="off" required />
      <div id="profileSearchResults" class="search-results"></div>
      <input type="hidden" id="selectedProfileId" name="selectedProfileId">
      <div id="selectedProfileCard" style="display:none; margin-bottom:1rem;"></div>
      <div class="step-actions"><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 1: Hero Section -->
    <fieldset class="wizard-step" data-step="1">
      <h2>Hero Section</h2>
      <label>Hero Title <input type="text" id="title" name="heroTitle" /></label>
      <label>Hero Subtitle <input type="text" id="tagline" name="heroSubtitle" /></label>
      <label>Description <textarea id="about" name="heroDescription" rows="3"></textarea></label>
      <!-- Social inputs (optional) -->
      <div class="social-inputs" style="margin-top:.5rem">
        <label>Website <input type="url" id="socialWebsite" name="socialWebsite" placeholder="https://example.com"/></label>
        <label>LinkedIn <input type="url" id="socialLinkedin" name="socialLinkedin" placeholder="https://linkedin.com/in/..."/></label>
        <label>Instagram <input type="url" id="socialInstagram" name="socialInstagram" placeholder="https://instagram.com/..."/></label>
      </div>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 2: About Section -->
    <fieldset class="wizard-step" data-step="2">
      <h2>About Section</h2>
      <label>About Description <textarea name="about" rows="4"></textarea></label>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 3: Skills Section -->
    <fieldset class="wizard-step" data-step="3">
      <h2>Skills</h2>
      <div id="skillsList">
        <!-- Dynamic skills inputs: JS will add/remove -->
      </div>
      <button type="button" onclick="addSkill()">Add Skill</button>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 4: Projects -->
    <fieldset class="wizard-step" data-step="4">
      <h2>Projects</h2>
      <div id="projectsList"></div>
      <button type="button" id="addProjectBtn">Add Project</button>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 5: Experience -->
    <fieldset class="wizard-step" data-step="5">
      <h2>Experience Timeline</h2>
      <div id="experienceList"></div>
      <button type="button" onclick="addExperience()">Add Experience</button>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 6: Testimonials -->
    <fieldset class="wizard-step" data-step="6">
      <h2>Testimonials</h2>
      <div id="testimonialsList"></div>
      <button type="button" onclick="addTestimonial()">Add Testimonial</button>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 7: Gallery -->
    <fieldset class="wizard-step" data-step="7">
      <h2>Gallery Images</h2>
      <div id="galleryList"></div>
      <button type="button" onclick="addGalleryImage()">Add Gallery Image</button>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 8: Services -->
    <fieldset class="wizard-step" data-step="8">
      <h2>Services Offered</h2>
      <div id="servicesList"></div>
      <button type="button" id="addServiceBtn">Add Service</button>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 9: SEO and Theme -->
    <fieldset class="wizard-step" data-step="9">
      <h2>SEO and Theme Settings</h2>
      <label>Page Title <input type="text" id="seoTitle" name="seoTitle" /></label>
      <label>Meta Description <textarea id="seoDescription" name="seoDescription" rows="2"></textarea></label>
      <label>Meta Keywords <input type="text" id="seoKeywords" name="seoKeywords" placeholder="Comma separated" /></label>
      <label>OG Image URL <input type="url" id="seoOgImage" name="seoOgImage" /></label>
      <label>Page Theme
        <input type="text" id="themePrimary" name="themePrimary" placeholder="Primary color (e.g. #00c6ff)" />
        <input type="text" id="themeSecondary" name="themeSecondary" placeholder="Secondary color (e.g. #0072ff)" />
        <input type="text" id="themeAccent" name="themeAccent" placeholder="Accent color (e.g. #9c27b0)" />
        <input type="text" id="themeFont" name="themeFont" placeholder="Font family (e.g. Lato)" />
      </label>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="button" data-action="next">Next</button></div>
    </fieldset>
    <!-- Step 10: Review/Submit -->
    <fieldset class="wizard-step" data-step="10">
      <h2>Review & Submit</h2>
      <div id="reviewArea"></div>
      <div class="step-actions"><button type="button" data-action="prev">Back</button><button type="submit" class="btn-primary">Create Portfolio</button></div>
    </fieldset>
  </form>
</div>

<script src="/js/portfolio-wizard.js"></script>

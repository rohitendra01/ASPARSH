<% layout('layouts/boilerplate') -%>
<% block('styles').append(`<link rel="stylesheet" href="/css/asparsh/index-snap.css" />`) %>
<main>
        <section class="size container1 snap-section">
            <div class="hero-text">
                <div class="hero-head-text">
                    <h1>
                        <span id="text1">The future of new </span>
                        <span id="text1">connection is </span>
                        <span id="text2">instant </span>
                        <span id="text2">with NFC technology</span>
                    </h1>
                </div>
                <div class="hero-sub-text">
                    <h3>
                        Empower your business with NFC, turning connectivity issues into opportunities, ensuring
                        customers receive the support they truly deserve.
                    </h3>
                </div>
                <div class="started-button">
                    <a href="/home" class="get-started-link">
                        <button>Get Started</button>
                    </a>
                </div>
            </div>
            <div class="hero-image">
                <img src="/assets/hero-image.jpg" alt="NFC Hero Image">
            </div>
        </section>
        <section class="size container2 snap-section">
            <div class="description-head-text">
                <span>
                    At Asparsh, we offer NFC tag solutions that modernize business connections.
                </span>
                    Our touchless service replaces outdated paper tools, providing digital business cards and product-linked tags for seamless engagement.
                <div class="description-highlited-text">
                    <span >We create interactive, tap-and-go experiences </span><span> that feel both modern and timeless.</span>
                </div>
                </div>
            <div class="description-box">
                <div class="description-card">
                    <div class="card-title">No Paper Cards. Just One Smart Tap.</div>
                    <div class="card-desc">Stop using printed business cards that get lost or discarded. Use NFC tags to share your contact details and websites instantly with just one tap.</div>
                    <div class="card-img-ref"><img src="assets/1.png" alt="A sasmple image"></div>
                </div>
                <div class="description-card">
                    <div class="card-title">No Reprints. Easily Editable.</div>
                    <div class="card-desc">Traditional cards become outdated fast. With NFC, your information is dynamic — update it anytime without needing to reprint. One tag, endless uses.</div>
                    <div class="card-img-ref"><img src="assets/2.png" alt="A sasmple image"></div>
                </div>
                <div class="description-card">
                    <div class="card-title">Built for Every Industry and Role</div>
                    <div class="card-desc">Whether you’re a creator, entrepreneur, recruiter, or business exec — NFC cards adapt to your needs and help you connect smarter.</div>
                    <div class="card-img-ref"><img src="assets/3.png" alt="A sasmple image"></div>
                </div>
            </div>
        </section>
        <section class="size container3 snap-section">
            <div class="container3-head-text">
                <div class="container3-head-text1">
                    <h2>Our Products</h2>
                </div>
                <div class="container3-head-text2">
                    <p>Explore our NFC‑enabled product line designed to streamline and elevate your professional networking.<br>
                    From smart cards to customizable digital profiles, share contact details, portfolio links, and promotional content with a single tap.</p>
                </div>
            </div>
            <div class="swiper">
                <div class="swiper-wrapper">
                    <% products.forEach(product => { %>
                    <div class="swiper-slide">
                        <div class="index-product-card">
                            <div class="index-product-image">
                                <img src="<%= product.image %>" alt="<%= product.title %>">
                            </div>
                            <div class="index-product-content">
                                <div class="index-product-head">
                                    <% if (product.badge) { %>
                                        <div class="flash-message-new"><%= product.badge %></div>
                                        <% } %>
                                        <h2><%= product.title %></h2>
                                        <h3><%= product.subtitle %></h3>
                                    </div>
                                    <div class="index-product-price">
                                        <h3>Price</h3>
                                        <span class="index-product-current-price">₹ <%= product.price %></span>
                                    </div>
                                    <div class="index-product-description-container">
                                        <div class="tab-headers">
                                            <div class="tab-header active" data-tab="description-<%= product.id %>">DESCRIPTION</div>
                                            <div class="tab-header" data-tab="features-<%= product.id %>">DETAILS</div>
                                            <div class="tab-underline"></div>
                                        </div>
                                        <div class="tab-content-wrapper">
                                            <div id="description-<%= product.id %>" class="tab-pane active">
                                                <div class="index-product-description-details"><%= product.description %></div>
                                            </div>
                                            <div id="features-<%= product.id %>" class="tab-pane">
                                                <div class="index-product-description-features">
                                                    <ul>
                                                        <% product.features.forEach(feature => { %>
                                                            <li><%= feature %></li>
                                                            <% }) %>
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="index-product-button">
                                        <button class="buy-now-btn">Buy Now</button>
                                        <button class="explore-more-btn">Explore More</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </section>
        <section class="size container4 snap-section">
            <div class="container4-head-text">
                <h2>How Asparsh Works!</h2>
                <p>Asparsh leverages cutting-edge NFC technology to create seamless and interactive experiences for users. Our platform allows businesses to connect with their customers in innovative ways, enhancing engagement and driving results.</p>
            </div>
           <div class="container4-how-it-works">
                <div class="container4-how-it-works-card">
                        <img src="/assets/how-it-works-1.jpg" alt="Step 1">
                        <div class="container4-how-it-works-card-text">
                            <h3>Step 1</h3>
                            <p>Choose your NFC product and customize it to fit your brand with ease and flexibility.</p>
                        </div>
               </div>
                <div class="container4-how-it-works-card">
                        <img src="/assets/how-it-works-2.jpg" alt="Step 2">
                        <div class="container4-how-it-works-card-text">
                            <h3>Step 2</h3>
                            <p>Share your NFC-enabled product with customers, allowing them to tap and connect instantly.</p>
                        </div>
                </div>
                <div class="container4-how-it-works-card">
                        <img src="/assets/how-it-works-3.jpg" alt="Step 3">
                        <div class="container4-how-it-works-card-text">
                            <h3>Step 3</h3>
                            <p>Engage with your audience through interactive content and track their interactions for better insights.</p>
                        </div>
               </div>
                <div class="container4-how-it-works-card">
                        <img src="/assets/how-it-works-4.jpg" alt="Step 4">
                        <div class="container4-how-it-works-card-text">
                            <h3>Step 4</h3>
                            <p>Analyze the data collected to refine your marketing strategies and improve customer engagement.</p>
                        </div>
                </div> 
            </div>
        </section>
        <section class="size container5 snap-section">
            <div class="container5-head-text">
                <h2>Happy Customers</h2>
                <p>Hear from our satisfied customers who have transformed their business connections with Asparsh.
                    <br>It has always been possible with the help of our innovative solutions. So join the community of happy customers today!
                </p>
            </div>
            <div class="testimonial-carousel">
                <button class="testimonial-carousel-nav prev">&#10094;</button>
                <div class="testimonial-carousel-wrapper">
                  <% testimonials.forEach(function(testimonial, idx) { %>
                    <div class="testimonial-card">
                        <img class="testimonial-avatar" src="<%= testimonial.avatar %>" alt="<%= testimonial.name %>">
                        <div class="testimonial-quote">"<%= testimonial.text %>"</div>
                        <div class="testimonial-user">
                            <div class="testimonial-name"><%= testimonial.name %></div>
                            <div class="testimonial-role"><%= testimonial.role %></div>
                    </div>
                </div>
                  <% }) %>
            </div>
                <button class="testimonial-carousel-nav next">&#10095;</button>
                <div class="testimonial-carousel-dots"></div>
        </section>
        <section class="size container6 snap-section">
            <div class="container6-head-text">
                <h2>Sharing is Caring</h2>
            </div>
            <div class="container6-content">
                <div class="container6-content-text">
                    <p>Share your NFC-enabled products with friends and colleagues. Help them discover the convenience of instant connections and interactive experiences.</p>
                    <p>Join our community of users who are embracing the future of connectivity with Asparsh.</p>
                    
                </div>
                <div class="container6-content-image">
                    <img src="/assets/share-nfc.jpg" alt="Share NFC Products">
                </div>
            </div>
            <p>Spread the word about Asparsh and let others experience the future of connectivity.</p>      
        </section>
</main>
    
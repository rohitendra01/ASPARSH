<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/main-content.css" />
    <link rel="stylesheet" href="/css/nav.css" />
    <title>Asparsh</title>
</head>
<body>
    <div class="navbar">
        <div class="container-fluid">
            <div class="brand-name">
                <a href="/">Asparsh</a>
            </div>
            <div class="navbar-nav">
                <a class="nav-link active" aria-current="page" href="/">Home</a>
                <a class="nav-link active" href="#">Features</a>
                <a class="nav-link active" href="#">Pricing</a>
                <a class="nav-link active" aria-disabled="true">Products</a>
            </div>
            
            <div class="user-dropdown">
                <div class="user-profile-trigger">
                    <img src="/assets/user-login.png" alt="User Profile" style="width: 32px; height: 28px; cursor: pointer;">
                </div>
                
                <div class="user-dropdown-content">
                    <%- include('partials/login') %>
                </div>
            </div>
        </div>
    </div>
    <div class="main-container">
        <div class="main-row1">
            <div class="main-image"></div>
            <div class="main-content">
                <div class="main-line">
                    Make your business Innovative, Engaging and Digital
                </div>
                <div class="main-text">
                    We make NFC integrated QR codes for your visiting cards, digital menus, portfolios and many more.
                </div>
            </div>
        </div>
        <div class="main-row2">
            <div class="main-tag-line">
                One Tap One Scan Total Digital Experience
            </div>
            <div class="main-button">
                <a href="/generate">Products</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
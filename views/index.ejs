<% layout('layouts/boilerplate') -%>
<% block('styles').append(`
<link rel="stylesheet" href="/css/asparsh/index.css" />
<style>
/* Critical CSS for above-the-fold content */
.hero-section {
  min-height: calc(100vh - var(--header-height));
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  color: var(--text-inverse);
}
</style>
`) %>

<% block('scripts').append(`
<script src="/js/modern-products-slider.js" defer></script>
`) %>

    <!-- Hero Section -->
    <section class="hero-section" aria-labelledby="hero-title">
    <div class="hero-container">
        <div class="hero-content animate-on-scroll">
            <div class="hero-badge">
                <div class="badge-icon">⚡</div>
                <span>The Future of Connections</span>
            </div>
                
                <h1 id="hero-title" class="hero-title">
                    The future of new connection is 
                    <span class="highlight">instant</span> 
                    with NFC technology
                </h1>
                
                <p class="hero-description">
                    Empower your business with cutting-edge NFC technology, turning connectivity challenges into opportunities, ensuring customers receive the exceptional support they truly deserve.
                </p>
                
                <div class="hero-actions">
                    <a href="/home" class="hero-cta" aria-describedby="cta-description">
                        <span>Get Started</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </a>
                    <a href="#features" class="hero-secondary">
                        <span>Learn More</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M6 9l6 6 6-6"/>
                        </svg>
                    </a>
                </div>
                
                <p id="cta-description" class="sr-only">
                    Start your journey with Asparsh's NFC technology solutions
                </p>
            </div>
            
            <div class="hero-visual animate-on-scroll">
                <img 
                    src="/assets/hero-image.jpg" 
                    alt="Professional demonstrating NFC technology with modern smart devices and digital business cards"
                    class="hero-image"
                    loading="eager"
                    width="500"
                    height="400"
                >
                
                <!-- Floating elements for visual interest -->
                <div class="hero-floating float-1" aria-hidden="true">
                    <span>Instant Connection</span>
                </div>
                <div class="hero-floating float-2" aria-hidden="true">
                    <span>Zero Contact</span>
                </div>
                <div class="hero-floating float-3" aria-hidden="true">
                    <span>100% Digital</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features-section" aria-labelledby="features-title">
        <div class="features-container">
            <div class="section-header animate-on-scroll">
                <h2 id="features-title" class="features-title">
                    Instant NFC Connections
                </h2>
                <p class="features-description">
                    <span>At Asparsh, we offer innovative NFC tag solutions that modernize business interactions. </span><span>
                    Our touchless technology replaces outdated paper tools, providing seamless digital experiences 
                    that feel both cutting-edge and timeless.</span>
                </p>
            </div>
            
            <div class="features-grid">
                <article class="feature-card animate-on-scroll">
                    <div class="feature-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L2 7v10c0 5.55 3.84 10 10 10s10-4.45 10-10V7L12 2z"/>
                            <path d="M8 11l2 2 4-4"/>
                        </svg>
                    </div>
                    <h3 class="feature-title">No Paper Cards. Just One Smart Tap.</h3>
                    <p class="feature-description">
                        Eliminate printed business cards that get lost or discarded. Use NFC tags to share 
                        contact details and websites instantly with just one tap, creating memorable 
                        first impressions.
                    </p>
                </article>
                
                <article class="feature-card animate-on-scroll">
                    <div class="feature-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                    </div>
                    <h3 class="feature-title">No Reprints. Easily Editable.</h3>
                    <p class="feature-description">
                        Traditional cards become outdated fast. With NFC, your information is dynamic — 
                        update it anytime without needing to reprint. One tag, endless possibilities, 
                        always current.
                    </p>
                </article>
                
                <article class="feature-card animate-on-scroll">
                    <div class="feature-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <h3 class="feature-title">Built for Every Industry and Role</h3>
                    <p class="feature-description">
                        Whether you're a creator, entrepreneur, recruiter, or business executive — 
                        NFC cards adapt to your unique needs and help you connect smarter, 
                        faster, and more effectively.
                    </p>
                </article>
            </div>
        </div>
    </section>

    <!-- Products Section -->
    <section class="products-section" aria-labelledby="products-title">
        <div class="products-container">
            <div class="testimonials-header animate-on-scroll">
                <h2 id="products-title" class="products-title">Our Products</h2>
                <p class="products-description">
                    Explore our NFC-enabled product line designed to streamline and elevate your professional networking. 
                    From smart cards to customizable digital profiles, share content with a single tap.
                </p>
            </div>
            
            <div class="products-swiper swiper animate-on-scroll" 
                 tabindex="0" 
                 role="group" 
                 aria-label="Product slider - use arrow keys to navigate">
                <div class="swiper-wrapper">
                <% if (typeof products !== 'undefined' && products && products.length > 0) { %>
                <% products.forEach((product, index) => { %>
                            <div class="swiper-slide">
                                <div class="index-product-card">
                                    <div class="index-product-image">
                                        <img src="<%= product.image %>" alt="<%= product.title %>">
                                    </div>
                                    <div class="index-product-content">
                                        <div class="index-product-head">
                                            <% if (product.badge) { %>
                                                <div class="flash-message-<%= product.badge.toLowerCase().replace(' ', '-') %>"><%= product.badge %></div>
                                            <% } %>
                                            <h2><%= product.title %></h2>
                                            <h3><%= product.subtitle %></h3>
                                        </div>
                                        <div class="index-product-price">
                                            <h3>Price</h3>
                                            <span class="index-product-current-price">₹ <%= product.price %></span>
                                        </div>
                                        <div class="index-product-description-container">
                                            <div class="tab-headers">
                                                <div class="tab-header active" data-tab="description-<%= product.id %>">DESCRIPTION</div>
                                                <div class="tab-header" data-tab="features-<%= product.id %>">DETAILS</div>
                                                <div class="tab-underline"></div>
                                            </div>
                                            <div class="tab-content-wrapper">
                                                <div id="description-<%= product.id %>" class="tab-pane active index-product-description-details">
                                                    <p><%= product.description %></p>
                                                </div>
                                                <div id="features-<%= product.id %>" class="tab-pane index-product-description-features">
                                                    <ul>
                                                        <% product.features.forEach(feature => { %>
                                                            <li><%= feature %></li>
                                                        <% }) %>
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="index-product-button">
                                            <button class="buy-now-btn" data-product-id="<%= product.id %>">Buy Now</button>
                                            <button class="explore-more-btn" data-product-id="<%= product.id %>">Explore More</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                            <% } %>
                        
				</div>
                
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="how-it-works-section" aria-labelledby="how-it-works-title">
        <div class="how-it-works-container">
            <div class="section-header animate-on-scroll">
                <h2 id="how-it-works-title" class="how-it-works-title">How Asparsh Works!</h2>
                <p class="how-it-works-description">
                    Asparsh leverages cutting-edge NFC technology to create seamless and interactive experiences. 
                    Our platform helps businesses connect with customers in innovative ways, enhancing engagement and driving results.
                </p>
            </div>
            
            <div class="steps-grid">
                <article class="step-card animate-on-scroll">
                    <div class="step-number" aria-hidden="true">1</div>
                    <div class="step-image">
                        <img 
                            src="/assets/how-it-works-1.jpg" 
                            alt="Step 1: Choose and customize your NFC product"
                            loading="lazy"
                            width="200"
                            height="200"
                        >
                    </div>
                    <h3 class="step-title">Choose & Customize</h3>
                    <p class="step-description">
                        Select your NFC product and customize it to perfectly match your brand 
                        with our intuitive design tools and professional templates.
                    </p>
                </article>
                
                <article class="step-card animate-on-scroll">
                    <div class="step-number" aria-hidden="true">2</div>
                    <div class="step-image">
                        <img 
                            src="/assets/how-it-works-2.jpg" 
                            alt="Step 2: Configure your digital content and links"
                            loading="lazy"
                            width="200"
                            height="200"
                        >
                    </div>
                    <h3 class="step-title">Configure Content</h3>
                    <p class="step-description">
                        Set up your digital profile, contact information, social links, and 
                        any other content you want to share instantly with a simple tap.
                    </p>
                </article>
                
                <article class="step-card animate-on-scroll">
                    <div class="step-number" aria-hidden="true">3</div>
                    <div class="step-image">
                        <img 
                            src="/assets/how-it-works-3.jpg" 
                            alt="Step 3: Receive your professionally crafted NFC product"
                            loading="lazy"
                            width="200"
                            height="200"
                        >
                    </div>
                    <h3 class="step-title">Receive & Deploy</h3>
                    <p class="step-description">
                        Get your professionally crafted NFC product delivered to your door, 
                        ready to use immediately with all your content pre-configured.
                    </p>
                </article>
                
                <article class="step-card animate-on-scroll">
                    <div class="step-number" aria-hidden="true">4</div>
                    <div class="step-image">
                        <img 
                            src="/assets/how-it-works-4.jpg" 
                            alt="Step 4: Connect and engage with your audience effortlessly"
                            loading="lazy"
                            width="200"
                            height="200"
                        >
                    </div>
                    <h3 class="step-title">Connect & Engage</h3>
                    <p class="step-description">
                        Start connecting with your audience effortlessly. Track engagement, 
                        update content anytime, and watch your network grow exponentially.
                    </p>
                </article>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section class="testimonials-section" aria-labelledby="testimonials-title">
        <div class="testimonials-container">
            <div class="section-header animate-on-scroll">
                <h2 id="testimonials-title" class="testimonials-title">Happy Customers</h2>
                <p class="testimonials-description">
                    Hear from our satisfied customers who have transformed their business connections with Asparsh. 
                    Join the community of professionals embracing the future of networking today!
                </p>
            </div>
            
            <div class="testimonials-carousel-wrapper animate-on-scroll">
                <div class="testimonials-carousel" id="testimonialsCarousel">
                    <div class="testimonials-track" id="testimonialsTrack">
                        <% if (typeof testimonials !== 'undefined' && testimonials && testimonials.length > 0) { %>
                        <% testimonials.forEach((testimonial, index) => { %>
                        <div class="testimonial-card">
                            <div class="testimonial-avatar">
                                <img src="<%= testimonial.avatar %>" alt="<%= testimonial.name %>" loading="lazy">
                            </div>
                            <h3 class="testimonial-name"><%= testimonial.name %></h3>
                            <p class="testimonial-role"><%= testimonial.role %></p>
                            <blockquote class="testimonial-quote">
                                "<%= testimonial.text %>"
                            </blockquote>
                        </div>
                        <% }) %>
                        <% } %>
                    </div>
                    
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section" aria-labelledby="cta-title">
        <div class="cta-container">
            <h2 id="cta-title" class="cta-title animate-on-scroll">
                Ready to Transform Your Connections?
            </h2>
            <p class="cta-description animate-on-scroll">
                Join thousands of professionals who have already embraced the future of networking. 
                Experience the power of NFC technology and see the difference it makes for your business.
            </p>
            <div class="cta-actions animate-on-scroll">
                <a href="/home" class="footer-cta-button">
                    <span>Get Started Today</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
                <a href="/contact" class="cta-secondary">
                    <span>Contact Us</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                </a>
            </div>
        </div>
    </section>

    <!-- Join Us / Sharing Section -->
    <section class="sharing-section" aria-labelledby="sharing-title">
        <div class="sharing-container">
            <div class="sharing-content animate-on-scroll">
                <div class="section-header">
                    <h2 id="sharing-title" class="sharing-title">Sharing is Caring</h2>
                </div>
                
                <div class="sharing-body">
                    <div class="sharing-text">
                        <p>Share your NFC-enabled products with friends and colleagues. Help them discover the convenience of instant connections and interactive experiences.</p>
                        <p>Join our community of users who are embracing the future of connectivity with Asparsh.</p>
                        <p class="sharing-cta-text">Spread the word about Asparsh and let others experience the future of connectivity.</p>
                    </div>
                    
                    <div class="sharing-image">
                        <img 
                            src="/assets/share-nfc.jpg" 
                            alt="Share NFC Products with friends and colleagues"
                            loading="lazy"
                            width="400"
                            height="300"
                        >
                    </div>
                </div>
            </div>
        </div>
    </section>
